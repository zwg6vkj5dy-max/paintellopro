<%- include('../partials/header', { title: title }) %>

<!-- Add Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
/* VOTRE CSS EXISTANT RESTE IDENTIQUE */
.swiper {
    width: 100%;
    height: 400px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
}

.swiper-slide {
    text-align: center;
    background: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.swiper-slide:hover {
    transform: scale(1.02);
}

.swiper-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.swiper-button-next,
.swiper-button-prev {
    color: white;
    background: rgba(0,0,0,0.5);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    backdrop-filter: blur(10px);
}

.swiper-button-next:after,
.swiper-button-prev:after {
    font-size: 20px;
    font-weight: bold;
}

.swiper-pagination-bullet {
    background: white;
    opacity: 0.6;
    width: 12px;
    height: 12px;
}

.swiper-pagination-bullet-active {
    background: #007bff;
    opacity: 1;
}

/* Lightbox Styles */
.portfolio-lightbox .swiper-slide {
    cursor: zoom-in;
}

.portfolio-lightbox .swiper-slide:hover::after {
    content: '🔍 Click to enlarge';
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    backdrop-filter: blur(10px);
}

/* Project Info Overlay */
.project-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    color: white;
    padding: 60px 20px 20px 20px;
    transform: translateY(100%);
    transition: transform 0.3s ease;
}

.swiper-slide:hover .project-info-overlay {
    transform: translateY(0);
}

.project-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 8px;
}

.project-description {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-bottom: 0;
}

/* Thumbnail Navigation */
.thumbnail-swiper {
    height: 100px;
    margin-top: 15px;
}

.thumbnail-swiper .swiper-slide {
    opacity: 0.4;
    transition: opacity 0.3s ease;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
}

.thumbnail-swiper .swiper-slide-thumb-active {
    opacity: 1;
    border: 3px solid #007bff;
}

.thumbnail-swiper .swiper-slide img {
    height: 100%;
    object-fit: cover;
}

/* Lightbox Modal */
.lightbox-modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.95);
    backdrop-filter: blur(10px);
}

.lightbox-content {
    position: relative;
    margin: 2% auto;
    padding: 20px;
    width: 90%;
    height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.lightbox-image {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.lightbox-info {
    color: white;
    text-align: center;
    margin-top: 20px;
    max-width: 600px;
}

.lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    color: white;
    font-size: 2rem;
    font-weight: bold;
    cursor: pointer;
    background: rgba(0,0,0,0.5);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255,255,255,0.2);
}

.lightbox-nav {
    position: absolute;
    top: 50%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    transform: translateY(-50%);
}

.lightbox-nav button {
    background: rgba(0,0,0,0.5);
    color: white;
    border: 2px solid rgba(255,255,255,0.2);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
}

.lightbox-nav button:hover {
    background: #007bff;
    border-color: #007bff;
}

/* Responsive Design */
@media (max-width: 768px) {
    .swiper {
        height: 300px;
    }
    
    .thumbnail-swiper {
        height: 80px;
    }
    
    .lightbox-content {
        width: 95%;
        height: 95%;
    }
    
    .lightbox-nav button {
        width: 50px;
        height: 50px;
        font-size: 1.2rem;
    }
}

/* Loading Animation */
.swiper-lazy-preloader {
    border-color: #007bff transparent transparent transparent;
}

.project-count {
    background: #007bff;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-left: 10px;
}

/* Image Counter */
.image-counter {
    position: absolute;
    top: 20px;
    left: 20px;
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.9rem;
    backdrop-filter: blur(10px);
    z-index: 10;
}
</style>

<div class="container py-4">
    <!-- Profile Header (identique) -->
    <div class="row mb-5">
        <div class="col-md-4 text-center">
            <div class="avatar-large mb-3 mx-auto" style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden; background: #f8f9fa;">
                <% if (painter.profilePicture && painter.profilePicture.url) { %>
                    <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" 
                         style="width: 100%; height: 100%; object-fit: cover;"
                         onerror="this.src='https://via.placeholder.com/150/007bff/ffffff?text=P'">
                <% } else { %>
                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-primary">
                        <i class="fas fa-brush fa-3x text-white"></i>
                    </div>
                <% } %>
            </div>
            
            <% if (isVerified) { %>
            <div class="mb-3">
                <span class="badge bg-success fs-6">
                    <i class="fas fa-check-circle me-1"></i>Verified Pro Painter
                </span>
            </div>
            <% } %>
            
            <div class="mb-3">
                <h4 class="text-primary mb-1"><%= painter.pricePerSqm %> DZD</h4>
                <small class="text-muted">Price per m²</small>
            </div>
            
            <a href="/painters/<%= painter._id %>/order" class="btn btn-primary btn-lg w-100 mb-2">
                <i class="fas fa-paint-roller me-2"></i>Hire This Painter
            </a>
            
            <% if (!user) { %>
            <small class="text-muted">No account needed - order as guest</small>
            <% } %>
        </div>
        
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h1 class="h2 mb-1"><%= painter.name %></h1>
                    <p class="text-muted mb-2">
                        <i class="fas fa-map-marker-alt me-1"></i>
                        <%= painter.location.wilaya %>, Algeria
                        <% if (painter.location.address) { %>
                            <br><small class="text-muted"><%= painter.location.address %></small>
                        <% } %>
                    </p>
                    
                    <div class="d-flex align-items-center mb-3">
                        <div class="star-rating me-2">
                            <% for (let i = 1; i <= 5; i++) { %>
                            <i class="fas fa-star <%= i <= (painter.rating || 0) ? 'text-warning' : 'text-muted' %> fs-5"></i>
                            <% } %>
                        </div>
                        <span class="fw-bold me-2"><%= (painter.rating || 0).toFixed(1) %></span>
                        <span class="text-muted">(<%= painter.completedJobs || 0 %> jobs completed)</span>
                    </div>
                </div>
                
                <div class="text-end">
                    <% if (painter.availability === 'available') { %>
                    <span class="badge bg-success fs-6 p-2">
                        <i class="fas fa-check-circle me-1"></i>Available
                    </span>
                    <% } else if (painter.availability === 'busy') { %>
                    <span class="badge bg-warning fs-6 p-2">
                        <i class="fas fa-clock me-1"></i>Busy
                    </span>
                    <% } else { %>
                    <span class="badge bg-secondary fs-6 p-2">
                        <i class="fas fa-times-circle me-1"></i>Unavailable
                    </span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Portfolio Section CORRIGÉE -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-0">
                    <h4 class="mb-0 d-flex align-items-center">
                        <i class="fas fa-images me-2"></i>Portfolio Gallery
                        <% if (painter.portfolio && painter.portfolio.length > 0) { %>
                        <span class="project-count">
                            <%= painter.portfolio.length %> <%= painter.portfolio.length === 1 ? 'Project' : 'Projects' %>
                        </span>
                        <% } %>
                    </h4>
                </div>
                <div class="card-body p-4">
                    <% 
                    // DEBUG: Vérifions ce que nous recevons
                    console.log('=== DEBUG PORTFOLIO DATA ===');
                    console.log('Portfolio exists:', !!painter.portfolio);
                    console.log('Portfolio length:', painter.portfolio ? painter.portfolio.length : 0);
                    
                    const portfolio = painter.portfolio || [];
                    const allImages = [];
                    let totalImages = 0;
                    
                    // CORRECTION: Collecter TOUTES les images de TOUS les projets
                    portfolio.forEach((project, projectIndex) => {
                        console.log(`Project ${projectIndex}:`, project.title);
                        console.log('Project images:', project.images);
                        
                        if (project.images && Array.isArray(project.images)) {
                            project.images.forEach((img, imgIndex) => {
                                console.log(`  Image ${imgIndex}:`, img.url);
                                allImages.push({
                                    url: img.url,
                                    projectTitle: project.title || `Project ${projectIndex + 1}`,
                                    description: project.description,
                                    category: project.category,
                                    uploadedAt: project.uploadedAt,
                                    projectIndex: projectIndex,
                                    imageIndex: imgIndex,
                                    totalInProject: project.images.length
                                });
                                totalImages++;
                            });
                        }
                    });
                    
                    console.log('Total images collected:', totalImages);
                    console.log('All images array:', allImages);
                    %>
                    
                    <!-- Debug Info (à supprimer après test) -->
                    <div class="alert alert-info d-none">
                        <strong>Debug Info:</strong><br>
                        Portfolio Projects: <%= portfolio.length %><br>
                        Total Images: <%= totalImages %><br>
                        All Images Array Length: <%= allImages.length %>
                    </div>
                    
                    <% if (allImages.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No portfolio images yet</h5>
                        <p class="text-muted">This painter hasn't uploaded any project photos</p>
                    </div>
                    <% } else { %>
                    
                    <!-- Image Counter -->
                    <div class="image-counter">
                        <i class="fas fa-images me-1"></i>
                        <%= totalImages %> images
                    </div>

                    <!-- Main Slider -->
                    <div class="swiper portfolio-lightbox mb-3">
                        <div class="swiper-wrapper">
                            <% allImages.forEach((image, index) => { %>
                            <div class="swiper-slide" 
                                 data-image-index="<%= index %>"
                                 onclick="openLightbox(<%= index %>)">
                                 
                                <img src="<%= image.url %>" 
                                     alt="<%= image.projectTitle %>"
                                     onerror="this.src='https://via.placeholder.com/800x400/f8f9fa/6c757d?text=Project+Image'">
                                
                                <div class="project-info-overlay">
                                    <div class="project-title">
                                        <%= image.projectTitle %>
                                        <% if (image.totalInProject > 1) { %>
                                        <span class="badge bg-info ms-2">
                                            Image <%= image.imageIndex + 1 %> of <%= image.totalInProject %>
                                        </span>
                                        <% } %>
                                    </div>
                                    <% if (image.description) { %>
                                    <div class="project-description">
                                        <%= image.description.length > 100 ? image.description.substring(0, 100) + '...' : image.description %>
                                    </div>
                                    <% } %>
                                    <div class="project-meta mt-2">
                                        <% if (image.category) { %>
                                        <span class="badge bg-primary me-2"><%= image.category %></span>
                                        <% } %>
                                        <% if (image.uploadedAt) { %>
                                        <small>
                                            <i class="fas fa-calendar me-1"></i>
                                            <%= new Date(image.uploadedAt).toLocaleDateString() %>
                                        </small>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                        
                        <!-- Navigation Buttons -->
                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                        
                        <!-- Pagination -->
                        <div class="swiper-pagination"></div>
                    </div>

                    <!-- Thumbnail Slider -->
                    <div class="swiper thumbnail-swiper">
                        <div class="swiper-wrapper">
                            <% allImages.forEach((image, index) => { %>
                            <div class="swiper-slide" data-index="<%= index %>">
                                <img src="<%= image.url %>" 
                                     alt="Thumbnail <%= index + 1 %>"
                                     onerror="this.src='https://via.placeholder.com/100x60/f8f9fa/6c757d?text=Thumb'">
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightboxModal" class="lightbox-modal">
        <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
        
        <!-- Image Counter in Lightbox -->
        <div class="image-counter">
            <span id="lightboxCounter">1/<%= allImages.length %></span>
        </div>
        
        <div class="lightbox-nav">
            <button onclick="changeLightboxImage(-1)">❮</button>
            <button onclick="changeLightboxImage(1)">❯</button>
        </div>
        
        <div class="lightbox-content">
            <img id="lightboxImage" class="lightbox-image" src="" alt="">
            <div class="lightbox-info">
                <h4 id="lightboxTitle" class="mb-3"></h4>
                <p id="lightboxDescription" class="mb-3"></p>
                <div class="d-flex justify-content-center gap-3 align-items-center">
                    <span id="lightboxCategory" class="badge bg-primary"></span>
                    <span id="lightboxProjectInfo" class="text-muted small"></span>
                    <span id="lightboxDate" class="text-muted small"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Jobs Section -->
    <% if (recentJobs && recentJobs.length > 0) { %>
    <div class="row mt-4">
        <div class="col-12">
            <!-- Votre section recent jobs -->
        </div>
    </div>
    <% } %>
</div>

<!-- Add Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
// Global variables
let currentLightboxIndex = 0;
const allImages = <%= JSON.stringify(allImages) %>;

// DEBUG: Vérifier les données dans la console
console.log('=== CLIENT-SIDE DEBUG ===');
console.log('All images loaded:', allImages.length);
console.log('All images data:', allImages);

// Initialize Swiper
const swiper = new Swiper('.portfolio-lightbox', {
    loop: true,
    lazy: true,
    spaceBetween: 10,
    navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
    },
    pagination: {
        el: '.swiper-pagination',
        clickable: true,
    },
    autoplay: {
        delay: 5000,
        disableOnInteraction: false,
    },
    effect: 'slide',
    speed: 600,
});

// Initialize Thumbnail Swiper
const thumbnailSwiper = new Swiper('.thumbnail-swiper', {
    loop: true,
    spaceBetween: 10,
    slidesPerView: 6,
    freeMode: true,
    watchSlidesProgress: true,
    breakpoints: {
        320: {
            slidesPerView: 3,
        },
        768: {
            slidesPerView: 4,
        },
        1024: {
            slidesPerView: 6,
        },
    },
});

// Connect main slider with thumbnails
swiper.controller.control = thumbnailSwiper;
thumbnailSwiper.controller.control = swiper;

// Lightbox Functions
function openLightbox(index) {
    console.log('Opening lightbox for image:', index);
    currentLightboxIndex = index;
    updateLightboxContent();
    document.getElementById('lightboxModal').style.display = 'block';
    document.body.style.overflow = 'hidden';
}

function closeLightbox() {
    document.getElementById('lightboxModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

function changeLightboxImage(direction) {
    currentLightboxIndex += direction;
    
    if (currentLightboxIndex < 0) {
        currentLightboxIndex = allImages.length - 1;
    } else if (currentLightboxIndex >= allImages.length) {
        currentLightboxIndex = 0;
    }
    
    updateLightboxContent();
}

function updateLightboxContent() {
    const image = allImages[currentLightboxIndex];
    console.log('Updating lightbox with image:', image);
    
    document.getElementById('lightboxImage').src = image.url;
    document.getElementById('lightboxTitle').textContent = image.projectTitle;
    document.getElementById('lightboxDescription').textContent = image.description || '';
    document.getElementById('lightboxCounter').textContent = `${currentLightboxIndex + 1}/${allImages.length}`;
    
    // Update category
    const categoryEl = document.getElementById('lightboxCategory');
    if (image.category) {
        categoryEl.textContent = image.category;
        categoryEl.style.display = 'inline-block';
    } else {
        categoryEl.style.display = 'none';
    }
    
    // Update project info
    const projectInfoEl = document.getElementById('lightboxProjectInfo');
    if (image.totalInProject > 1) {
        projectInfoEl.textContent = `Image ${image.imageIndex + 1} of ${image.totalInProject}`;
        projectInfoEl.style.display = 'inline-block';
    } else {
        projectInfoEl.style.display = 'none';
    }
    
    // Update date
    const dateEl = document.getElementById('lightboxDate');
    if (image.uploadedAt) {
        dateEl.textContent = new Date(image.uploadedAt).toLocaleDateString();
        dateEl.style.display = 'inline-block';
    } else {
        dateEl.style.display = 'none';
    }
}

// Keyboard navigation
document.addEventListener('keydown', function(e) {
    const lightbox = document.getElementById('lightboxModal');
    if (lightbox.style.display === 'block') {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') changeLightboxImage(-1);
        if (e.key === 'ArrowRight') changeLightboxImage(1);
    }
});

// Close lightbox when clicking outside image
document.getElementById('lightboxModal').addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
});

// Swipe gestures for mobile
let touchStartX = 0;
let touchEndX = 0;

document.getElementById('lightboxModal').addEventListener('touchstart', e => {
    touchStartX = e.changedTouches[0].screenX;
});

document.getElementById('lightboxModal').addEventListener('touchend', e => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
});

function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
            changeLightboxImage(1); // Swipe left - next
        } else {
            changeLightboxImage(-1); // Swipe right - previous
        }
    }
}
</script>

<%- include('../partials/footer') %>
