<%- include('../partials/header', { title: title }) %>

<!-- Add Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
.swiper {
    width: 100%;
    height: 500px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
}

.swiper-slide {
    text-align: center;
    background: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    cursor: pointer;
    transition: all 0.4s ease;
}

.swiper-slide:hover {
    transform: scale(1.05);
    z-index: 10;
}

.swiper-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}

.swiper-slide:hover img {
    transform: scale(1.1);
}

.swiper-button-next,
.swiper-button-prev {
    color: white;
    background: rgba(0,0,0,0.7);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    backdrop-filter: blur(20px);
    border: 2px solid rgba(255,255,255,0.3);
    transition: all 0.3s ease;
}

.swiper-button-next:hover,
.swiper-button-prev:hover {
    background: #007bff;
    transform: scale(1.1);
}

.swiper-button-next:after,
.swiper-button-prev:after {
    font-size: 24px;
    font-weight: bold;
}

.swiper-pagination-bullet {
    background: white;
    opacity: 0.6;
    width: 14px;
    height: 14px;
    transition: all 0.3s ease;
}

.swiper-pagination-bullet-active {
    background: #007bff;
    opacity: 1;
    transform: scale(1.2);
}

/* Project Info Overlay */
.project-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.9));
    color: white;
    padding: 80px 30px 30px 30px;
    transform: translateY(100%);
    transition: transform 0.4s ease;
    backdrop-filter: blur(10px);
}

.swiper-slide:hover .project-info-overlay {
    transform: translateY(0);
}

.project-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 12px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

.project-description {
    font-size: 1rem;
    opacity: 0.95;
    margin-bottom: 15px;
    line-height: 1.5;
}

.project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    opacity: 0.9;
}

/* Thumbnail Navigation */
.thumbnail-swiper {
    height: 120px;
    margin-top: 20px;
    padding: 10px 0;
}

.thumbnail-swiper .swiper-slide {
    opacity: 0.5;
    transition: all 0.3s ease;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    transform: scale(0.9);
}

.thumbnail-swiper .swiper-slide:hover {
    opacity: 0.8;
    transform: scale(0.95);
}

.thumbnail-swiper .swiper-slide-thumb-active {
    opacity: 1;
    border: 3px solid #007bff;
    transform: scale(1);
    box-shadow: 0 8px 25px rgba(0,123,255,0.3);
}

.thumbnail-swiper .swiper-slide img {
    height: 100%;
    object-fit: cover;
}

/* Lightbox Modal */
.lightbox-modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.98);
    backdrop-filter: blur(20px);
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.lightbox-content {
    position: relative;
    margin: 1% auto;
    padding: 20px;
    width: 95%;
    height: 95%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.lightbox-image {
    max-width: 90%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    animation: zoomIn 0.4s ease;
}

@keyframes zoomIn {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

.lightbox-info {
    color: white;
    text-align: center;
    margin-top: 30px;
    max-width: 700px;
    background: rgba(255,255,255,0.1);
    padding: 20px;
    border-radius: 12px;
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.2);
}

.lightbox-close {
    position: absolute;
    top: 30px;
    right: 40px;
    color: white;
    font-size: 2.5rem;
    font-weight: bold;
    cursor: pointer;
    background: rgba(0,0,0,0.6);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(20px);
    border: 2px solid rgba(255,255,255,0.3);
    transition: all 0.3s ease;
    z-index: 10000;
}

.lightbox-close:hover {
    background: #dc3545;
    transform: scale(1.1);
}

.lightbox-nav {
    position: absolute;
    top: 50%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 30px;
    transform: translateY(-50%);
    z-index: 10000;
}

.lightbox-nav button {
    background: rgba(0,0,0,0.7);
    color: white;
    border: 2px solid rgba(255,255,255,0.3);
    width: 70px;
    height: 70px;
    border-radius: 50%;
    font-size: 1.8rem;
    cursor: pointer;
    backdrop-filter: blur(20px);
    transition: all 0.3s ease;
}

.lightbox-nav button:hover {
    background: #007bff;
    border-color: #007bff;
    transform: scale(1.1);
}

/* Image Counter */
.image-counter {
    position: absolute;
    top: 30px;
    left: 30px;
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 10px 20px;
    border-radius: 25px;
    font-size: 0.9rem;
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.2);
    z-index: 10;
}

/* Zoom Indicator */
.zoom-indicator {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(20px);
}

.swiper-slide:hover .zoom-indicator {
    opacity: 1;
}

/* Responsive Design */
@media (max-width: 768px) {
    .swiper {
        height: 350px;
    }
    
    .thumbnail-swiper {
        height: 80px;
    }
    
    .lightbox-content {
        width: 98%;
        height: 98%;
        padding: 10px;
    }
    
    .lightbox-nav button {
        width: 50px;
        height: 50px;
        font-size: 1.3rem;
    }
    
    .lightbox-close {
        top: 15px;
        right: 20px;
        width: 45px;
        height: 45px;
        font-size: 1.8rem;
    }
    
    .project-info-overlay {
        padding: 60px 20px 20px 20px;
    }
    
    .project-title {
        font-size: 1.2rem;
    }
}

.project-count {
    background: #007bff;
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-left: 10px;
}
</style>

<div class="container py-4">
    <!-- Profile Header -->
    <div class="row mb-5">
        <div class="col-md-4 text-center">
            <div class="avatar-large mb-3 mx-auto" style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden; background: #f8f9fa;">
                <% if (painter.profilePicture && painter.profilePicture.url) { %>
                    <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" 
                         style="width: 100%; height: 100%; object-fit: cover;"
                         onerror="this.src='https://via.placeholder.com/150/007bff/ffffff?text=P'">
                <% } else { %>
                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-primary">
                        <i class="fas fa-brush fa-3x text-white"></i>
                    </div>
                <% } %>
            </div>
            
            <% if (isVerified) { %>
            <div class="mb-3">
                <span class="badge bg-success fs-6">
                    <i class="fas fa-check-circle me-1"></i>Verified Pro Painter
                </span>
            </div>
            <% } %>
            
            <div class="mb-3">
                <h4 class="text-primary mb-1"><%= painter.pricePerSqm %> DZD</h4>
                <small class="text-muted">Price per m²</small>
            </div>
            
            <a href="/painters/<%= painter._id %>/order" class="btn btn-primary btn-lg w-100 mb-2">
                <i class="fas fa-paint-roller me-2"></i>Hire This Painter
            </a>
            
            <% if (!user) { %>
            <small class="text-muted">No account needed - order as guest</small>
            <% } %>
        </div>
        
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h1 class="h2 mb-1"><%= painter.name %></h1>
                    <p class="text-muted mb-2">
                        <i class="fas fa-map-marker-alt me-1"></i>
                        <%= painter.location.wilaya %>, Algeria
                        <% if (painter.location.address) { %>
                            <br><small class="text-muted"><%= painter.location.address %></small>
                        <% } %>
                    </p>
                    
                    <div class="d-flex align-items-center mb-3">
                        <div class="star-rating me-2">
                            <% for (let i = 1; i <= 5; i++) { %>
                            <i class="fas fa-star <%= i <= (painter.rating || 0) ? 'text-warning' : 'text-muted' %> fs-5"></i>
                            <% } %>
                        </div>
                        <span class="fw-bold me-2"><%= (painter.rating || 0).toFixed(1) %></span>
                        <span class="text-muted">(<%= painter.completedJobs || 0 %> jobs completed)</span>
                    </div>
                </div>
                
                <div class="text-end">
                    <% if (painter.availability === 'available') { %>
                    <span class="badge bg-success fs-6 p-2">
                        <i class="fas fa-check-circle me-1"></i>Available
                    </span>
                    <% } else if (painter.availability === 'busy') { %>
                    <span class="badge bg-warning fs-6 p-2">
                        <i class="fas fa-clock me-1"></i>Busy
                    </span>
                    <% } else { %>
                    <span class="badge bg-secondary fs-6 p-2">
                        <i class="fas fa-times-circle me-1"></i>Unavailable
                    </span>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Portfolio Section CORRIGÉE -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-0">
                    <h4 class="mb-0 d-flex align-items-center">
                        <i class="fas fa-images me-2"></i>Portfolio Gallery
                        <% if (painter.portfolio && painter.portfolio.length > 0) { %>
                        <span class="project-count">
                            <%= painter.portfolio.length %> <%= painter.portfolio.length === 1 ? 'Project' : 'Projects' %>
                        </span>
                        <% } %>
                    </h4>
                </div>
                <div class="card-body p-4">
                    <% 
                    const portfolio = painter.portfolio || [];
                    const allImages = [];
                    let totalImages = 0;
                    
                    // CORRECTION: Collecter TOUTES les images
                    portfolio.forEach((project, projectIndex) => {
                        if (project.images && Array.isArray(project.images)) {
                            project.images.forEach((img, imgIndex) => {
                                allImages.push({
                                    url: img.url,
                                    projectTitle: project.title || `Project ${projectIndex + 1}`,
                                    description: project.description,
                                    category: project.category,
                                    uploadedAt: project.uploadedAt,
                                    projectIndex: projectIndex,
                                    imageIndex: imgIndex,
                                    totalInProject: project.images.length
                                });
                                totalImages++;
                            });
                        }
                    });
                    %>
                    
                    <% if (allImages.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No portfolio images yet</h5>
                        <p class="text-muted">This painter hasn't uploaded any project photos</p>
                    </div>
                    <% } else { %>
                    
                    <!-- Image Counter -->
                    <div class="image-counter">
                        <i class="fas fa-images me-2"></i>
                        <%= totalImages %> images in <%= portfolio.length %> projects
                    </div>

                    <!-- Main Slider - CORRECTION: TOUTES les images sont ajoutées -->
                    <div class="swiper portfolio-lightbox mb-3">
                        <div class="swiper-wrapper">
                            <% allImages.forEach((image, index) => { %>
                            <div class="swiper-slide" 
                                 data-image-index="<%= index %>"
                                 onclick="openLightbox(<%= index %>)">
                                 
                                <!-- Zoom Indicator -->
                                <div class="zoom-indicator">
                                    <i class="fas fa-search-plus me-1"></i>Click to view full size
                                </div>
                                
                                <img src="<%= image.url %>" 
                                     alt="<%= image.projectTitle %>"
                                     loading="lazy"
                                     onerror="this.src='https://via.placeholder.com/800x500/f8f9fa/6c757d?text=Project+Image'">
                                
                                <div class="project-info-overlay">
                                    <div class="project-title">
                                        <%= image.projectTitle %>
                                        <% if (image.totalInProject > 1) { %>
                                        <span class="badge bg-info ms-2">
                                            <%= image.imageIndex + 1 %>/<%= image.totalInProject %>
                                        </span>
                                        <% } %>
                                    </div>
                                    
                                    <% if (image.description) { %>
                                    <div class="project-description">
                                        <%= image.description %>
                                    </div>
                                    <% } %>
                                    
                                    <div class="project-meta">
                                        <% if (image.category) { %>
                                        <span class="badge bg-primary">
                                            <i class="fas fa-tag me-1"></i><%= image.category %>
                                        </span>
                                        <% } %>
                                        
                                        <% if (image.uploadedAt) { %>
                                        <span>
                                            <i class="fas fa-calendar me-1"></i>
                                            <%= new Date(image.uploadedAt).toLocaleDateString() %>
                                        </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                        
                        <!-- Navigation Buttons -->
                        <div class="swiper-button-next"></div>
                        <div class="swiper-button-prev"></div>
                        
                        <!-- Pagination -->
                        <div class="swiper-pagination"></div>
                    </div>

                    <!-- Thumbnail Slider - CORRECTION: TOUTES les miniatures -->
                    <div class="swiper thumbnail-swiper">
                        <div class="swiper-wrapper">
                            <% allImages.forEach((image, index) => { %>
                            <div class="swiper-slide" data-index="<%= index %>">
                                <img src="<%= image.url %>" 
                                     alt="Thumbnail <%= index + 1 %>"
                                     loading="lazy"
                                     onerror="this.src='https://via.placeholder.com/100x60/f8f9fa/6c757d?text=Thumb'">
                            </div>
                            <% }); %>
                        </div>
                    </div>
                    
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightboxModal" class="lightbox-modal">
        <span class="lightbox-close" onclick="closeLightbox()">&times;</span>
        
        <!-- Image Counter in Lightbox -->
        <div class="image-counter">
            <span id="lightboxCounter">1/<%= allImages.length %></span>
        </div>
        
        <div class="lightbox-nav">
            <button onclick="changeLightboxImage(-1)">❮</button>
            <button onclick="changeLightboxImage(1)">❯</button>
        </div>
        
        <div class="lightbox-content">
            <img id="lightboxImage" class="lightbox-image" src="" alt="">
            <div class="lightbox-info">
                <h3 id="lightboxTitle" class="mb-3"></h3>
                <p id="lightboxDescription" class="mb-3"></p>
                <div class="d-flex justify-content-center gap-3">
                    <span id="lightboxCategory" class="badge bg-primary"></span>
                    <span id="lightboxDate" class="text-muted"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
// DEBUG: Vérifier les données
console.log('=== SWIPER DEBUG ===');
console.log('Total images:', <%= allImages.length %>);
console.log('All images:', <%= JSON.stringify(allImages) %>);

// Global variables
let currentLightboxIndex = 0;
const allImages = <%= JSON.stringify(allImages) %>;

// CORRECTION: Initialisation correcte du Swiper
const swiper = new Swiper('.portfolio-lightbox', {
    // DÉSACTIVER le loop si peu d'images
    loop: <%= allImages.length > 2 %>, // Loop seulement si plus de 2 images
    lazy: true,
    spaceBetween: 0,
    navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
    },
    pagination: {
        el: '.swiper-pagination',
        clickable: true,
        dynamicBullets: true,
    },
    autoplay: {
        delay: 5000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
    },
    effect: 'slide',
    speed: 600,
    grabCursor: true,
    // CORRECTION: Important pour le chargement des slides
    preloadImages: false,
    lazy: {
        loadPrevNext: true,
        loadPrevNextAmount: 2,
    },
    // CORRECTION: S'assurer que toutes les slides sont visibles
    watchSlidesProgress: true,
    watchSlidesVisibility: true,
    // CORRECTION: Slides par vue
    slidesPerView: 1,
    slidesPerGroup: 1,
});

// CORRECTION: Initialisation du thumbnail Swiper
const thumbnailSwiper = new Swiper('.thumbnail-swiper', {
    loop: <%= allImages.length > 6 %>,
    spaceBetween: 10,
    slidesPerView: 'auto',
    freeMode: true,
    watchSlidesProgress: true,
    centerInsufficientSlides: true,
    breakpoints: {
        320: {
            slidesPerView: 3,
        },
        576: {
            slidesPerView: 4,
        },
        768: {
            slidesPerView: 5,
        },
        992: {
            slidesPerView: 6,
        },
        1200: {
            slidesPerView: 8,
        },
    },
});

// CORRECTION: Connexion entre les deux sliders
swiper.controller.control = thumbnailSwiper;
thumbnailSwiper.controller.control = swiper;

// CORRECTION: Mettre à jour les thumbnails actifs
swiper.on('slideChange', function () {
    const activeIndex = swiper.realIndex;
    thumbnailSwiper.slides.forEach((slide, index) => {
        if (index === activeIndex) {
            slide.classList.add('swiper-slide-thumb-active');
        } else {
            slide.classList.remove('swiper-slide-thumb-active');
        }
    });
});

// CORRECTION: Cliquer sur les thumbnails pour changer la slide principale
thumbnailSwiper.slides.forEach((slide, index) => {
    slide.addEventListener('click', function () {
        swiper.slideTo(index);
    });
});

// Lightbox Functions
function openLightbox(index) {
    console.log('Opening lightbox for image:', index, allImages[index]);
    currentLightboxIndex = index;
    updateLightboxContent();
    document.getElementById('lightboxModal').style.display = 'block';
    document.body.style.overflow = 'hidden';
}

function closeLightbox() {
    document.getElementById('lightboxModal').style.display = 'none';
    document.body.style.overflow = 'auto';
}

function changeLightboxImage(direction) {
    currentLightboxIndex += direction;
    
    if (currentLightboxIndex < 0) {
        currentLightboxIndex = allImages.length - 1;
    } else if (currentLightboxIndex >= allImages.length) {
        currentLightboxIndex = 0;
    }
    
    updateLightboxContent();
}

function updateLightboxContent() {
    const image = allImages[currentLightboxIndex];
    const lightboxImage = document.getElementById('lightboxImage');
    
    // Preload image for smooth transition
    lightboxImage.style.opacity = '0';
    
    const img = new Image();
    img.onload = function() {
        lightboxImage.src = image.url;
        lightboxImage.style.opacity = '1';
    };
    img.src = image.url;
    
    document.getElementById('lightboxTitle').textContent = image.projectTitle;
    document.getElementById('lightboxDescription').textContent = image.description || '';
    document.getElementById('lightboxCounter').textContent = `${currentLightboxIndex + 1}/${allImages.length}`;
    
    // Update category and date
    const categoryEl = document.getElementById('lightboxCategory');
    const dateEl = document.getElementById('lightboxDate');
    
    if (image.category) {
        categoryEl.textContent = image.category;
        categoryEl.style.display = 'inline-block';
    } else {
        categoryEl.style.display = 'none';
    }
    
    if (image.uploadedAt) {
        dateEl.textContent = new Date(image.uploadedAt).toLocaleDateString();
        dateEl.style.display = 'inline-block';
    } else {
        dateEl.style.display = 'none';
    }
}

// Keyboard navigation
document.addEventListener('keydown', function(e) {
    const lightbox = document.getElementById('lightboxModal');
    if (lightbox.style.display === 'block') {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') changeLightboxImage(-1);
        if (e.key === 'ArrowRight') changeLightboxImage(1);
    }
});

// Close lightbox when clicking outside image
document.getElementById('lightboxModal').addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
});

// Swipe gestures for mobile
let touchStartX = 0;
let touchEndX = 0;

document.getElementById('lightboxModal').addEventListener('touchstart', e => {
    touchStartX = e.changedTouches[0].screenX;
});

document.getElementById('lightboxModal').addEventListener('touchend', e => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
});

function handleSwipe() {
    const swipeThreshold = 50;
    const diff = touchStartX - touchEndX;
    
    if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
            changeLightboxImage(1);
        } else {
            changeLightboxImage(-1);
        }
    }
}

// CORRECTION: Initialiser les thumbnails actifs au chargement
document.addEventListener('DOMContentLoaded', function() {
    // Activer le premier thumbnail
    if (thumbnailSwiper.slides[0]) {
        thumbnailSwiper.slides[0].classList.add('swiper-slide-thumb-active');
    }
});
</script>

<%- include('../partials/footer') %>
