<%- include('../partials/header', { title: painter.name, painter: painter }) %>

<style>
/* Modern Instagram/Muula Style */
:root {
    --primary: #007bff;
    --primary-dark: #0056b3;
    --background: #fafafa;
    --card-bg: #ffffff;
    --text-dark: #262626;
    --text-gray: #8e8e8e;
    --border-color: #dbdbdb;
}

body {
    background: var(--background);
}

/* Modern Profile Header - Instagram Style */
.profile-header-modern {
    background: var(--card-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 30px 0;
    margin-bottom: 30px;
}

.profile-container {
    max-width: 935px;
    margin: 0 auto;
    padding: 0 20px;
}

.profile-grid {
    display: flex;
    gap: 60px;
    align-items: center;
    flex-wrap: wrap;
}

/* Avatar Section */
.avatar-modern {
    flex-shrink: 0;
}

.avatar-modern img {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--primary);
    padding: 3px;
    background: white;
    transition: transform 0.3s ease;
    cursor: pointer;
}

.avatar-modern img:hover {
    transform: scale(1.05);
}

/* Stats Section */
.stats-modern {
    flex: 1;
    display: flex;
    gap: 40px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.stat-item {
    text-align: center;
}

.stat-number {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--text-dark);
    display: block;
}

.stat-label {
    font-size: 1rem;
    color: var(--text-gray);
    font-weight: 400;
}

/* Bio Section */
.bio-modern {
    margin-top: 20px;
}

.name-modern {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.bio-text {
    color: var(--text-dark);
    margin-bottom: 10px;
    line-height: 1.5;
}

.location-modern {
    color: var(--text-gray);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 12px;
}

.price-tag {
    background: linear-gradient(135deg, #28a745, #20c997);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 8px;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    flex-wrap: wrap;
}

.btn-action {
    padding: 8px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-book {
    background: linear-gradient(135deg, #28a745, #20c997);
    color: white;
}

.btn-book:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(40,167,69,0.3);
    color: white;
}

.btn-message {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-dark);
}

.btn-message:hover {
    background: #f5f5f5;
    text-decoration: none;
    color: var(--text-dark);
}

.btn-follow {
    background: var(--primary);
    color: white;
}

.btn-follow:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    color: white;
}

/* Tabs Section */
.tabs-modern {
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 30px;
    background: var(--card-bg);
}

.tabs-container {
    max-width: 935px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 60px;
}

.tab {
    padding: 16px 0;
    cursor: pointer;
    position: relative;
    color: var(--text-gray);
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
}

.tab i {
    font-size: 1.1rem;
}

.tab.active {
    color: var(--text-dark);
}

.tab.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--text-dark);
}

.tab:hover:not(.active) {
    color: var(--text-dark);
}

/* Portfolio Grid - Instagram Style */
.portfolio-grid-modern {
    max-width: 935px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    padding: 0 20px;
}

.portfolio-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    background: #f0f0f0;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.portfolio-item:hover {
    transform: translateY(-5px);
}

.portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.portfolio-item:hover img {
    transform: scale(1.05);
}

/* Overlay on Hover */
.portfolio-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    opacity: 0;
    transition: opacity 0.3s ease;
    color: white;
}

.portfolio-item:hover .portfolio-overlay {
    opacity: 1;
}

.overlay-stats {
    display: flex;
    gap: 20px;
    font-size: 1.2rem;
    font-weight: 600;
}

.overlay-stats span {
    display: flex;
    align-items: center;
    gap: 5px;
}

/* Project Detail View (for when clicking on grid item) */
.project-detail {
    max-width: 935px;
    margin: 0 auto;
    padding: 0 20px;
    display: none;
}

.project-detail.active {
    display: block;
}

.project-detail-card {
    background: var(--card-bg);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 30px;
}

.project-detail-image {
    width: 100%;
    max-height: 600px;
    object-fit: contain;
    background: #000;
}

.project-detail-info {
    padding: 30px;
}

.project-title-modern {
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 15px;
    color: var(--text-dark);
}

.project-description-modern {
    color: var(--text-dark);
    line-height: 1.6;
    margin-bottom: 20px;
}

.project-meta-modern {
    display: flex;
    gap: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
    color: var(--text-gray);
}

.btn-back-to-grid {
    margin: 20px 20px;
    padding: 8px 20px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}

/* Reviews Section */
.reviews-section {
    max-width: 935px;
    margin: 0 auto;
    padding: 0 20px;
    display: none;
}

.reviews-section.active {
    display: block;
}

.review-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
    border: 1px solid var(--border-color);
}

.review-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
}

.review-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
}

.review-user {
    font-weight: 600;
    color: var(--text-dark);
}

.review-date {
    font-size: 0.8rem;
    color: var(--text-gray);
}

.review-stars {
    color: #ffc107;
    margin-bottom: 10px;
}

.review-text {
    color: var(--text-dark);
    line-height: 1.5;
}

/* About Section */
.about-section {
    max-width: 935px;
    margin: 0 auto;
    padding: 0 20px;
    display: none;
}

.about-section.active {
    display: block;
}

.about-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 30px;
    border: 1px solid var(--border-color);
}

.about-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--text-dark);
}

.skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 15px;
}

.skill-tag {
    background: #f0f0f0;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.9rem;
    color: var(--text-dark);
}

/* Responsive */
@media (max-width: 768px) {
    .profile-grid {
        flex-direction: column;
        text-align: center;
        gap: 20px;
    }
    
    .stats-modern {
        justify-content: center;
    }
    
    .action-buttons {
        justify-content: center;
    }
    
    .portfolio-grid-modern {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }
    
    .tabs-container {
        gap: 30px;
    }
    
    .tab span {
        display: none;
    }
    
    .tab i {
        font-size: 1.3rem;
    }
}

@media (max-width: 480px) {
    .portfolio-grid-modern {
        grid-template-columns: 1fr;
    }
    
    .stats-modern {
        gap: 20px;
    }
    
    .stat-number {
        font-size: 1.2rem;
    }
    
    .stat-label {
        font-size: 0.8rem;
    }
}

/* Carousel overrides for project detail */
.carousel-item img {
    width: 100%;
    height: auto;
    max-height: 600px;
    object-fit: contain;
    cursor: pointer;
}
</style>

<!-- Modern Profile Header -->
<div class="profile-header-modern">
    <div class="profile-container">
        <div class="profile-grid">
            <!-- Avatar -->
            <div class="avatar-modern">
                <% if (painter.profilePicture && painter.profilePicture.url) { %>
                    <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" 
                         onclick="openLightboxFromProject(0, 0, true)">
                <% } else { %>
                    <img src="https://via.placeholder.com/300x300?text=Painter" alt="No profile">
                <% } %>
            </div>
            
            <!-- Stats & Info -->
            <div>
                <div class="stats-modern">
                    <div class="stat-item">
                        <span class="stat-number"><%= (painter.portfolio || []).reduce((total, project) => total + (project.images?.filter(i => i && i.url).length || 0), 0) %></span>
                        <span class="stat-label">Posts</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number"><%= painter.followers || 0 %></span>
                        <span class="stat-label">Followers</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number"><%= painter.completedJobs || 0 %></span>
                        <span class="stat-label">Jobs Done</span>
                    </div>
                </div>
                
                <div class="bio-modern">
                    <div class="name-modern">
                        <%= painter.name %>
                        <% if (painter.verification && painter.verification.status === 'verified') { %>
                            <span class="verified-badge" style="background: #28a745; color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.7rem;">
                                <i class="fas fa-check-circle"></i> Verified
                            </span>
                        <% } %>
                    </div>
                    
                    <div class="location-modern">
                        <i class="fas fa-map-marker-alt"></i>
                        <%= painter.location?.wilaya || 'Algeria' %>
                    </div>
                    
                    <div class="bio-text">
                        <%= painter.bio || 'Professional painter with years of experience. Quality work guaranteed!' %>
                    </div>
                    
                    <div class="price-tag">
                        <i class="fas fa-paint-roller"></i> <%= painter.pricePerSqm || 0 %> DA/m²
                    </div>
                    
                    <div class="availability-badge mt-2">
                        <span class="badge <%= painter.availability === 'available' ? 'bg-success' : (painter.availability === 'busy' ? 'bg-warning' : 'bg-secondary') %>">
                            <i class="fas <%= painter.availability === 'available' ? 'fa-check-circle' : (painter.availability === 'busy' ? 'fa-clock' : 'fa-times-circle') %> me-1"></i>
                            <%= (painter.availability || 'unavailable').charAt(0).toUpperCase() + (painter.availability || 'unavailable').slice(1) %>
                        </span>
                    </div>
                </div>
                
                <div class="action-buttons">
                    <a href="/painters/<%= painter._id %>/order" class="btn-action btn-book">
                        <i class="fas fa-calendar-check"></i> Book Now
                    </a>
                    <button class="btn-action btn-message" onclick="contactWhatsApp()">
                        <i class="fab fa-whatsapp"></i> Message
                    </button>
                    <button class="btn-action btn-follow" onclick="followPainter()">
                        <i class="fas fa-user-plus"></i> Follow
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="tabs-modern">
    <div class="tabs-container">
        <button class="tab active" data-tab="posts">
            <i class="fas fa-th"></i>
            <span>POSTS</span>
        </button>
        <button class="tab" data-tab="reviews">
            <i class="fas fa-star"></i>
            <span>REVIEWS</span>
        </button>
        <button class="tab" data-tab="about">
            <i class="fas fa-info-circle"></i>
            <span>ABOUT</span>
        </button>
    </div>
</div>

<!-- Posts Grid View -->
<div id="posts-view">
    <% 
    const allImages = [];
    const projectImageMap = [];
    (painter.portfolio || []).forEach((project, pIndex) => {
        const imgs = Array.isArray(project.images) ? project.images.filter(i => i && i.url) : [];
        imgs.forEach((img, localIdx) => {
            allImages.push({
                url: img.url,
                projectIndex: pIndex,
                localIndex: localIdx,
                project: project
            });
            projectImageMap.push({ project: pIndex, local: localIdx });
        });
    });
    %>
    
    <div class="portfolio-grid-modern" id="posts-grid">
        <% if (allImages.length === 0) { %>
            <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px;">
                <i class="fas fa-camera" style="font-size: 3rem; color: var(--text-gray); margin-bottom: 20px;"></i>
                <h3 style="color: var(--text-dark);">No Posts Yet</h3>
                <p style="color: var(--text-gray);">This painter hasn't shared any projects.</p>
            </div>
        <% } else { %>
            <% allImages.forEach((image, idx) => { %>
                <div class="portfolio-item" onclick="showProjectDetail(<%= image.projectIndex %>, <%= image.localIndex %>)">
                    <img src="<%= image.url %>" alt="<%= image.project.title %>" loading="lazy">
                    <div class="portfolio-overlay">
                        <div class="overlay-stats">
                            <span><i class="fas fa-heart"></i> 0</span>
                            <span><i class="fas fa-comment"></i> 0</span>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<!-- Project Detail View -->
<div id="project-detail-view" style="display: none;">
    <div class="project-detail">
        <button class="btn-back-to-grid" onclick="showPostsGrid()">
            <i class="fas fa-arrow-left"></i> Back to all posts
        </button>
        
        <div class="project-detail-card">
            <div id="project-carousel" class="carousel slide" data-bs-ride="false">
                <div class="carousel-inner" id="project-carousel-inner">
                    <!-- Carousel items will be injected here -->
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#project-carousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#project-carousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
            
            <div class="project-detail-info">
                <h3 class="project-title-modern" id="project-title"></h3>
                <div class="project-description-modern" id="project-description"></div>
                <div class="project-meta-modern">
                    <span><i class="fas fa-tag"></i> <span id="project-category"></span></span>
                    <span><i class="fas fa-ruler"></i> <span id="project-size"></span></span>
                    <span><i class="fas fa-calendar"></i> <span id="project-date"></span></span>
                </div>
                
                <div class="text-center mt-4">
                    <a href="/painters/<%= painter._id %>/order" class="btn-action btn-book" style="padding: 12px 40px;">
                        <i class="fas fa-handshake"></i> Hire This Painter
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reviews Section -->
<div class="reviews-section" id="reviews-tab">
    <% const reviews = painter.reviews || []; %>
    <% if (reviews.length === 0) { %>
        <div style="text-align: center; padding: 60px 20px;">
            <i class="fas fa-star" style="font-size: 3rem; color: var(--text-gray); margin-bottom: 20px;"></i>
            <h3 style="color: var(--text-dark);">No Reviews Yet</h3>
            <p style="color: var(--text-gray);">Be the first to review this painter!</p>
        </div>
    <% } else { %>
        <% reviews.forEach(review => { %>
            <div class="review-card">
                <div class="review-header">
                    <img src="<%= review.userAvatar || '/img/default-avatar.jpg' %>" class="review-avatar">
                    <div>
                        <div class="review-user"><%= review.userName || 'Anonymous' %></div>
                        <div class="review-date"><%= new Date(review.createdAt).toLocaleDateString() %></div>
                    </div>
                </div>
                <div class="review-stars">
                    <% for(let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= review.rating ? 'text-warning' : 'text-muted' %>"></i>
                    <% } %>
                </div>
                <div class="review-text"><%= review.comment || review.text || '' %></div>
            </div>
        <% }) %>
    <% } %>
</div>

<!-- About Section -->
<div class="about-section" id="about-tab">
    <div class="about-card">
        <div class="about-title">
            <i class="fas fa-brush"></i> About <%= painter.name %>
        </div>
        
        <p style="margin-bottom: 20px; line-height: 1.6;">
            <%= painter.about || `${painter.name} is a professional painter with ${painter.experience || 'extensive'} experience in the field. Specializing in residential and commercial painting projects.` %>
        </p>
        
        <div class="about-title" style="margin-top: 30px;">
            <i class="fas fa-tools"></i> Skills & Specialties
        </div>
        <div class="skills-list">
            <% 
            const skills = painter.specialization || painter.painterProfile?.skills || ['Interior Painting', 'Exterior Painting', 'Wall Finishing'];
            skills.forEach(skill => { 
            %>
                <span class="skill-tag"><%= skill %></span>
            <% }) %>
        </div>
        
        <div class="about-title" style="margin-top: 30px;">
            <i class="fas fa-clock"></i> Availability
        </div>
        <p><%= painter.availability === 'available' ? '✅ Available for new projects' : '⏰ Currently booked, but accepting future projects' %></p>
        
        <div class="about-title" style="margin-top: 30px;">
            <i class="fas fa-phone"></i> Contact Info
        </div>
        <p>
            <i class="fab fa-whatsapp"></i> WhatsApp: 
            <a href="https://wa.me/<%= painter.phone || '213XXXXXXXX' %>" target="_blank">
                <%= painter.phone || 'Click to reveal number' %>
            </a>
        </p>
    </div>
</div>

<!-- Keep existing lightbox overlay from original -->
<div id="lightboxOverlay" role="dialog" aria-hidden="true">
    <div id="lightboxBox">
        <img id="lightboxImg" src="" alt="Zoomed">
        <div class="lightbox-close" onclick="closeLightbox()" title="Close">&times;</div>
        <div class="lightbox-nav">
            <button onclick="prevLightbox()" title="Previous">❮</button>
            <button onclick="nextLightbox()" title="Next">❯</button>
        </div>
    </div>
</div>

<script>
// Store all images data
const allImagesData = <%= JSON.stringify(allImages) %>;
let currentAbsIndex = 0;

// Tab switching
document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', function() {
        const tabId = this.dataset.tab;
        
        // Update active tab
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        
        // Show/hide sections
        document.getElementById('posts-view').style.display = tabId === 'posts' ? 'block' : 'none';
        document.getElementById('project-detail-view').style.display = 'none';
        document.getElementById('reviews-tab').style.display = tabId === 'reviews' ? 'block' : 'none';
        document.getElementById('about-tab').style.display = tabId === 'about' ? 'block' : 'none';
        
        // Reset posts grid visibility
        if (tabId === 'posts') {
            showPostsGrid();
        }
    });
});

function showPostsGrid() {
    document.getElementById('posts-view').style.display = 'block';
    document.getElementById('project-detail-view').style.display = 'none';
}

function showProjectDetail(projectIndex, imageIndex) {
    const project = <%= JSON.stringify(painter.portfolio || []) %>[projectIndex];
    if (!project) return;
    
    const images = (project.images || []).filter(i => i && i.url);
    
    // Build carousel
    const carouselInner = document.getElementById('project-carousel-inner');
    carouselInner.innerHTML = '';
    
    images.forEach((img, idx) => {
        const isActive = idx === imageIndex;
        const div = document.createElement('div');
        div.className = `carousel-item ${isActive ? 'active' : ''}`;
        div.innerHTML = `<img src="${img.url}" class="d-block w-100" alt="${project.title}" onclick="openLightboxFromProjectDetail(${projectIndex}, ${idx})">`;
        carouselInner.appendChild(div);
    });
    
    // Update project info
    document.getElementById('project-title').textContent = project.title || 'Untitled Project';
    document.getElementById('project-description').textContent = project.description || 'No description available.';
    document.getElementById('project-category').textContent = project.category || 'General';
    document.getElementById('project-size').textContent = project.projectSize || 'Not specified';
    document.getElementById('project-date').textContent = project.uploadedAt ? new Date(project.uploadedAt).toLocaleDateString() : 'Unknown';
    
    // Show detail view
    document.getElementById('posts-view').style.display = 'none';
    document.getElementById('project-detail-view').style.display = 'block';
}

function openLightboxFromProjectDetail(projectIndex, imageIndex) {
    // Calculate absolute index
    let absIdx = 0;
    for (let i = 0; i < projectIndex; i++) {
        const proj = <%= JSON.stringify(painter.portfolio || []) %>[i];
        absIdx += (proj.images || []).filter(img => img && img.url).length;
    }
    absIdx += imageIndex;
    openLightboxAt(absIdx);
}

// Lightbox functions (keeping original implementation)
function openLightboxAt(index) {
    if (window.openLightbox) {
        window.openLightbox(index);
    }
}

// Contact WhatsApp
function contactWhatsApp() {
    const phone = '<%= painter.phone || "213555000000" %>';
    const text = encodeURIComponent('Hello <%= painter.name %>! I found you on Paintello and I\'m interested in your painting services.');
    window.open(`https://wa.me/${phone}?text=${text}`, '_blank');
}

// Follow painter
function followPainter() {
    fetch('/painters/<%= painter._id %>/follow', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('You are now following this painter!');
            location.reload();
        } else {
            alert('Please login to follow painters');
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

// Keep original lightbox implementation
(function(){
    const allImages = <%= JSON.stringify(allImages.map(img => img.url)) %>;
    const overlay = document.getElementById('lightboxOverlay');
    const imgEl = document.getElementById('lightboxImg');
    let absIndex = 0;
    let scale = 1;
    let translate = { x: 0, y: 0 };
    let dragging = false;
    let lastPointer = { x: 0, y: 0 };
    
    window.openLightbox = function(index) {
        if (!allImages.length) return;
        absIndex = (index + allImages.length) % allImages.length;
        imgEl.src = allImages[absIndex];
        resetTransform();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    };
    
    window.closeLightbox = function() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
        resetTransform();
    };
    
    window.nextLightbox = function() { 
        if (window.openLightbox) window.openLightbox(absIndex + 1);
    };
    
    window.prevLightbox = function() { 
        if (window.openLightbox) window.openLightbox(absIndex - 1);
    };
    
    function resetTransform() {
        scale = 1;
        translate = { x: 0, y: 0 };
        applyTransform();
    }
    
    function applyTransform() {
        imgEl.style.transform = `translate(${translate.x}px, ${translate.y}px) scale(${scale})`;
        imgEl.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
    }
    
    // Keep other lightbox event handlers...
    imgEl.addEventListener('dblclick', function(e) {
        e.preventDefault();
        if (scale <= 1) {
            zoomAt(e.clientX, e.clientY, 2.2);
        } else {
            resetTransform();
        }
    });
    
    imgEl.addEventListener('wheel', function(e) {
        if (!e.ctrlKey && !e.metaKey) return;
        e.preventDefault();
        const delta = -e.deltaY;
        const zoomFactor = delta > 0 ? 1.12 : 0.9;
        zoomAt(e.clientX, e.clientY, zoomFactor);
    }, { passive: false });
    
    function zoomAt(cx, cy, factor) {
        const rect = imgEl.getBoundingClientRect();
        const ix = (cx - rect.left - rect.width/2 - translate.x) / scale;
        const iy = (cy - rect.top - rect.height/2 - translate.y) / scale;
        scale = Math.max(1, Math.min(4, scale * factor));
        translate.x = (cx - rect.left - rect.width/2) - ix * scale;
        translate.y = (cy - rect.top - rect.height/2) - iy * scale;
        applyTransform();
    }
    
    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) window.closeLightbox();
    });
    
    document.addEventListener('keydown', function(e) {
        if (!overlay.classList.contains('active')) return;
        if (e.key === 'Escape') window.closeLightbox();
        if (e.key === 'ArrowRight') window.nextLightbox();
        if (e.key === 'ArrowLeft') window.prevLightbox();
    });
})();
</script>

