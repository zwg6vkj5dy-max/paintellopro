<%- include('../partials/header', { title: painter.name, painter: painter }) %>

<style>
/* Layout */
.container { max-width: 1100px; }

/* Profile */
.profile-card { display:flex; gap:20px; align-items:center; margin-bottom:24px; }
.avatar { width:120px; height:120px; border-radius:50%; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.08); }
.avatar img { width:100%; height:100%; object-fit:cover; }

/* Badges */
.badge-availability { padding:6px 10px; border-radius:12px; font-weight:600; }

/* Cards */
.card-hover { transition: transform .18s ease, box-shadow .18s ease; }
.card-hover:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,0,0,0.08); }

/* Carousel images */
.carousel-item img { width:100%; height:420px; object-fit:cover; border-radius:8px; cursor:zoom-in; }

/* Lightbox overlay */
#lightboxOverlay { position:fixed; inset:0; background:rgba(0,0,0,0.95); z-index:10500; display:none; justify-content:center; align-items:center; overflow:hidden; }
#lightboxOverlay.active { display:flex; }
#lightboxBox { position:relative; max-width:95%; max-height:95%; display:flex; align-items:center; justify-content:center; }
#lightboxImg { transform-origin:center center; transition: transform .18s ease; max-width:100%; max-height:100%; touch-action: none; cursor: zoom-in; border-radius:8px; box-shadow:0 18px 60px rgba(0,0,0,0.6); }

/* Controls */
.lightbox-close { position:absolute; top:18px; right:22px; font-size:28px; color:#fff; cursor:pointer; background:rgba(0,0,0,0.4); border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center; }
.lightbox-nav { position:absolute; top:50%; left:0; right:0; display:flex; justify-content:space-between; transform:translateY(-50%); pointer-events:none; }
.lightbox-nav button { pointer-events:auto; background:rgba(0,0,0,0.45); border:none; color:#fff; font-size:24px; width:52px; height:52px; border-radius:999px; }

/* Responsive */
@media (max-width:768px) {
  .carousel-item img { height:280px; }
  .avatar { width:96px; height:96px; }
}
</style>

<div class="container py-4">
  <!-- Profile header -->
  <div class="profile-card">
    <div class="avatar">
      <% if (painter.profilePicture && painter.profilePicture.url) { %>
        <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
      <% } else { %>
        <img src="https://via.placeholder.com/300x300?text=Painter" alt="No profile">
      <% } %>
    </div>

    <div class="flex-grow-1">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="mb-1"><%= painter.name %></h2>
          <div class="text-muted mb-2">
            <i class="fas fa-map-marker-alt me-1"></i> <%= painter.location?.wilaya || 'Unknown Wilaya' %>
          </div>

          <div class="d-flex align-items-center gap-3">
            <div>
              <% for (let i=1;i<=5;i++) { %>
                <i class="fas fa-star <%= i <= (painter.rating||0) ? 'text-warning' : 'text-muted' %>"></i>
              <% } %>
              <span class="fw-bold ms-2"><%= (painter.rating||0).toFixed(1) %></span>
              <small class="text-muted ms-2">(<%= painter.completedJobs||0 %> jobs)</small>
            </div>

            <div>
              <span class="badge badge-availability
                <% if (painter.availability === 'available') { %> bg-success text-white <% }
                   else if (painter.availability === 'busy') { %> bg-warning text-dark <% }
                   else { %> bg-secondary text-white <% } %>">
                <i class="fas <%= painter.availability === 'available' ? 'fa-check-circle' : (painter.availability === 'busy' ? 'fa-clock' : 'fa-times-circle') %> me-1"></i>
                <%= (painter.availability || 'unavailable').charAt(0).toUpperCase() + (painter.availability || 'unavailable').slice(1) %>
              </span>
            </div>

            <div>
              <span class="badge bg-primary"><%= painter.pricePerSqm %> DZD / m²</span>
            </div>
          </div>

          <% if (painter.verification && painter.verification.status === 'verified') { %>
            <div class="mt-2"><span class="badge bg-success"><i class="fas fa-check me-1"></i>Verified</span></div>
          <% } %>
        </div>

        <div class="text-end">
          <!-- HIRE BUTTON -->
          <a href="/painters/<%= painter._id %>/order" class="btn btn-lg btn-primary">
            <i class="fas fa-paint-roller me-1"></i>Hire This Painter
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Projects list -->
  <% if (!painter.portfolio || painter.portfolio.length === 0) { %>
    <div class="card p-4 text-center text-muted">No portfolio projects yet.</div>
  <% } else { %>
    <% painter.portfolio.forEach((project, pIndex) => { %>
      <div class="card mb-5 card-hover">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h5 class="mb-1 text-primary"><%= project.title || 'Project' %></h5>
              <p class="text-muted small mb-0"><%= project.description || '' %></p>
            </div>
            <div class="text-end">
              <% if (project.category) { %><span class="badge bg-info text-dark"><%= project.category %></span><% } %>
              <% if (project.projectSize) { %><span class="badge bg-warning text-dark ms-1"><%= project.projectSize %></span><% } %>
            </div>
          </div>

          <% const imgs = Array.isArray(project.images) ? project.images.filter(i=>i && i.url) : []; %>

          <% if (imgs.length === 0) { %>
            <div class="text-center py-4 text-muted">
              <img src="https://via.placeholder.com/800x420?text=No+images" class="img-fluid rounded" alt="no images">
            </div>
          <% } else { %>
            <div id="projectCarousel<%= pIndex %>" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
              <div class="carousel-inner">
                <% imgs.forEach((img, i) => { %>
                  <div class="carousel-item <%= i===0 ? 'active' : '' %>">
                    <img src="<%= img.url %>" class="d-block w-100" alt="proj <%= pIndex %> img <%= i %>"
                         onclick="openLightboxFromProject(<%= pIndex %>, <%= i %>)">
                  </div>
                <% }) %>
              </div>

              <% if (imgs.length > 1) { %>
                <button class="carousel-control-prev" type="button" data-bs-target="#projectCarousel<%= pIndex %>" data-bs-slide="prev">
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#projectCarousel<%= pIndex %>" data-bs-slide="next">
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<!-- Lightbox overlay -->
<div id="lightboxOverlay" role="dialog" aria-hidden="true">
  <div id="lightboxBox">
    <img id="lightboxImg" src="" alt="Zoomed image">
    <div class="lightbox-close" onclick="closeLightbox()" title="Close">&times;</div>
    <div class="lightbox-nav">
      <button onclick="prevLightbox()" title="Previous">❮</button>
      <button onclick="nextLightbox()" title="Next">❯</button>
    </div>
  </div>
</div>

<script>
/* Build flat array of all image URLs and a map from (project,local) to absolute index */
const _projectsImageCounts = <%= JSON.stringify((painter.portfolio||[]).map(pr => Array.isArray(pr.images) ? pr.images.filter(i=>i&&i.url).length : 0)) %>;
const allImages = [];
(() => {
  const pf = <%= JSON.stringify(painter.portfolio || []) %>;
  for (let p = 0; p < pf.length; ++p) {
    const project = pf[p];
    const imgs = Array.isArray(project.images) ? project.images.filter(i=>i&&i.url) : [];
    for (let j = 0; j < imgs.length; ++j) allImages.push(imgs[j].url);
  }
})();

// Lightbox state and elements
const overlay = document.getElementById('lightboxOverlay');
const imgEl = document.getElementById('lightboxImg');
let absIndex = 0;
let scale = 1;
let translate = { x: 0, y: 0 };
let dragging = false;
let lastPointer = { x: 0, y: 0 };

// Pinch state
let pinchStartDist = 0;
let pinchStartScale = 1;
let lastTap = 0;
let doubleTapTimeout = null;

function openAt(index) {
  if (!allImages.length) return;
  absIndex = ((index % allImages.length) + allImages.length) % allImages.length;
  imgEl.src = allImages[absIndex];
  resetTransform();
  overlay.classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeLightbox() {
  overlay.classList.remove('active');
  document.body.style.overflow = '';
  resetTransform();
}

function nextLightbox() { openAt(absIndex + 1); }
function prevLightbox() { openAt(absIndex - 1); }

function resetTransform() {
  scale = 1;
  translate = { x: 0, y: 0 };
  applyTransform();
  imgEl.style.cursor = 'zoom-in';
}

function applyTransform() {
  imgEl.style.transform = `translate(${translate.x}px, ${translate.y}px) scale(${scale})`;
  imgEl.style.willChange = 'transform';
}

// compute distance between two touches
function dist(t1, t2) {
  const dx = t2.clientX - t1.clientX;
  const dy = t2.clientY - t1.clientY;
  return Math.sqrt(dx*dx + dy*dy);
}

// compute midpoint
function midpoint(t1, t2) {
  return { x: (t1.clientX + t2.clientX)/2, y: (t1.clientY + t2.clientY)/2 };
}

// Toggle zoom on double-tap/click
imgEl.addEventListener('click', function(e) {
  const now = Date.now();
  if (now - lastTap < 300) {
    // double tap detected
    toggleZoomAt(e.clientX, e.clientY);
    lastTap = 0;
    return;
  }
  lastTap = now;
});

// Pointer events for desktop (dragging)
imgEl.addEventListener('pointerdown', function(e) {
  if (scale <= 1) return;
  dragging = true;
  lastPointer.x = e.clientX;
  lastPointer.y = e.clientY;
  imgEl.setPointerCapture(e.pointerId);
  imgEl.style.cursor = 'grabbing';
});
imgEl.addEventListener('pointermove', function(e) {
  if (!dragging) return;
  const dx = e.clientX - lastPointer.x;
  const dy = e.clientY - lastPointer.y;
  lastPointer.x = e.clientX; lastPointer.y = e.clientY;
  translate.x += dx; translate.y += dy;
  limitTranslate();
  applyTransform();
});
imgEl.addEventListener('pointerup', function(e) {
  if (!dragging) return;
  dragging = false;
  imgEl.style.cursor = 'grab';
  try { imgEl.releasePointerCapture(e.pointerId); } catch(_) {}
});

// Wheel zoom on desktop (optional: ctrl to zoom)
imgEl.addEventListener('wheel', function(e) {
  // require ctrl or meta to avoid page zoom — but allow pinch-to-zoom on touch
  if (!e.ctrlKey && !e.metaKey) return;
  e.preventDefault();
  const factor = e.deltaY < 0 ? 1.12 : 0.9;
  zoomAt(e.clientX, e.clientY, factor);
}, { passive: false });

// Touch handlers for pinch-to-zoom
let ongoingTouchIds = [];
imgEl.addEventListener('touchstart', function(e) {
  if (e.touches.length === 2) {
    pinchStartDist = dist(e.touches[0], e.touches[1]);
    pinchStartScale = scale;
  }
  // detect double-tap for mobile: handled via click timing above
}, { passive: true });

imgEl.addEventListener('touchmove', function(e) {
  if (e.touches.length === 2) {
    e.preventDefault(); // prevent scrolling while pinching
    const d = dist(e.touches[0], e.touches[1]);
    const factor = d / pinchStartDist;
    scale = Math.max(1, Math.min(4, pinchStartScale * factor));

    // adjust translate to keep midpoint under fingers stable
    const mid = midpoint(e.touches[0], e.touches[1]);
    // compute bounding rect
    const rect = imgEl.getBoundingClientRect();
    // convert to image-local coords (center based)
    const ix = (mid.x - rect.left - rect.width/2 - translate.x) / pinchStartScale;
    const iy = (mid.y - rect.top - rect.height/2 - translate.y) / pinchStartScale;
    // recompute translate after new scale to keep ix,iy stable
    translate.x = (mid.x - rect.left - rect.width/2) - ix * scale;
    translate.y = (mid.y - rect.top - rect.height/2) - iy * scale;

    limitTranslate();
    applyTransform();
  } else if (e.touches.length === 1 && scale > 1) {
    // single-finger drag while zoomed
    e.preventDefault();
    const t = e.touches[0];
    if (!ongoingTouchIds.length || ongoingTouchIds[0] !== t.identifier) {
      ongoingTouchIds[0] = t.identifier;
      lastPointer.x = t.clientX; lastPointer.y = t.clientY;
      return;
    }
    const dx = t.clientX - lastPointer.x;
    const dy = t.clientY - lastPointer.y;
    lastPointer.x = t.clientX; lastPointer.y = t.clientY;
    translate.x += dx; translate.y += dy;
    limitTranslate();
    applyTransform();
  }
}, { passive: false });

imgEl.addEventListener('touchend', function(e) {
  // reset pinch start if fingers lifted
  if (e.touches.length < 2) pinchStartDist = 0;
  ongoingTouchIds = [];
}, { passive: true });

// helpers: zoom at point
function zoomAt(cx, cy, factor) {
  const rect = imgEl.getBoundingClientRect();
  const ix = (cx - rect.left - rect.width/2 - translate.x) / scale;
  const iy = (cy - rect.top - rect.height/2 - translate.y) / scale;
  scale = Math.max(1, Math.min(4, scale * factor));
  translate.x = (cx - rect.left - rect.width/2) - ix * scale;
  translate.y = (cy - rect.top - rect.height/2) - iy * scale;
  limitTranslate();
  applyTransform();
}

// toggle zoom (double-tap)
function toggleZoomAt(cx, cy) {
  if (scale <= 1) {
    // zoom in around the point
    zoomAt(cx || window.innerWidth/2, cy || window.innerHeight/2, 2.2);
    imgEl.style.cursor = 'grab';
  } else {
    resetTransform();
  }
}

// limit translate so image does not travel too far
function limitTranslate() {
  const rect = imgEl.getBoundingClientRect();
  const parentW = window.innerWidth;
  const parentH = window.innerHeight;
  // calculate visible size of the image after scale
  const imgW = rect.width;
  const imgH = rect.height;
  // allowed overflow (some padding)
  const limitX = Math.max(0, (imgW - parentW) / 2 + 20);
  const limitY = Math.max(0, (imgH - parentH) / 2 + 20);
  translate.x = Math.max(-limitX, Math.min(limitX, translate.x));
  translate.y = Math.max(-limitY, Math.min(limitY, translate.y));
}

// expose functions for carousel images to call
window.openLightboxFromProject = function(pIndex, localIdx) {
  // compute absolute index from project counts
  const counts = _projectsImageCounts || [];
  let acc = 0;
  for (let i = 0; i < pIndex; ++i) acc += counts[i] || 0;
  const abs = acc + localIdx;
  openAt(abs);
};
window.nextLightbox = nextLightbox;
window.prevLightbox = prevLightbox;
window.closeLightbox = closeLightbox;

// click outside image closes lightbox
overlay.addEventListener('click', function(e) { if (e.target === overlay) closeLightbox(); });
// keyboard nav
document.addEventListener('keydown', function(e) {
  if (!overlay.classList.contains('active')) return;
  if (e.key === 'Escape') closeLightbox();
  if (e.key === 'ArrowRight') nextLightbox();
  if (e.key === 'ArrowLeft') prevLightbox();
});

</script>

<%- include('../partials/footer') %>



