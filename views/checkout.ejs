    "Si Mahdjoub", "Sidi Demed", "Sidi Naamane", "Souagui", "Tablat", "Tafraout", 
    "Tamesguida", "Tizi Mahdi", "Tlatet Eddouair", "Zoubiria"
  ]
},
"bordj badji mokhtar": { fee: 900, delay: "5–8 jours", communes: ["Bordj Badji Mokhtar", "Timiaouine", "Zaouiet Kounta"]}
};

  const FREE_SHIPPING_THRESHOLD = 5000;
  let basePrice = <%= cart.totalPrice %>;

  const citySelect = document.getElementById('city');
  const communeSelect = document.getElementById('commune');
  const shippingDisplay = document.getElementById('shippingDisplay');
  const delayDisplay = document.getElementById('delayDisplay');
  const totalDisplay = document.getElementById('totalDisplay');
  const btnTotalSpan = document.getElementById('btn-total');
  const shippingFeeInput = document.getElementById('shippingFee');
  const deliveryDelayInput = document.getElementById('deliveryDelay');
  const totalPriceFinalInput = document.getElementById('totalPriceFinal');

  function formatPrice(n) {
    return n.toLocaleString('ar-DZ') + ' دج';
  }

  function populateCommunes(wilayaKey) {
    communeSelect.innerHTML = '<option value="">اختر البلدية</option>';
    const entry = shippingData[wilayaKey];
    if (entry && entry.communes) {
      entry.communes.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c; opt.textContent = c;
        communeSelect.appendChild(opt);
      });
    }
  }

  function updateShipping(wilayaKey) {
    if (!wilayaKey) {
      shippingDisplay.textContent = '—';
      delayDisplay.textContent = '—';
      shippingFeeInput.value = 0;
      deliveryDelayInput.value = '';
      updateTotalDisplay(basePrice);
      return;
    }
    const data = shippingData[wilayaKey] || { fee: 700, delay: "3–5 أيام" };
    let fee = data.fee;
    if (basePrice >= FREE_SHIPPING_THRESHOLD) fee = 0;
    const total = basePrice + fee;
    shippingDisplay.textContent = fee === 0 ? 'مجاني' : formatPrice(fee);
    delayDisplay.textContent = data.delay;
    shippingFeeInput.value = fee;
    deliveryDelayInput.value = data.delay;
    totalPriceFinalInput.value = total;
    updateTotalDisplay(total);
  }

  function updateTotalDisplay(total) {
    totalDisplay.textContent = formatPrice(total);
    btnTotalSpan.textContent = formatPrice(total);
  }

  citySelect.addEventListener('change', function() {
    populateCommunes(this.value);
    updateShipping(this.value);
  });

  // Init
  document.addEventListener('DOMContentLoaded', () => {
    updateShipping(citySelect.value);
    // Payment method visual update
    const radios = document.querySelectorAll('input[name="paymentMethod"]');
    radios.forEach(r => r.addEventListener('change', function() {
      document.querySelectorAll('.payment-option').forEach(l => l.classList.remove('active'));
      this.closest('.payment-option').classList.add('active');
      const btn = document.getElementById('placeOrderBtn');
      if (this.value === 'chargily') {
        const card = this.dataset.card === 'cib' ? 'CIB' : 'الذهبية';
        btn.innerHTML = `<i class="fas fa-lock"></i> ادفع بـ ${card} — ${btnTotalSpan.textContent}`;
      } else {
        btn.innerHTML = `<i class="fas fa-box"></i> تأكيد الطلب (الدفع عند الاستلام) — ${btnTotalSpan.textContent}`;
      }
    }));
  });
// ---------- Quantity Controls ----------
// Make sure basePrice is declared with let at the top of the script
let basePrice = <%= cart.totalPrice %>;

// Pre-defined prices per product (from EJS)
const pricesPerUnit = {
  <% Object.keys(cart.items).forEach(id => { %>
    "<%= id %>": <%= cart.items[id].item.price %>,
  <% }); %>
};

function updateAllTotals() {
  let newTotalQty = 0;
  let newCartTotal = 0;

  document.querySelectorAll('.cart-item').forEach(item => {
    const productId = item.dataset.productId;
    const qtyInput = item.querySelector('.qty-input');
    const qty = parseInt(qtyInput.value) || 1;
    const pricePerUnit = pricesPerUnit[productId] || 0;

    const lineTotal = pricePerUnit * qty;
    newTotalQty += qty;
    newCartTotal += lineTotal;

    // Update line total display
    item.querySelector('.item-total').textContent = lineTotal.toLocaleString('ar-DZ') + ' دج';

    // Update hidden quantity field
    const hiddenQty = item.querySelector('input[name="qtys[' + productId + ']"]');
    if (hiddenQty) hiddenQty.value = qty;
  });

  // Update base price (this will be used by updateShipping)
  basePrice = newCartTotal;
  document.getElementById('baseTotal').textContent = formatPrice(basePrice);
  updateShipping(citySelect.value);
}

// Attach events to quantity buttons
document.querySelectorAll('.qty-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const item = this.closest('.cart-item');
    const input = item.querySelector('.qty-input');
    let qty = parseInt(input.value) || 1;

    if (this.dataset.action === 'minus') {
      qty = Math.max(1, qty - 1);
    } else {
      qty = qty + 1;
    }
    input.value = qty;
    updateAllTotals();
  });
});
</script>
