<%- include('partials/header', {
  title: 'إتمام الطلب - Paintello Pro',
  metaEventIdPageView: typeof metaEventIdPageView !== 'undefined' ? metaEventIdPageView : '',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null
}) %>

<!-- Checkout Content -->
<div dir="rtl" class="checkout-container">
  <div class="container" style="max-width:1200px; margin:0 auto; padding:0 24px;">
    
    <div class="checkout-header">
      <h1>إتمام الطلب</h1>
      <p>أكمل معلوماتك وسيتم احتساب رسوم التوصيل تلقائياً</p>
    </div>

    <div class="row g-5">
      <!-- Left: Form -->
      <div class="col-lg-8">
        <div class="checkout-card">
          <form id="checkoutForm" action="/checkout" method="POST">
            
            <!-- Personal Info -->
            <div class="form-section">
              <h3>المعلومات الشخصية</h3>
              <input type="hidden" name="country" value="Algeria">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="firstName">الاسم</label>
                  <input type="text" id="firstName" name="firstName" value="<%= user && user.firstName ? user.firstName : '' %>" required>
                </div>
                <div class="col-md-6">
                  <label for="lastName">اللقب</label>
                  <input type="text" id="lastName" name="lastName" value="<%= user && user.lastName ? user.lastName : '' %>" required>
                </div>
                <div class="col-md-6">
                  <label for="numero">الهاتف</label>
                  <input type="tel" id="numero" name="numero" pattern="0[5-7][0-9]{8}" placeholder="مثال: 0551234567" value="<%= user && user.numero ? user.numero : '' %>" required>
                </div>
              </div>
            </div>

            <!-- Address -->
            <div class="form-section">
              <h3>عنوان التوصيل</h3>
              <div class="mb-3">
                <label for="address">العنوان الكامل</label>
                <input type="text" id="address" name="address" placeholder="الشارع، الرقم، العمارة..." value="<%= typeof address !== 'undefined' ? address : '' %>" required>
              </div>
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="city">الولاية</label>
                    <select id="city" name="city" required class="input">
                      <option value="">Sélectionnez votre wilaya</option>
                      <!-- wilaya options remain the same -->
<option value="adrar">Adrar</option>
  <option value="chlef">Chlef</option>
  <option value="laghouat">Laghouat</option>
  <option value="oum el bouaghi">Oum El Bouaghi</option>
  <option value="batna">Batna</option>
  <option value="bejaia">Bejaia</option>
  <option value="biskra">Biskra</option>
  <option value="bechar">Bechar</option>
  <option value="bordj badji mokhtar">Bordj Badji Mokhtar</option> <!-- AJOUTÉ -->
  <option value="blida">Blida</option>
  <option value="bouira">Bouira</option>
  <option value="tamanrasset">Tamanrasset</option>
  <option value="tebessa">Tebessa</option>
  <option value="tlemcen">Tlemcen</option>
  <option value="tiaret">Tiaret</option>
  <option value="tizi ouzou">Tizi Ouzou</option>
  <option value="Algiers">Algiers</option>
  <option value="djelfa">Djelfa</option>
  <option value="jijel">Jijel</option>
  <option value="setif">Setif</option>
  <option value="saida">Saida</option>
  <option value="skikda">Skikda</option>
  <option value="sidi belabbes">Sidi Belabbes</option>
  <option value="annaba">Annaba</option> <!-- AJOUTÉ -->
  <option value="guelma">Guelma</option>
  <option value="constantine">Constantine</option>
  <option value="medea">Médéa</option> <!-- AJOUTÉ -->
  <option value="mostaganem">Mostaganem</option>
  <option value="msila">M'sila</option>
  <option value="mascara">Mascara</option>
  <option value="ouargla">Ouargla</option>
  <option value="oran">Oran</option>
  <option value="el bayadh">El Bayadh</option>
  <option value="illizi">Illizi</option> <!-- AJOUTÉ -->
  <option value="bordj bou arreridj">Bordj Bou Arreridj</option>
  <option value="boumerdes">Boumerdes</option>
  <option value="el taref">El Taref</option>
  <option value="tindouf">Tindouf</option>
  <option value="tissemsilt">Tissemsilt</option>
  <option value="el oued">El Oued</option>
  <option value="khenchela">Khenchela</option>
  <option value="souk ahras">Souk Ahras</option>
  <option value="tipaza">Tipaza</option>
  <option value="mila">Mila</option>
  <option value="ain defla">Ain Defla</option>
  <option value="naama">Naama</option>
  <option value="ain temouchent">Ain Temouchent</option>
  <option value="ghardaia">Ghardaia</option>
  <option value="relizane">Relizane</option>
  <option value="el mghair">El M'ghair</option>
  <option value="el menia">El Menia</option>
  <option value="ouled djellal">Ouled Djellal</option>
  <option value="beni abbes">Beni Abbes</option>
  <option value="timimoun">Timimoun</option>
  <option value="touggourt">Touggourt</option>
  <option value="djanet">Djanet</option>
  <option value="in salah">In Salah</option>
  <option value="in guezzam">In Guezzam</option>
</select>
                </div>
                <div class="col-md-6">
                  <label for="commune">البلدية</label>
                  <select id="commune" name="commune" required>
                    <option value="">اختر الولاية أولاً</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Payment Method -->
            <div class="form-section">
              <h3>طريقة الدفع</h3>
              <div class="payment-options">
                <label class="payment-option active" for="payCOD">
                  <input type="radio" id="payCOD" name="paymentMethod" value="cod" checked>
                  <span>الدفع عند الاستلام</span>
                  <p>ادفع نقداً عند استلام الطلب</p>
                </label>
                <label class="payment-option" for="payCIB">
                  <input type="radio" id="payCIB" name="paymentMethod" value="chargily" data-card="cib">
                  <img src="/favicon/cib.png" alt="CIB">
                  <span>بطاقة CIB</span>
                  <p>دفع آمن عبر الإنترنت</p>
                </label>
                <label class="payment-option" for="payEdahabia">
                  <input type="radio" id="payEdahabia" name="paymentMethod" value="chargily" data-card="edahabia">
                  <img src="/favicon/eddahabia.png" alt="Edahabia">
                  <span>بطاقة الذهبية</span>
                  <p>دفع آمن عبر الإنترنت</p>
                </label>
              </div>
            </div>

            <!-- Hidden fields -->
            <input type="hidden" id="shippingFee" name="shippingFee" value="0">
            <input type="hidden" id="deliveryDelay" name="deliveryDelay" value="">
            <input type="hidden" id="totalPriceFinal" name="totalPriceFinal" value="<%= cart.totalPrice %>">
          </form>
        </div>
      </div>

    <div class="col-lg-4">
  <div class="summary-card">
    <h3>ملخص الطلب</h3>

    <!-- Product list with quantity controls -->
    <% if (cart && cart.items) { %>
      <% Object.keys(cart.items).forEach(id => {
           const item = cart.items[id]; %>
        <div class="cart-item" data-product-id="<%= id %>">
          <img src="<%= item.item.image %>" alt="<%= item.item.name %>" />
          <div class="cart-item-details">
            <p><%= item.item.name %></p>
            <div class="qty-control">
              <button type="button" class="qty-btn" data-action="minus">−</button>
              <input type="number" class="qty-input" value="<%= item.qty %>" min="1" readonly />
              <button type="button" class="qty-btn" data-action="plus">+</button>
            </div>
          </div>
          <span class="item-total"><%= (item.item.price * item.qty).toLocaleString('ar-DZ') %> دج</span>
          <!-- hidden field to submit the new quantity -->
          <input type="hidden" name="qtys[<%= id %>]" value="<%= item.qty %>" />
        </div>
      <% }); %>
    <% } %>

    <hr>
    <div class="summary-item">
      <span>إجمالي المنتجات</span>
      <span id="baseTotal"><%= cart.totalPrice.toLocaleString('ar-DZ') %> دج</span>
    </div>
    <div class="summary-item">
      <span>رسوم التوصيل</span>
      <span id="shippingDisplay">—</span>
    </div>
    <div class="summary-item">
      <span>مدة التوصيل</span>
      <span id="delayDisplay">—</span>
    </div>
    <hr>
    <div class="summary-total">
      <span>المبلغ الإجمالي</span>
      <span id="totalDisplay"><%= cart.totalPrice.toLocaleString('ar-DZ') %> دج</span>
    </div>

    <button id="placeOrderBtn" type="submit" form="checkoutForm" class="btn-checkout">
      <i class="fas fa-box"></i> تأكيد الطلب (الدفع عند الاستلام) — <span id="btn-total"><%= cart.totalPrice.toLocaleString('ar-DZ') %> دج</span>
    </button>

    <div class="support-link">
      <a href="tel:0791679611"><i class="fas fa-phone"></i> اتصل بالدعم</a>
    </div>
    <div class="security-note">
      <span><i class="fas fa-lock"></i> دفع آمن</span>
      <span><i class="fas fa-truck"></i> توصيل مضمون</span>
    </div>
  </div>
</div>
    </div>
  </div>
</div>

<!-- Styles (inline to keep everything together) -->
<style>
.cart-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border-light);
}
.cart-item img {
  width: 50px;
  height: 50px;
  object-fit: contain;
  border-radius: 8px;
}
.cart-item-details p {
  margin: 0 0 6px 0;
  font-weight: 500;
}
.qty-control {
  display: flex;
  align-items: center;
  gap: 6px;
}
.qty-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1px solid var(--border-light);
  background: var(--bg-white);
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-dark);
  transition: all 0.2s;
}
.qty-btn:hover {
  background: var(--primary-blue);
  color: white;
  border-color: var(--primary-blue);
}
.qty-input {
  width: 40px;
  text-align: center;
  border: 1px solid var(--border-light);
  border-radius: 8px;
  font-size: 14px;
  padding: 4px;
}
.item-total {
  font-weight: 700;
  color: var(--primary-blue);
  min-width: 70px;
  text-align: left;
}
  :root {
    --primary-blue: #295797;
    --accent-blue: #1C84C1;
    --primary-dark: #1E3F5C;
    --bg-light: #E8EEF6;
    --bg-white: #FFFFFF;
    --border-light: #D1DCE6;
    --shadow-sm: 0 2px 8px rgba(41,87,151,0.08);
    --shadow-md: 0 4px 12px rgba(41,87,151,0.12);
  }

  body { font-family: 'Tajawal','Cairo',sans-serif; background: var(--bg-light); }

  .checkout-container { padding: 60px 0; }
  .checkout-header { text-align: center; margin-bottom: 40px; }
  .checkout-header h1 { font-size: 2rem; font-weight: 700; color: var(--primary-blue); }
  .checkout-header p { color: #666; }

  .checkout-card, .summary-card {
    background: var(--bg-white);
    border-radius: 24px;
    padding: 32px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-light);
  }

  .form-section { margin-bottom: 30px; }
  .form-section h3 {
    font-size: 1.1rem; font-weight: 700; color: var(--primary-blue);
    border-bottom: 1px solid var(--border-light); padding-bottom: 8px; margin-bottom: 16px;
  }

  label { display: block; font-weight: 600; margin-bottom: 4px; color: var(--primary-dark); }
  input, select {
    width: 100%; padding: 12px; border: 1px solid var(--border-light);
    border-radius: 12px; font-size: 0.95rem; transition: border 0.2s;
    background: var(--bg-white);
  }
  input:focus, select:focus { border-color: var(--accent-blue); outline: none; box-shadow: 0 0 0 3px rgba(28,132,193,0.1); }

  .payment-options { display: flex; gap: 15px; flex-wrap: wrap; }
  .payment-option {
    flex: 1; min-width: 150px; background: #fff; border: 2px solid var(--border-light);
    border-radius: 16px; padding: 16px; text-align: center; cursor: pointer;
    transition: border-color 0.3s, background 0.3s; position: relative;
  }
  .payment-option input { display: none; }
  .payment-option.active { border-color: var(--primary-blue); background: rgba(41,87,151,0.04); }
  .payment-option span { display: block; font-weight: 700; color: var(--text-dark); margin-top: 8px; }
  .payment-option p { color: #666; margin: 4px 0 0; font-size: 0.8rem; }
  .payment-option img { height: 36px; margin-bottom: 8px; }

  .summary-item { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem; }
  .summary-total { font-size: 1.2rem; font-weight: 700; color: var(--primary-blue); display: flex; justify-content: space-between; margin-top: 15px; }

  .btn-checkout {
    width: 100%; background: var(--primary-blue); color: white; border: none;
    padding: 14px; border-radius: 50px; font-size: 1rem; font-weight: 700;
    margin-top: 20px; transition: all 0.3s; box-shadow: var(--shadow-sm);
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .btn-checkout:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: var(--shadow-md); }

  .support-link { text-align: center; margin-top: 12px; }
  .support-link a { color: var(--primary-blue); text-decoration: none; font-weight: 600; }
  .security-note { display: flex; justify-content: center; gap: 20px; margin-top: 16px; color: #666; font-size: 0.8rem; }

  @media (max-width: 768px) {
    .payment-options { flex-direction: column; }
  }
</style>

