<% layout('layouts/main') %>
<h2>Request a painter</h2>
<form method="POST" action="/client/project">
  <label>Description</label><input name="description" required>
  <label>Room size</label><input name="roomSize">
  <label>Style</label><input name="style">
  <label>Budget</label><input name="budget" type="number">
  <label>Colors (comma-separated)</label><input name="colors">
  <label>Address</label><input name="address">
  <button type="submit">Submit</button>
</form>
