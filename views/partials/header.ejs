<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <% if (process.env.FB_PIXEL_ID) { %>
    <!-- Meta Pixel Code -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');

      // Advanced matching: use sessionPainter (logged‑in painter) and user (logged‑in client)
      fbq('init', '<%= process.env.FB_PIXEL_ID %>', {
        <% if (typeof user !== 'undefined' && user && user.email) { %>em: '<%= user.email %>',<% } %>
        <% if (typeof user !== 'undefined' && user && user.firstName) { %>fn: '<%= user.firstName %>',<% } %>
        <% if (typeof user !== 'undefined' && user && user.lastName) { %>ln: '<%= user.lastName %>',<% } %>
        <% if (typeof user !== 'undefined' && user && user.numero) { %>ph: '<%= user.numero %>',<% } %>
        <% if (typeof sessionPainter !== 'undefined' && sessionPainter && sessionPainter.email) { %>em: '<%= sessionPainter.email %>',<% } %>
        <% if (typeof sessionPainter !== 'undefined' && sessionPainter && sessionPainter.name) { %>fn: '<%= sessionPainter.name %>',<% } %>
        <% if (typeof sessionPainter !== 'undefined' && sessionPainter && sessionPainter.phone) { %>ph: '<%= sessionPainter.phone %>',<% } %>
      });

      // ---- PageView ----
      fbq('track', 'PageView', {}, {
        eventID: '<%= typeof metaEventIdPageView !== 'undefined' ? metaEventIdPageView : '' %>' || undefined
      });

      // ---- ViewContent (database painter) ----
      <% if (typeof metaEventIdView !== 'undefined' && metaEventIdView && typeof painter !== 'undefined' && painter) { %>
        setTimeout(function() {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'ViewContent', {
              content_name: '<%= painter.name.replace(/'/g, "\\'") %>',
              content_ids: ['<%= painter._id %>'],
              content_type: 'painter_profile',
              value: <%= painter.pricePerSqm || 0 %>,
              currency: 'DZD'
            }, {
              eventID: '<%= metaEventIdView %>'
            });
          }
        }, 1000);
      <% } %>

      // ---- InitiateCheckout (database painter) ----
      <% if (typeof metaEventIdInitiateCheckout !== 'undefined' && metaEventIdInitiateCheckout && typeof painter !== 'undefined' && painter) { %>
        setTimeout(function() {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'InitiateCheckout', {
              content_name: 'Hire <%= painter.name.replace(/'/g, "\\'") %>',
              content_ids: ['<%= painter._id %>'],
              content_type: 'painter_hire',
              value: <%= painter.pricePerSqm || 0 %>,
              currency: 'DZD'
            }, {
              eventID: '<%= metaEventIdInitiateCheckout %>'
            });
          }
        }, 1200);
      <% } %>
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=<%= process.env.FB_PIXEL_ID %>&ev=PageView&noscript=1"
    /></noscript>
    <% } %>

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WQVTHK89');</script>
    <!-- End Google Tag Manager -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HH68LJB4LB"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HH68LJB4LB');
    </script>

    <!-- Clarity -->
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "u0kvphhg42");
    </script>

    <title><%= title %> - Paintello Pro</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    
    <style>
        /* ===== COLOR THEME ===== */
        :root {
            --primary-blue: #295797;
            --accent-blue:  #1C84C1;
            --primary-dark: #1E3F5C;
            --primary-light: #4A7FA8;
            --text-dark: #2D3748;
            --text-gray: #4A5568;
            --bg-light: #E8EEF6;
            --bg-white: #FFFFFF;
            --border-light: #D1DCE6;
            --shadow-sm: 0 2px 8px rgba(41, 87, 151, 0.08);
            --shadow-md: 0 4px 12px rgba(41, 87, 151, 0.12);
            --shadow-lg: 0 8px 24px rgba(41, 87, 151, 0.16);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--text-dark);
            background: var(--bg-light);
        }
        
        .navbar-modern {
            background: var(--bg-white) !important;
            box-shadow: var(--shadow-sm);
            padding: 12px 0;
            transition: all 0.3s ease;
        }
        
        .navbar-modern.scrolled {
            box-shadow: var(--shadow-md);
            padding: 8px 0;
        }
        
        .navbar-brand-modern {
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .navbar-brand-modern i {
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 1.3rem;
        }
        
        .nav-link-modern {
            color: var(--text-dark) !important;
            font-weight: 500;
            padding: 8px 16px !important;
            border-radius: var(--radius-sm);
            transition: all 0.2s ease;
            margin: 0 2px;
        }
        
        .nav-link-modern:hover {
            background: var(--bg-light);
            color: var(--primary-blue) !important;
        }
        
        .dropdown-modern .dropdown-menu {
            border: none;
            box-shadow: var(--shadow-lg);
            border-radius: var(--radius-md);
            padding: 8px;
            margin-top: 8px;
        }
        
        .dropdown-modern .dropdown-item {
            border-radius: var(--radius-sm);
            padding: 8px 16px;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .dropdown-modern .dropdown-item:hover {
            background: rgba(28, 132, 193, 0.06);
            color: var(--accent-blue);
        }
        
        .dropdown-modern .dropdown-item i {
            width: 20px;
            margin-right: 8px;
            color: var(--text-gray);
        }
        
        .btn-login-modern {
            background: transparent;
            border: 1px solid var(--border-light);
            color: var(--text-dark);
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            transition: all 0.2s ease;
            text-decoration: none;
        }
        
        .btn-login-modern:hover {
            border-color: var(--accent-blue);
            background: rgba(28, 132, 193, 0.04);
            color: var(--accent-blue);
        }
        
        .btn-signup-modern {
            background: var(--primary-blue);
            border: none;
            color: white;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            transition: all 0.2s ease;
            text-decoration: none;
        }
        
        .btn-signup-modern:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
        }
        
        .avatar-dropdown {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 40px;
            background: var(--bg-light);
            transition: all 0.2s ease;
        }
        
        .avatar-dropdown:hover {
            background: var(--border-light);
        }
        
        .avatar-small {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }
        
        .avatar-small i {
            font-size: 0.9rem;
        }
        
        .painter-name-nav {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-dark);
        }
        
        .verified-badge-nav {
            background: var(--accent-blue);
            color: white;
            font-size: 0.6rem;
            padding: 2px 6px;
            border-radius: 20px;
            margin-left: 6px;
        }
        
        .card-hover {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
        }
        
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }
        
        .star-rating {
            color: #FBBF24;
        }
        
        [dir="rtl"] {
            text-align: right;
        }
        [dir="rtl"] .me-1 { margin-right: 0 !important; margin-left: 0.25rem !important; }
        [dir="rtl"] .me-2 { margin-right: 0 !important; margin-left: 0.5rem !important; }
        [dir="rtl"] .me-3 { margin-right: 0 !important; margin-left: 1rem !important; }
        [dir="rtl"] .ms-1 { margin-left: 0 !important; margin-right: 0.25rem !important; }
        [dir="rtl"] .ms-2 { margin-left: 0 !important; margin-right: 0.5rem !important; }
        [dir="rtl"] .ms-3 { margin-left: 0 !important; margin-right: 1rem !important; }
        
        @media (max-width: 768px) {
            .navbar-nav { padding: 16px 0; }
            .nav-link-modern { padding: 10px 16px !important; }
            .btn-login-modern, .btn-signup-modern {
                width: 100%;
                text-align: center;
                margin: 5px 0;
                display: inline-block;
            }
            .avatar-dropdown { width: 100%; justify-content: center; }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .navbar-collapse.show { animation: fadeIn 0.3s ease; }
    </style>
</head>
<body>

<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WQVTHK89"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<!-- Modern Navbar -->
<nav class="navbar navbar-expand-lg navbar-modern sticky-top">
    <div class="container">
        <a class="navbar-brand navbar-brand-modern" href="/">
            <i class="fas fa-paint-roller"></i>
            <span>Paintello Pro</span>
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link nav-link-modern" href="/">
                        <i class="fas fa-home me-1"></i> Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link nav-link-modern" href="/painters">
                        <i class="fas fa-search me-1"></i> Find Painters
                    </a>
                </li>
                <% if (typeof sessionPainter !== 'undefined' && sessionPainter) { %>
                <li class="nav-item">
                    <a class="nav-link nav-link-modern" href="/painter/dashboard">
                        <i class="fas fa-chart-line me-1"></i> Dashboard
                    </a>
                </li>
                <% } %>
            </ul>
            
            <ul class="navbar-nav">
                <% if (typeof sessionPainter !== 'undefined' && sessionPainter) { %>
                    <!-- Painter logged in -->
                    <li class="nav-item dropdown dropdown-modern">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <div class="avatar-dropdown">
                                <div class="avatar-small">
                                    <% if (sessionPainter.profilePicture && sessionPainter.profilePicture.url) { %>
                                        <img src="<%= sessionPainter.profilePicture.url %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                                    <% } else { %>
                                        <i class="fas fa-brush"></i>
                                    <% } %>
                                </div>
                                <span class="painter-name-nav">
                                    <%= sessionPainter.name %>
                                    <% if (sessionPainter.verification && sessionPainter.verification.status === 'verified') { %>
                                        <span class="verified-badge-nav">
                                            <i class="fas fa-check-circle"></i> Verified
                                        </span>
                                    <% } %>
                                </span>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/painter/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                            <li><a class="dropdown-item" href="/painter/profile"><i class="fas fa-user-circle"></i> My Profile</a></li>
                            <li><a class="dropdown-item" href="/painter/portfolio"><i class="fas fa-images"></i> Portfolio</a></li>
                            <li><a class="dropdown-item" href="/painter/orders"><i class="fas fa-clipboard-list"></i> My Orders</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/index/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <!-- Not logged in -->
                    <li class="nav-item me-2">
                        <a class="btn-login-modern" href="/auth/login-painter">
                            <i class="fas fa-sign-in-alt me-1"></i> Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn-signup-modern" href="/auth/register-painter">
                            <i class="fas fa-user-plus me-1"></i> Sign Up
                        </a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<script>
    window.addEventListener('scroll', function() {
        const navbar = document.querySelector('.navbar-modern');
        if (window.scrollY > 50) navbar.classList.add('scrolled');
        else navbar.classList.remove('scrolled');
    });
    document.querySelectorAll('.nav-link-modern, .dropdown-item, .btn-login-modern, .btn-signup-modern').forEach(link => {
        if (link) {
            link.addEventListener('click', () => {
                const navbarCollapse = document.querySelector('.navbar-collapse');
                if (navbarCollapse && navbarCollapse.classList.contains('show')) {
                    navbarCollapse.classList.remove('show');
                }
            });
        }
    });
</script>
