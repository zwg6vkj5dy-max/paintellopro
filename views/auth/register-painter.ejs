<<%- include('../partials/header', { title: 'انضم كدهان - بينتيلو برو' }) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="card-title">
                            <i class="fas fa-brush text-primary me-2"></i>
                            انضم إلى فريقنا المحترف
                        </h2>
                        <p class="text-muted">كن دهانًا موثوقًا في بينتيلو برو ونمِّ عملك</p>
                    </div>

<!-- 🔔 رسائل التنبيه العامة -->
<% if (success && success.length) { %>
  <% success.forEach(msg => { %>
    <div class="alert alert-success alert-dismissible fade show"><%= msg %></div>
  <% }) %>
<% } %>

<% if (error && error.length) { %>
  <% error.forEach(msg => { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= msg %></div>
  <% }) %>
<% } %>

<% if (warning && warning.length) { %>
  <% warning.forEach(msg => { %>
    <div class="alert alert-warning alert-dismissible fade show"><%= msg %></div>
  <% }) %>
<% } %>

<% if (info && info.length) { %>
  <% info.forEach(msg => { %>
    <div class="alert alert-info alert-dismissible fade show"><%= msg %></div>
  <% }) %>
<% } %>

                   <!-- Add id="painterRegistrationForm" to your form -->
<form action="/auth/register-painter" method="POST" enctype="multipart/form-data" id="painterRegistrationForm">
                        <!-- المعلومات الشخصية -->
                        <h5 class="mb-3 text-primary">
                            <i class="fas fa-user me-2"></i>المعلومات الشخصية
                        </h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="name" class="form-label">الاسم الكامل *</label>
                                <input type="text" class="form-control" id="name" name="name" 
                                       value="<%= oldInput.name || '' %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="phone" class="form-label">رقم الهاتف *</label>
                                <input type="tel" class="form-control" id="phone" name="phone" 
                                       value="<%= oldInput.phone || '' %>" pattern="[0]{1}[5-7]{1}[0-9]{8}" required>
                                <div class="form-text">التنسيق: 05XX XXX XXX, 06XX XXX XXX, أو 07XX XXX XXX</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">البريد الإلكتروني *</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   value="<%= oldInput.email || '' %>" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="password" class="form-label">كلمة المرور *</label>
                                <input type="password" class="form-control" id="password" name="password" required>
                                <div class="form-text">6 أحرف على الأقل</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="confirmPassword" class="form-label">تأكيد كلمة المرور *</label>
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                            </div>
                        </div>

                        <!-- المعلومات المهنية -->
                        <h5 class="mb-3 mt-4 text-primary">
                            <i class="fas fa-briefcase me-2"></i>المعلومات المهنية
                        </h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="experience" class="form-label">سنوات الخبرة *</label>
                                <input type="number" class="form-control" id="experience" name="experience" 
                                       value="<%= oldInput.experience || '' %>" min="0" max="50" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="pricePerSqm" class="form-label">السعر لكل متر مربع (دج) *</label>
                                <input type="number" class="form-control" id="pricePerSqm" name="pricePerSqm" 
                                       value="<%= oldInput.pricePerSqm || '' %>" min="0" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">التخصص *</label>
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="specialization" value="interior" 
                                               id="interior" <%= (oldInput.specialization && oldInput.specialization.includes('interior')) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="interior">دهان داخلي</label>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="specialization" value="exterior" 
                                               id="exterior" <%= (oldInput.specialization && oldInput.specialization.includes('exterior')) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="exterior">دهان خارجي</label>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="specialization" value="commercial" 
                                               id="commercial" <%= (oldInput.specialization && oldInput.specialization.includes('commercial')) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="commercial">تجاري</label>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="specialization" value="residential" 
                                               id="residential" <%= (oldInput.specialization && oldInput.specialization.includes('residential')) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="residential">سكني</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- معلومات الموقع -->
                        <h5 class="mb-3 mt-4 text-primary">
                            <i class="fas fa-map-marker-alt me-2"></i>معلومات الموقع
                        </h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="wilaya" class="form-label">الولاية *</label>
                                <select class="form-select" id="wilaya" name="wilaya" required>
                                    <option value="">اختر الولاية</option>
                                    <% wilayas.forEach(wilaya => { %>
                                    <option value="<%= wilaya.name %>" 
                                            <%= (oldInput.wilaya === wilaya.name) ? 'selected' : '' %>>
                                        <%= wilaya.name %> (<%= wilaya.number %>)
                                    </option>
                                    <% }); %>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="wilayaNumber" class="form-label">رقم الولاية *</label>
                                <input type="number" class="form-control" id="wilayaNumber" name="wilayaNumber" 
                                       value="<%= oldInput.wilayaNumber || '' %>" readonly required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="address" class="form-label">العنوان الكامل *</label>
                            <textarea class="form-control" id="address" name="address" rows="2" required><%= oldInput.address || '' %></textarea>
                        </div>

                        <!-- التحقق -->
                        <h5 class="mb-3 mt-4 text-primary">
                            <i class="fas fa-id-card me-2"></i>التحقق
                        </h5>
                        <div class="mb-3">
                            <label for="idCard" class="form-label">صورة بطاقة الهوية *</label>
                            <input type="file" class="form-control" id="idCard" name="idCard" accept="image/*" required>
                            <div class="form-text">
                                <i class="fas fa-info-circle text-info me-1"></i>
                                قم برفع صورة واضحة لبطاقة الهوية الوطنية.
                                الحجم الأقصى: 2 ميجابايت. الصيغ المدعومة: JPG, PNG, WebP.
                            </div>
                        </div>

                        <!-- المحفظة (اختياري - عملية يدوية) -->
                        <div class="mb-3">
                            <label class="form-label">صور الأعمال السابقة</label>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>عملية إرسال المحفظة:</strong><br>
                                بعد التسجيل، يمكنك إرسال صور أعمالك إلى فريق الإدارة.
                                سنقوم برفعها إلى المعرض وإضافتها إلى ملفك الشخصي يدويًا.
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="terms" required>
                            <label class="form-check-label" for="terms">
                                أوافق على <a href="/terms" class="text-decoration-none">شروط الخدمة</a>، 
                                <a href="/privacy" class="text-decoration-none">سياسة الخصوصية</a>، وهيكل العمولة
                            </label>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-check me-2"></i>تقديم طلب الانضمام كدهان محترف
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="mb-0">
                                هل لديك حساب بالفعل؟ 
                                <a href="/auth/login-painter" class="text-decoration-none">سجل الدخول كدهان</a>
                            </p>
                            
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
window.dataLayer = window.dataLayer || [];

document.getElementById('painterRegistrationForm').addEventListener('submit', function(e) {
    // These names MUST match your GTM variables exactly
    window.dataLayer.push({
        'event': 'ga4_sign_up',
        'user_wilaya': document.getElementById('wilaya').value,
        'painter_price_sqm': parseInt(document.getElementById('pricePerSqm').value) || 0,
        'painter_experience': parseInt(document.getElementById('experience').value) || 0,
        'painter_specialization': Array.from(document.querySelectorAll('input[name="specialization"]:checked'))
                                    .map(cb => cb.value).join(', ')
    });
});
</script>
<script>
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(alert => {
      const bsAlert = new bootstrap.Alert(alert);
      bsAlert.close();
    });
  }, 4000);
</script>

<%- include('../partials/footer') %>
