<%- include('../partials/header', { title: 'Painter Login - Paintello Pro' }) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Painter Login</h2>
                  <% if (success && success.length) { %>
  <% success.forEach(msg => { %>
    <div class="alert alert-success"><%= msg %></div>
  <% }) %>
<% } %>

<% if (error && error.length) { %>
  <% error.forEach(msg => { %>
    <div class="alert alert-danger"><%= msg %></div>
  <% }) %>
<% } %>

<% if (warning && warning.length) { %>
  <% warning.forEach(msg => { %>
    <div class="alert alert-warning"><%= msg %></div>
  <% }) %>
<% } %>

<% if (info && info.length) { %>
  <% info.forEach(msg => { %>
    <div class="alert alert-info"><%= msg %></div>
  <% }) %>
<% } %>


                    <form action="/auth/login-painter" method="POST">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>
                        
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">Login</button>
                        </div>
                        
                        <div class="text-center">
                            <p class="mb-0">Don't have an account? 
                                <a href="/auth/register-painter" class="text-decoration-none">Register as Painter</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
