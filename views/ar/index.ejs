    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

[dir="rtl"] .btn-cta-light i {
    margin-left: 8px;
    margin-right: 0;
}

.btn-cta-light:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-cta-outline {
    background: transparent;
    border: 2px solid white;
    color: white;
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-flex;
