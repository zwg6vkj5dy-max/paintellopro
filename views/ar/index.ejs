<%- include('../partials/header', { title: 'بينتيلو برو - Find Professional Painters in Algeria' }) %>

<!-- Language Switcher -->
<div class="container-fluid bg-light py-2">
    <div class="container">
        <div class="d-flex justify-content-end">
            <div class="btn-group btn-group-sm">
                <a href="/" class="btn btn-outline-primary">English</a>
                <a href="/ar" class="btn btn-outline-primary active">العربية</a>
            </div>
        </div>
    </div>
</div>

<!-- Hero Section -->
<section class="hero-section" dir="rtl">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">ابحث عن دهانين محترفين في منطقتك</h1>
                <p class="lead mb-4">تواصل مع دهانين موثوقين عبر الجزائر. خدمة عالية الجودة، أسعار عادلة، ورضا مضمون لجميع مشاريع الدهان الخاصة بك.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/ar/painters" class="btn btn-light btn-lg">
                        <i class="fas fa-search me-2"></i>ابحث عن دهانين
                    </a>
                    <a href="/ar/auth/register-painter" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-brush me-2"></i>انضم كدهان
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="/images/hero-painter.png" alt="دهان محترف" class="img-fluid" style="max-height: 400px;">
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5 bg-light" dir="rtl">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">كيف تعمل بينتيلو برو</h2>
            <p class="text-muted lead">خطوات بسيطة لإنجاز مشروع الدهان الخاص بك</p>
        </div>
        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="bg-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-search fa-2x text-white"></i>
                    </div>
                    <h5>ابحث عن دهّامين</h5>
                    <p class="text-muted">ابحث عن دهانين موثوقين في ولايتك مع التقييمات والأعمال السابقة</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="bg-success rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-clipboard-list fa-2x text-white"></i>
                    </div>
                    <h5>أنشئ طلب</h5>
                    <p class="text-muted">صف مشروعك، حدد الميزانية، واختر الدهان المفضل لديك</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="bg-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-paint-roller fa-2x text-white"></i>
                    </div>
                    <h5>ابدأ العمل</h5>
                    <p class="text-muted">يقوم دهانين المحترفون بإنجاز مشروعك بمواد عالية الجودة</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="text-center">
                    <div class="bg-info rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px;">
                        <i class="fas fa-star fa-2x text-white"></i>
                    </div>
                    <h5>قيم العمل</h5>
                    <p class="text-muted">شارك تجربتك وساعد في الحفاظ على معايير الجودة</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Painters -->
<section class="py-5" dir="rtl">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold">الدهانين المميزين</h2>
                <p class="text-muted">المحترفون الأعلى تقييماً في منطقتك</p>
            </div>
            <a href="/painters" class="btn btn-outline-primary">عرض جميع الدهانين</a>
        </div>
        <div class="row">
            <% featuredPainters.forEach(painter => { %>
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card card-hover shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar-placeholder bg-primary rounded-circle me-3 d-flex align-items-center justify-content-center"
                                 style="width: 50px; height: 50px;">
                                <% if (painter.profilePicture && painter.profilePicture.url) { %>
                                    <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>" 
                                         style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                                <% } else { %>
                                    <i class="fas fa-brush text-white"></i>
                                <% } %>
                            </div>
                            <div>
                                <h6 class="mb-0"><%= painter.name %></h6>
                                <small class="text-muted">
                                    <i class="fas fa-map-marker-alt me-1"></i>
                                    <%= painter.location.wilaya %>
                                </small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="star-rating mb-2">
                                <% for (let i = 1; i <= 5; i++) { %>
                                <i class="fas fa-star <%= i <= painter.rating ? 'text-warning' : 'text-muted' %>"></i>
                                <% } %>
                                <span class="ms-1">(<%= painter.rating.toFixed(1) %>)</span>
                            </div>
                            <div class="d-flex justify-content-between text-muted small">
                                <span><%= painter.experience %> سنوات خبرة</span>
                                <span><%= painter.completedJobs %> مشروع</span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 text-primary mb-0"><%= painter.pricePerSqm %> دج/م²</span>
                            <a href="/painters/<%= painter._id %>" class="btn btn-primary btn-sm">عرض الملف</a>
                        </div>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-primary text-white" dir="rtl">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">مستعد لبدء مشروع الدهان الخاص بك؟</h2>
        <p class="lead mb-4">انضم إلى آلاف العملاء الراضين الذين وجدوا دهّامهم المثالي عبر بينتيلو برو</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
           
            <a href="/auth/register-painter" class="btn btn-outline-light btn-lg">انضم كدهّام محترف</a>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
