<%- include('../partials/header', { title: 'بينتيلو برو - منصة الدهانين المحترفين في الجزائر' }) %>

<!-- Leaflet CSS + JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    /* ===== COLOR THEME & SYSTEM VARIABLES ===== */
    :root {
        --primary-blue: #295797;        /* Main brand colour */
        --accent-blue:  #1C84C1;        /* Vibrant sky blue for accents */
        --primary-dark: #1E3F5C;        /* Darker shade for depth */
        --primary-light: #4A7FA8;       /* Lighter variant for gradients */
        --text-dark: #1A202C;
        --text-gray: #718096;
        --bg-light: #F8FAFC;            /* Page background tint */
        --bg-white: #FFFFFF;
        --border-light: #E2E8F0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.03);
        --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.05), 0 4px 6px -2px rgba(0,0,0,0.03);
        --shadow-lg: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        --radius-lg: 16px;
        --radius-md: 12px;
        --radius-sm: 8px;
        --hero-gradient-start: #295797;
        --hero-gradient-end: #1C84C1;   /* Accent blue for gradient */
    }

    /* Import Arabic fonts */
    @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap');

    body {
        font-family: 'Tajawal', 'Cairo', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background-color: var(--bg-light);
    }

    /* RTL Layout Helpers */
    [dir="rtl"] {
        text-align: right;
    }
    [dir="rtl"] .me-1 { margin-right: 0 !important; margin-left: 0.25rem !important; }
    [dir="rtl"] .me-2 { margin-right: 0 !important; margin-left: 0.5rem !important; }
    [dir="rtl"] .ms-1 { margin-left: 0 !important; margin-right: 0.25rem !important; }
    [dir="rtl"] .ms-2 { margin-left: 0 !important; margin-right: 0.5rem !important; }
    
    [dir="rtl"] .hero-buttons .btn-hero-primary i,
    [dir="rtl"] .hero-buttons .btn-hero-secondary i {
        margin-left: 8px;
        margin-right: 0;
    }
    [dir="rtl"] .view-all-link i {
        transform: rotate(180deg);
    }
    [dir="rtl"] .map-legend, 
    [dir="rtl"] .legend-item, 
    [dir="rtl"] .map-stat-card {
        flex-direction: row-reverse;
        text-align: right;
    }

    /* ---- Language Switcher ---- */
    .language-switcher-modern {
        background: var(--bg-white);
        border-bottom: 1px solid var(--border-light);
        padding: 8px 0;
    }
    .language-switcher-modern .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }
    .language-buttons {
        display: flex;
        gap: 8px;
        justify-content: flex-start;
    }
    [dir="rtl"] .language-buttons {
        justify-content: flex-end;
    }
    .btn-lang {
        padding: 6px 18px;
        border-radius: 40px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
        border: 1px solid var(--border-light);
        background: transparent;
        color: var(--text-gray);
    }
    .btn-lang.active {
        background: var(--primary-blue);
        border-color: var(--primary-blue);
        color: white;
    }
    .btn-lang:hover:not(.active) {
        border-color: var(--accent-blue);
        color: var(--accent-blue);
    }

    /* ---- Hero Section ---- */
    .hero-modern {
        background: linear-gradient(135deg, var(--hero-gradient-start) 0%, var(--hero-gradient-end) 100%);
        position: relative;
        overflow: hidden;
        padding: 60px 0;
    }
    .hero-modern::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.06)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
        background-size: cover;
        opacity: 0.4;
    }
    .hero-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        position: relative;
        z-index: 2;
    }
    .hero-grid {
        display: flex;
        align-items: center;
        gap: 60px;
        flex-wrap: wrap;
    }
    [dir="rtl"] .hero-grid {
        flex-direction: row-reverse;
    }
    .hero-content {
        flex: 1;
        min-width: 280px;
    }
    .hero-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        padding: 6px 16px;
        border-radius: 40px;
        font-size: 0.85rem;
        font-weight: 500;
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        margin-bottom: 24px;
    }
    .hero-title {
        font-size: 3rem;
        font-weight: 800;
        color: white;
        margin-bottom: 20px;
        line-height: 1.3;
    }
    .hero-title .highlight-pro {
        color: #FFD700;
        position: relative;
    }
    .hero-title .highlight-pro::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: #FFD700;
        border-radius: 4px;
        opacity: 0.5;
    }
    .hero-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 32px;
        line-height: 1.8;
    }
    .hero-buttons {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 32px;
    }
    .btn-hero-primary {
        background: white;
        color: var(--primary-blue);
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: var(--shadow-md);
    }
    .btn-hero-primary:hover {
        background: #f0f4fa;
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        color: var(--primary-blue);
    }
    .btn-hero-secondary {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.4);
        color: white;
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    .btn-hero-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: white;
        color: white;
        transform: translateY(-2px);
    }
    .trust-badges {
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
    }
    .trust-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.85rem;
    }
    .trust-item i { color: #FFD700; }
    [dir="rtl"] .trust-item i { margin-left: 6px; margin-right: 0; }

    .hero-image {
        flex: 1;
        text-align: center;
        min-width: 280px;
    }
    .hero-image img {
        max-width: 100%;
        max-height: 400px;
        filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.2));
        border-radius: var(--radius-md);
    }

    /* ---- Stats Section ---- */
    .stats-modern {
        background: var(--bg-white);
        padding: 50px 0;
        border-bottom: 1px solid var(--border-light);
    }
    .stats-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 40px;
    }
    .stat-item { text-align: center; }
    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary-blue);
        display: block;
    }
    .stat-label {
        font-size: 0.85rem;
        color: var(--text-gray);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ---- Map Section ---- */
    .map-section-modern {
        padding: 80px 0;
        background: #F1F5F9;
        border-top: 1px solid var(--border-light);
        border-bottom: 1px solid var(--border-light);
    }
    .section-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 48px;
    }
    .section-header h2 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 16px;
    }
    .section-header p { font-size: 1rem; color: var(--text-gray); }
    
    #algeriaMap {
        height: 500px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        margin-top: 20px;
        z-index: 1;
        background: #DDE6EF;
        border: 1px solid var(--border-light);
    }
    .map-legend {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-top: 20px;
        flex-wrap: wrap;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: var(--text-gray);
        background: var(--bg-white);
        padding: 6px 12px;
        border-radius: 40px;
        border: 1px solid var(--border-light);
        box-shadow: var(--shadow-sm);
    }
    .legend-dot { width: 12px; height: 12px; border-radius: 50%; }
    .legend-dot.high { background: var(--primary-blue); box-shadow: 0 0 0 3px rgba(41, 87, 151, 0.2); }
    .legend-dot.medium { background: var(--accent-blue); box-shadow: 0 0 0 3px rgba(28, 132, 193, 0.2); }
    .legend-dot.low { background: #A0C4D9; }

    .map-stats-grid {
        max-width: 800px;
        margin: 30px auto 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 24px;
    }
    .map-stat-card {
        background: var(--bg-white);
        border-radius: var(--radius-lg);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        border: 1px solid var(--border-light);
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
    }
    .map-stat-card:hover {
        transform: translateY(-3px);
        border-color: var(--accent-blue);
        box-shadow: var(--shadow-md);
    }
    .map-stat-card i { font-size: 2rem; color: var(--primary-blue); }
    .map-stat-number {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-blue);
        display: block;
        line-height: 1;
    }
    .map-stat-label { font-size: 0.8rem; color: var(--text-gray); }

    /* ---- Modernized Products Carousel Section ---- */
    .products-section {
        background: #F8FAFC !important;
        padding: 80px 0;
    }
    .section-header-with-link {
        max-width: 1200px;
        margin: 0 auto 40px;
        padding: 0 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
    }
    [dir="rtl"] .section-header-with-link { flex-direction: row-reverse; }
    .section-header-with-link h2 { font-size: 1.8rem; font-weight: 700; color: var(--text-dark); margin-bottom: 8px; }
    .section-header-with-link p { color: var(--text-gray); margin: 0; }

    .view-all-link {
        color: var(--primary-blue);
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        padding: 8px 16px;
        border-radius: 40px;
        background: rgba(41, 87, 151, 0.06);
        border: 1px solid rgba(41, 87, 151, 0.1);
    }
    .view-all-link:hover { gap: 12px; background: var(--primary-blue); color: white; }

    .carousel-container {
        position: relative;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
    }
    .carousel-track {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding: 20px 4px;
        scrollbar-width: none;
        -ms-overflow-style: none;
        snap-type: x mandatory;
    }
    .carousel-track::-webkit-scrollbar { display: none; }

    .carousel-card {
        flex: 0 0 260px;
        background: var(--bg-white);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-light);
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
        cursor: pointer;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        snap-align: start;
    }
    .carousel-card:hover {
        transform: translateY(-6px);
        border-color: #CBD5E1;
        box-shadow: var(--shadow-lg);
    }
    .carousel-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        background: #FFFFFF;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-bottom: 1px solid var(--border-light);
        position: relative;
    }
    .carousel-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 20px;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .carousel-card:hover .carousel-image img { transform: scale(1.06); }

    .carousel-body {
        padding: 20px;
        text-align: right;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .carousel-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 8px;
        line-height: 1.4;
        height: 2.8em;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }
    .carousel-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--primary-blue);
        margin-bottom: 16px;
    }
    .btn-carousel-detail {
        width: 100%;
        padding: 10px;
        background: transparent;
        border: 1px solid var(--border-light);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-gray);
        transition: all 0.2s ease;
        cursor: pointer;
        margin-top: auto;
        text-align: center;
    }
    .carousel-card:hover .btn-carousel-detail {
        border-color: var(--primary-blue);
        background: var(--primary-blue);
        color: white;
    }
    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: var(--bg-white);
        border: 1px solid var(--border-light);
        border-radius: 50%;
        width: 46px;
        height: 46px;
        font-size: 1.25rem;
        color: var(--text-dark);
        cursor: pointer;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
        transition: all 0.2s ease;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .carousel-btn:hover {
        background: var(--bg-white);
        color: var(--primary-blue);
        border-color: #CBD5E1;
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.08);
    }
    .carousel-btn.prev { left: -8px; }
    .carousel-btn.next { right: -8px; }

    /* ---- How It Works ---- */
    .how-it-works-modern {
        padding: 80px 0;
        background: var(--bg-white);
    }
    .steps-grid {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }
    .step-card-modern {
        text-align: center;
        padding: 32px 24px;
        background: var(--bg-light);
        border-radius: var(--radius-lg);
        transition: all 0.3s ease;
        border: 1px solid var(--border-light);
    }
    .step-card-modern:hover {
        transform: translateY(-8px);
        border-color: var(--primary-blue);
        box-shadow: var(--shadow-md);
    }
    .step-icon-wrapper {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }
    .step-icon-wrapper i { font-size: 2rem; color: white; }
    .step-number-modern {
        width: 32px;
        height: 32px;
        background: var(--accent-blue);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-weight: 700;
        font-size: 0.85rem;
    }
    .step-card-modern h3 { font-size: 1.25rem; font-weight: 600; color: var(--text-dark); margin-bottom: 12px; }
    .step-card-modern p { color: var(--text-gray); line-height: 1.8; font-size: 0.9rem; }

    /* ---- CTA Section ---- */
    .cta-modern {
        background: linear-gradient(135deg, var(--hero-gradient-start) 0%, var(--hero-gradient-end) 100%);
        padding: 80px 0;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-top: 1px solid var(--border-light);
    }
    .cta-modern::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.05)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat top;
        background-size: cover;
    }
    .cta-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 0 24px;
        position: relative;
        z-index: 2;
    }
    .cta-modern h2 { font-size: 2rem; font-weight: 700; color: white; margin-bottom: 16px; }
    .cta-modern p { font-size: 1.1rem; color: rgba(255, 255, 255, 0.85); margin-bottom: 32px; line-height: 1.8; }
    .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    
    .btn-cta-light {
        background: white;
        color: var(--primary-blue);
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: var(--shadow-md);
    }
    [dir="rtl"] .btn-cta-light i { margin-left: 8px; margin-right: 0; }
    .btn-cta-light:hover { background: #f0f4fa; transform: translateY(-2px); box-shadow: var(--shadow-lg); color: var(--primary-blue); }

    .btn-cta-outline {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.4);
        color: white;
        padding: 14px 32px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }
    [dir="rtl"] .btn-cta-outline i { margin-left: 8px; margin-right: 0; }
    .btn-cta-outline:hover { background: rgba(255, 255, 255, 0.1); border-color: white; color: white; transform: translateY(-2px); }

    /* ---- Responsive Design ---- */
    @media (max-width: 768px) {
        .hero-title { font-size: 2rem; }
        .hero-description { font-size: 1rem; }
        .hero-grid { gap: 40px; text-align: center; }
        .hero-buttons, .trust-badges, .language-buttons { justify-content: center; }
        .section-header h2 { font-size: 1.6rem; }
        .steps-grid { grid-template-columns: 1fr; gap: 20px; }
        .section-header-with-link { flex-direction: column; text-align: center; }
        .stats-container { gap: 25px; }
        .stat-number { font-size: 1.5rem; }
        .cta-modern h2 { font-size: 1.5rem; }
        #algeriaMap { height: 350px; }
        .map-stats-grid { grid-template-columns: 1fr; padding: 0 20px; }
        .legend-item { font-size: 0.7rem; }
        .carousel-container { padding: 0 10px; }
        .carousel-card { flex: 0 0 210px; }
        .carousel-btn { display: none; }
    }

    /* ---- Smooth Animations ---- */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .hero-content, .hero-image, .step-card-modern {
        animation: fadeInUp 0.6s ease forwards;
    }
</style>

<!-- ===== LANGUAGE SWITCHER ===== -->
<div class="language-switcher-modern">
    <div class="container">
        <div class="language-buttons">
            <a href="/" class="btn-lang">English</a>
            <a href="/ar" class="btn-lang active">العربية</a>
        </div>
    </div>
</div>

<!-- ===== HERO SECTION ===== -->
<section class="hero-modern" dir="rtl">
    <div class="hero-container">
        <div class="hero-grid">
            <div class="hero-content">
                <div class="hero-badge"><i class="fas fa-check-circle"></i> المنصة الأولى للدهانين في الجزائر</div>
                <h1 class="hero-title">
