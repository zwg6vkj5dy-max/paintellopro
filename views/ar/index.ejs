<section class="stats-modern" dir="rtl">
    <div class="stats-container">
        <div class="stat-item"><span class="stat-number">500+</span><span class="stat-label">دهان موثوق</span></div>
        <div class="stat-item"><span class="stat-number">2,000+</span><span class="stat-label">عميل سعيد</span></div>
        <div class="stat-item"><span class="stat-number">58</span><span class="stat-label">ولاية مغطاة</span></div>
        <div class="stat-item"><span class="stat-number">4.9★</span><span class="stat-label">متوسط التقييم</span></div>
    </div>
</section>

<!-- ===== INTERACTIVE MAP SECTION (ARABIC TEXT) ===== -->
<section class="map-section-modern" dir="rtl">
    <div class="container">
        <div class="section-header">
            <h2>الدهانين عبر الجزائر</h2>
            <p>شبكتنا من الدهانين المحترفين تغطي جميع الولايات الـ 58</p>
        </div>
        <div id="algeriaMap"></div>
        <div class="map-legend">
            <div class="legend-item"><div class="legend-dot high"></div><span>نشاط عالي (50+ دهان)</span></div>
            <div class="legend-item"><div class="legend-dot medium"></div><span>نشاط متوسط (20-50)</span></div>
            <div class="legend-item"><div class="legend-dot low"></div><span>نشاط متنامٍ (أقل من 20)</span></div>
        </div>
        <div class="map-stats-grid">
            <div class="map-stat-card"><i class="fas fa-city"></i><div><span class="map-stat-number">58</span><span class="map-stat-label">ولاية مغطاة</span></div></div>
            <div class="map-stat-card"><i class="fas fa-users"></i><div><span class="map-stat-number">500+</span><span class="map-stat-label">دهان نشط</span></div></div>
            <div class="map-stat-card"><i class="fas fa-chart-line"></i><div><span class="map-stat-number">100%</span><span class="map-stat-label">تغطية وطنية</span></div></div>
        </div>
    </div>
</section>

<!-- ===== HOW IT WORKS (ARABIC) ===== -->
<section class="how-it-works-modern" dir="rtl">
    <div class="section-header">
        <h2>كيف تعمل بينتيلو برو</h2>
        <p>خطوات بسيطة لإنجاز مشروع الدهان الخاص بك بكل سهولة</p>
    </div>
    <div class="steps-grid">
        <div class="step-card-modern">
            <div class="step-number-modern">١</div>
            <div class="step-icon-wrapper"><i class="fas fa-search"></i></div>
            <h3>ابحث عن دهانين</h3>
            <p>ابحث عن دهانين موثوقين في ولايتك مع التقييمات والأعمال السابقة</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">٢</div>
            <div class="step-icon-wrapper"><i class="fas fa-clipboard-list"></i></div>
            <h3>أنشئ طلباً</h3>
            <p>صف مشروعك، حدد الميزانية، واختر الدهان المفضل لديك</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">٣</div>
            <div class="step-icon-wrapper"><i class="fas fa-paint-roller"></i></div>
            <h3>ابدأ العمل</h3>
            <p>يقوم الدهانين المحترفون بإنجاز مشروعك بمواد عالية الجودة</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">٤</div>
            <div class="step-icon-wrapper"><i class="fas fa-star"></i></div>
            <h3>قيم العمل</h3>
            <p>شارك تجربتك وساعد في الحفاظ على معايير الجودة</p>
        </div>
    </div>
</section>

<!-- ===== FEATURED PAINTERS (ARABIC) ===== -->
<section class="featured-modern" dir="rtl">
    <div class="section-header-with-link">
        <div><h2>الدهانين المميزين</h2><p>المحترفون الأعلى تقييماً في منطقتك</p></div>
        <a href="/painters" class="view-all-link">عرض جميع الدهانين <i class="fas fa-arrow-left"></i></a>
    </div>
    <div class="painters-grid-home">
        <% featuredPainters.forEach(painter => { %>
        <div class="painter-card-home" onclick="window.location.href='/painters/<%= painter._id %>'">
            <div class="card-body-home">
                <div class="avatar-home">
                    <% if (painter.profilePicture && painter.profilePicture.url) { %>
                        <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
                    <% } else { %>
                        <i class="fas fa-brush"></i>
                    <% } %>
                    <% if (painter.verification?.status === 'verified') { %>
                        <div class="verified-badge-home"><i class="fas fa-check"></i></div>
                    <% } %>
                </div>
                <div class="painter-name-home"><%= painter.name %></div>
                <div class="painter-location-home"><i class="fas fa-map-marker-alt"></i> <%= painter.location?.wilaya || 'الجزائر' %></div>
                <div class="stats-home">
                    <div class="stat-home"><span class="stat-value-home"><%= painter.experience || 0 %></span><span class="stat-label-home">سنوات</span></div>
                    <div class="stat-home"><span class="stat-value-home"><%= painter.completedJobs || 0 %></span><span class="stat-label-home">مشاريع</span></div>
                </div>
                <div class="rating-home">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= Math.round(painter.rating || 0) ? 'text-warning' : 'text-muted' %>" style="color: <%= i <= Math.round(painter.rating || 0) ? '#FBBF24' : '#E2E8F0' %>;"></i>
                    <% } %>
                    <span style="font-size: 0.7rem; color: var(--text-gray); margin-right: 4px;">(<%= (painter.rating || 0).toFixed(1) %>)</span>
                </div>
                <div class="price-home"><%= painter.pricePerSqm || 0 %> دج/م²</div>
                <button class="btn-profile-home" onclick="event.stopPropagation(); window.location.href='/painters/<%= painter._id %>'">عرض الملف الشخصي</button>
            </div>
        </div>
        <% }); %>
    </div>
</section>

<!-- ===== CTA SECTION (ARABIC) ===== -->
<section class="cta-modern" dir="rtl">
    <div class="cta-container">
        <h2>مستعد لبدء مشروع الدهان الخاص بك؟</h2>
        <p>انضم إلى آلاف العملاء الراضين الذين وجدوا دهّامهم المثالي عبر بينتيلو برو</p>
        <div class="cta-buttons">
            <a href="/auth/register" class="btn-cta-light"><i class="fas fa-user-plus"></i> ابدأ كعميل</a>
            <a href="/auth/register-painter" class="btn-cta-outline"><i class="fas fa-brush"></i> انضم كدهان</a>
        </div>
    </div>
</section>

<script>
    // Same map initialization as English version (works with RTL layout)
    var map = L.map('algeriaMap').setView([28.0, 2.0], 6);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; CartoDB',
        subdomains: 'abcd',
        maxZoom: 19,
        minZoom: 5
    }).addTo(map);
    
    const wilayas = [
        { name: "الجزائر", lat: 36.763056, lng: 3.050556, painters: 128, activity: "high" },
        { name: "وهران", lat: 35.696944, lng: -0.633056, painters: 86, activity: "high" },
        { name: "قسنطينة", lat: 36.365, lng: 6.614722, painters: 64, activity: "high" },
        { name: "عنابة", lat: 36.902778, lng: 7.7525, painters: 42, activity: "medium" },
        { name: "تيزي وزو", lat: 36.716667, lng: 4.05, painters: 38, activity: "medium" },
        { name: "بجاية", lat: 36.75, lng: 5.083333, painters: 35, activity: "medium" },
        { name: "سطيف", lat: 36.183333, lng: 5.4, painters: 52, activity: "medium" },
        { name: "البليدة", lat: 36.466667, lng: 2.816667, painters: 29, activity: "low" },
        { name: "تلمسان", lat: 34.882778, lng: -1.316667, painters: 31, activity: "low" },
        { name: "باتنة", lat: 35.555, lng: 6.178056, painters: 27, activity: "low" },
        { name: "بسكرة", lat: 34.85, lng: 5.733333, painters: 22, activity: "low" },
        { name: "الجلفة", lat: 34.666667, lng: 3.25, painters: 18, activity: "low" },
        { name: "ورقلة", lat: 31.95, lng: 5.316667, painters: 15, activity: "low" },
        { name: "غرداية", lat: 32.483333, lng: 3.666667, painters: 12, activity: "low" },
        { name: "تمنراست", lat: 22.785, lng: 5.522778, painters: 8, activity: "low" }
    ];
    
    const markerColors = { high: '#2C5F8A', medium: '#7AB2C8', low: '#B8D4E3' };
    
    wilayas.forEach(w => {
        const color = markerColors[w.activity];
        const customIcon = L.divIcon({
            html: `<div style="background-color: ${color}; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 12px; border: 2px solid white; box-shadow: 0 2px 6px rgba(0,0,0,0.3);">${w.painters}</div>`,
            iconSize: [32, 32],
            className: 'custom-marker'
        });
        const marker = L.marker([w.lat, w.lng], { icon: customIcon }).addTo(map);
        marker.bindPopup(`<b>${w.name}</b><br><span style="color: #2C5F8A;">${w.painters} دهاناً</span><br><small>محترفون جاهزون للعمل</small>`);
    });
    
    L.control.scale({ metric: true, imperial: false }).addTo(map);
    const group = L.featureGroup(wilayas.map(w => L.marker([w.lat, w.lng])));
    map.fitBounds(group.getBounds().pad(0.2));
</script>

<%- include('../partials/footer') %>
