                <i class="fas fa-clipboard-list"></i>
            </div>
            <h3>أنشئ طلباً</h3>
            <p>صف مشروعك، حدد الميزانية، واختر الدهان المفضل لديك</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">٣</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-paint-roller"></i>
            </div>
            <h3>ابدأ العمل</h3>
            <p>يقوم الدهانين المحترفون بإنجاز مشروعك بمواد عالية الجودة</p>
        </div>
        <div class="step-card-modern">
            <div class="step-number-modern">٤</div>
            <div class="step-icon-wrapper">
                <i class="fas fa-star"></i>
            </div>
            <h3>قيم العمل</h3>
            <p>شارك تجربتك وساعد في الحفاظ على معايير الجودة</p>
        </div>
    </div>
</section>

<!-- Featured Painters - Modern Arabic -->
<section class="featured-modern" dir="rtl">
    <div class="section-header-with-link">
        <div>
            <h2>الدهانين المميزين</h2>
            <p>المحترفون الأعلى تقييماً في منطقتك</p>
        </div>
        <a href="/painters" class="view-all-link">
            عرض جميع الدهانين <i class="fas fa-arrow-left"></i>
        </a>
    </div>
    
    <div class="painters-grid-home">
        <% featuredPainters.forEach(painter => { %>
        <div class="painter-card-home" onclick="window.location.href='/painters/<%= painter._id %>'">
            <div class="card-body-home">
                <div class="avatar-home">
                    <% if (painter.profilePicture && painter.profilePicture.url) { %>
                        <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
                    <% } else { %>
                        <i class="fas fa-brush"></i>
                    <% } %>
                    <% if (painter.verification?.status === 'verified') { %>
                        <div class="verified-badge-home">
                            <i class="fas fa-check"></i>
                        </div>
                    <% } %>
                </div>
                <div class="painter-name-home"><%= painter.name %></div>
                <div class="painter-location-home">
                    <i class="fas fa-map-marker-alt"></i> <%= painter.location?.wilaya || 'الجزائر' %>
                </div>
                <div class="stats-home">
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.experience || 0 %></span>
                        <span class="stat-label-home">سنوات</span>
                    </div>
                    <div class="stat-home">
                        <span class="stat-value-home"><%= painter.completedJobs || 0 %></span>
                        <span class="stat-label-home">مشاريع</span>
                    </div>
                </div>
                <div class="rating-home">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= i <= Math.round(painter.rating || 0) ? 'text-warning' : 'text-muted' %>" style="color: <%= i <= Math.round(painter.rating || 0) ? '#FBBF24' : '#E2E8F0' %>;"></i>
                    <% } %>
                    <span style="font-size: 0.7rem; color: var(--text-gray); margin-right: 4px;">(<%= (painter.rating || 0).toFixed(1) %>)</span>
                </div>
                <div class="price-home">
                    <%= painter.pricePerSqm || 0 %> دج/م²
                </div>
                <button class="btn-profile-home" onclick="event.stopPropagation(); window.location.href='/painters/<%= painter._id %>'">
                    عرض الملف الشخصي
                </button>
            </div>
        </div>
        <% }); %>
    </div>
</section>

<!-- CTA Section - Modern Arabic -->
<section class="cta-modern" dir="rtl">
    <div class="cta-container">
        <h2>مستعد لبدء مشروع الدهان الخاص بك؟</h2>
        <p>انضم إلى آلاف العملاء الراضين الذين وجدوا دهّامهم المثالي عبر بينتيلو برو</p>
        <div class="cta-buttons">
            <a href="/auth/register" class="btn-cta-light">
                <i class="fas fa-user-plus"></i> ابدأ كعميل
            </a>
            <a href="/auth/register-painter" class="btn-cta-outline">
                <i class="fas fa-brush"></i> انضم كدهان
            </a>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
