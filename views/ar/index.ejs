    transform: translateY(-2px);
}

/* Responsive */
@media (max-width: 768px) {
    .hero-title {
        font-size: 2rem;
    }
    
    .hero-description {
        font-size: 1rem;
    }
    
    .hero-grid {
        gap: 40px;
        text-align: center;
    }
    
    [dir="rtl"] .hero-grid {
        text-align: center;
    }
    
    .hero-buttons {
        justify-content: center;
    }
    
    .trust-badges {
        justify-content: center;
    }
    
    .section-header h2 {
        font-size: 1.6rem;
    }
    
    .steps-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    
    .painters-grid-home {
        grid-template-columns: 1fr;
    }
    
    .section-header-with-link {
        flex-direction: column;
        text-align: center;
    }
    
    .stats-container {
        gap: 25px;
    }
    
    .stat-number {
        font-size: 1.5rem;
    }
    
    .cta-modern h2 {
        font-size: 1.5rem;
    }
    
    .language-buttons {
        justify-content: center;
    }
    
    [dir="rtl"] .language-buttons {
        justify-content: center;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .painters-grid-home {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.hero-content, .hero-image, .step-card-modern, .painter-card-home {
    animation: fadeInUp 0.6s ease forwards;
}

.step-card-modern:nth-child(1) { animation-delay: 0.1s; }
.step-card-modern:nth-child(2) { animation-delay: 0.2s; }
.step-card-modern:nth-child(3) { animation-delay: 0.3s; }
.step-card-modern:nth-child(4) { animation-delay: 0.4s; }

/* Arabic Font */
@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap');
