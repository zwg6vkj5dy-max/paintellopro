<%- include('../../partials/header', { 
  title: 'جميع المنتجات - بينتيلو برو',
  user: typeof user !== 'undefined' ? user : null,
  sessionPainter: typeof sessionPainter !== 'undefined' ? sessionPainter : null
}) %>

<!-- Products Listing Page -->
<div dir="rtl" class="products-listing-page">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">

    <!-- Page Header -->
    <div class="page-header">
      <h1 class="page-title">جميع المنتجات</h1>
      <p class="page-subtitle">اكتشف مجموعتنا من الدهانات والأدوات الاحترافية</p>
    </div>

    <% if (products && products.length > 0) { %>
    <!-- Products Grid -->
    <div class="products-grid">
      <% products.forEach(product => { %>
      <div class="product-card">
        <a href="/products/<%= product._id %>" class="product-link">
          <!-- Image -->
          <div class="product-image-wrap">
            <img src="<%= (product.images && product.images[0]) ? product.images[0] : (product.image || '/images/default-product.png') %>" 
                 alt="<%= product.name %>" 
                 class="product-image" />
            <!-- Category Badge -->
            <span class="product-category-badge">
              <%= product.category === 'paint' ? 'دهان' : product.category === 'tools' ? 'أدوات' : 'إكسسوارات' %>
            </span>
          </div>

          <!-- Info -->
          <div class="product-info">
            <h3 class="product-name"><%= product.name %></h3>
            <p class="product-description"><%= product.description.substring(0, 80) %>...</p>
            
            <div class="product-footer">
              <span class="product-price"><%= product.price.toLocaleString('ar-DZ') %> دج</span>
              <span class="btn-view-detail">عرض التفاصيل <i class="fas fa-arrow-left"></i></span>
            </div>
          </div>
        </a>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <!-- Empty State -->
    <div class="empty-state">
      <i class="fas fa-box-open fa-4x" style="color: var(--accent-blue); opacity: 0.4;"></i>
      <p class="mt-4 text-muted">لا توجد منتجات متاحة حالياً</p>
      <a href="/ar" class="btn-back-home">العودة للرئيسية</a>
    </div>
    <% } %>

  </div>
</div>

<!-- Styles -->
<style>
  :root {
    --primary-blue: #295797;
    --accent-blue: #1C84C1;
    --primary-dark: #1E3F5C;
    --text-dark: #2D3748;
    --text-gray: #4A5568;
    --bg-light: #E8EEF6;
    --bg-white: #FFFFFF;
    --border-light: #D1DCE6;
    --shadow-sm: 0 2px 8px rgba(41, 87, 151, 0.08);
    --shadow-md: 0 4px 12px rgba(41, 87, 151, 0.12);
    --shadow-lg: 0 8px 24px rgba(41, 87, 151, 0.16);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 12px;
  }

  body {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-light);
  }

  .products-listing-page {
    padding: 60px 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .page-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--primary-blue);
    margin-bottom: 12px;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-gray);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Products Grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px;
  }

  .product-card {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-sm);
  }

  .product-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary-blue);
    box-shadow: var(--shadow-md);
  }

  .product-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .product-image-wrap {
    position: relative;
    height: 220px;
    background: var(--bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    padding: 16px;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-category-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(41, 87, 151, 0.9);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 40px;
    backdrop-filter: blur(4px);
  }

  .product-info {
    padding: 20px;
  }

  .product-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .product-description {
    font-size: 0.85rem;
    color: var(--text-gray);
    margin-bottom: 20px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border-light);
    padding-top: 16px;
    margin-top: auto;
  }

  .product-price {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--primary-blue);
  }

  .btn-view-detail {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary-blue);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
  }

  .product-card:hover .btn-view-detail {
    color: var(--primary-dark);
    gap: 10px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
  }

  .btn-back-home {
    display: inline-block;
    margin-top: 20px;
    background: var(--primary-blue);
    color: white;
    padding: 10px 24px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-back-home:hover {
    background: var(--primary-dark);
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
    }

    .product-image-wrap {
      height: 180px;
    }

    .page-title {
      font-size: 1.8rem;
    }
  }
</style>

<%- include('../../partials/footer') %>
