<%- include('../partials/header', { 
    title: 'Portfolio - Paintello Pro',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-images me-2"></i>My Portfolio
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Instructions for Painters -->
                    <div class="alert alert-info mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-info-circle fa-2x me-3"></i>
                            <div>
                                <h5 class="alert-heading mb-1">How to Add Portfolio Images</h5>
                                <p class="mb-0">
                                    To showcase your work, send your best project photos via WhatsApp. 
                      <%- include('../partials/header', { 
    title: 'المحفظة - بينتيلو برو',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-images me-2"></i>محفظة أعمالي
                    </h4>
                </div>
                <div class="card-body">
                    <!-- إرشادات للدهانين -->
                    <div class="alert alert-info mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-info-circle fa-2x me-3"></i>
                            <div>
                                <h5 class="alert-heading mb-1">كيفية إضافة صور للمحفظة</h5>
                                <p class="mb-0">
                                    لعرض أعمالك، أرسل أفضل صور المشاريع عبر واتساب.
                                    سنقوم برفعها إلى معرضنا المهني وإضافتها إلى محفظتك.
                                </p>
                            </div>
                        </div>
                    </div>

                    <% if (painter.portfolio && painter.portfolio.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">لا توجد عناصر في المحفظة بعد</h4>
                        <p class="text-muted">اتصل بنا عبر واتساب لإضافة صور أعمالك</p>
                        <div class="mt-3">
                            <a href="https://wa.me/1234567890?text=مرحباً! أرغب في إضافة صور إلى محفظتي في بينتيلو برو. معرف الدهان الخاص بي هو: <%= painter._id %>" 
                               class="btn btn-success" target="_blank">
                                <i class="fab fa-whatsapp me-2"></i>الاتصال عبر واتساب
                            </a>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="row">
                        <% painter.portfolio.forEach((project, index) => { %>
                        <div class="col-lg-6 mb-4">
                            <div class="card shadow-sm border-0 card-hover">
                                <% if (project.images && project.images.length > 0) { %>
                                    <% if (project.images.length > 1) { %>
                                        <!-- عرض الشرائح للصور المتعددة -->
                                        <div id="carousel<%= index %>" class="carousel slide" data-bs-ride="carousel">
                                            <div class="carousel-inner rounded-top">
                                                <% project.images.forEach((img, i) => { %>
                                                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                                                    <img src="<%= img.url %>" 
                                                         class="d-block w-100 portfolio-image"
                                                         alt="<%= project.title || 'صورة المشروع' %>"
                                                         style="height: 300px; object-fit: cover;">
                                                </div>
                                                <% }) %>
                                            </div>
                                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">السابق</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">التالي</span>
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <!-- صورة واحدة (بدون عرض شرائح) -->
                                        <div class="portfolio-image-container">
                                            <img src="<%= project.images[0].url %>" 
                                                 class="card-img-top portfolio-image"
                                                 alt="<%= project.title || 'صورة المشروع' %>"
                                                 style="height: 300px; object-fit: cover;">
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <!-- لا توجد صور متاحة -->
                                    <div class="portfolio-image-container text-center bg-light">
                                        <img src="https://via.placeholder.com/600x400/f8f9fa/6c757d?text=لا+توجد+صورة+متاحة" 
                                             class="card-img-top"
                                             style="height: 300px; object-fit: cover;">
                                    </div>
                                <% } %>

                                <div class="card-body">
                                    <h5 class="card-title text-primary mb-2">
                                        <%= project.title || 'مشروع بدون عنوان' %>
                                    </h5>
                                    <p class="card-text text-muted small mb-3">
                                        <%= project.description || 'لا يوجد وصف متاح' %>
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="fas fa-calendar-alt me-1"></i>
                                            <%= project.uploadedAt ? new Date(project.uploadedAt).toLocaleDateString('ar') : 'تاريخ غير معروف' %>
                                        </small>
                                        <div>
                                            <% if (project.category) { %>
                                                <span class="badge bg-secondary me-1">
                                                    <%= project.category === 'interior' ? 'داخلي' :
                                                       project.category === 'exterior' ? 'خارجي' :
                                                       project.category === 'commercial' ? 'تجاري' :
                                                       project.category === 'residential' ? 'سكني' : project.category %>
                                                </span>
                                            <% } %>
                                            <% if (project.uploadedByAdmin) { %>
                                                <span class="badge bg-success">موثوق</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>

                    <!-- إحصائيات المحفظة -->
                    <% if (painter.portfolio && painter.portfolio.length > 0) { %>
                    <div class="row mt-5">
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-primary mb-1"><%= painter.portfolio.length %></h2>
                                    <p class="text-muted mb-0 small">إجمالي المشاريع</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-success mb-1">
                                        <%= painter.portfolio.filter(p => p.uploadedByAdmin).length %>
                                    </h2>
                                    <p class="text-muted mb-0 small">الصور الموثوقة</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-warning mb-1">
                                        <%= painter.portfolio.filter(p => p.category === 'interior').length %>
                                    </h2>
                                    <p class="text-muted mb-0 small">المشاريع الداخلية</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-info mb-1">
                                        <%= new Date().getFullYear() %>
                                    </h2>
                                    <p class="text-muted mb-0 small">السنة الحالية</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- معلومات الاتصال -->
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-question-circle me-2"></i>هل تحتاج المزيد من الصور للمحفظة؟
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-primary">
                                <i class="fab fa-whatsapp me-2"></i>عبر واتساب
                            </h6>
                            <p class="small text-muted mb-3">
                                أرسل أفضل صور أعمالك مع أوصاف المشاريع.
                                سنقوم برفعها مهنياً وإضافتها خلال 24 ساعة.
                            </p>
                            <a href="https://wa.me/1234567890?text=مرحباً! أرغب في إضافة صور للمحفظة. معرف الدهان الخاص بي: <%= painter._id %>" 
                               class="btn btn-success btn-sm" target="_blank">
                                <i class="fab fa-whatsapp me-1"></i>إرسال الصور
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-primary">
                                <i class="fas fa-phone me-2"></i>عبر الهاتف
                            </h6>
                            <p class="small text-muted mb-3">
                                اتصل بنا لمناقشة محفظتك وسنرشدك خلال عملية عرض أعمالك.
                            </p>
                            <a href="tel:+1234567890" class="btn btn-primary btn-sm">
                                <i class="fas fa-phone me-1"></i>اتصل الآن
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.portfolio-image {
    transition: transform 0.3s ease;
}

.card-hover:hover .portfolio-image {
    transform: scale(1.05);
}

.card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
}

.card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.carousel-control-prev,
.carousel-control-next {
    width: 40px;
    height: 40px;
    background: rgba(0,0,0,0.5);
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
    margin: 0 10px;
}

/* تحسينات للغة العربية */
[dir="rtl"] .carousel-control-prev {
    left: auto;
    right: 10px;
}

[dir="rtl"] .carousel-control-next {
    right: auto;
    left: 10px;
}

[dir="rtl"] .me-2 {
    margin-right: 0 !important;
    margin-left: 0.5rem !important;
}

[dir="rtl"] .me-1 {
    margin-right: 0 !important;
    margin-left: 0.25rem !important;
}

[dir="rtl"] .ms-1 {
    margin-left: 0 !important;
    margin-right: 0.25rem !important;
}
</style>

<!-- Bootstrap 5 JavaScript for Carousel -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<%- include('../partials/footer') %>
