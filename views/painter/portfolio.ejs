
<%- include('../partials/header', { 
    title: 'Portfolio - Paintello Pro',
    user: painter, // Pass painter as user for header compatibility
    painter: painter 
}) %>
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-images me-2"></i>My Portfolio
                    </h4>
                    <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#addWorkModal">
                        <i class="fas fa-plus me-1"></i>Add Work
                    </button>
                </div>
                <div class="card-body">
                    <% if (painter.portfolio.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">No portfolio items yet</h4>
                        <p class="text-muted">Showcase your best work to attract more clients</p>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addWorkModal">
                            <i class="fas fa-plus me-1"></i>Add Your First Work
                        </button>
                    </div>
                    <% } else { %>
                    <div class="row">
                        <% painter.portfolio.forEach((work, index) => { %>
                        <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                            <div class="card card-hover">
                                <img src="<%= work.image %>" class="card-img-top" alt="Portfolio work"
                                     style="height: 200px; object-fit: cover;">
                                <div class="card-body">
                                    <p class="card-text small"><%= work.description %></p>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-muted">
                                            <%= new Date(work.createdAt).toLocaleDateString() %>
                                        </small>
                                        <div>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                    onclick="deleteWork('<%= work._id %>')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Work Modal -->
<div class="modal fade" id="addWorkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Portfolio Work</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/painter/portfolio" method="POST" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="workImage" class="form-label">Work Photo *</label>
                        <input type="file" class="form-control" id="workImage" name="workImage" accept="image/*" required>
                        <div class="form-text">Upload a high-quality photo of your work</div>
                    </div>
                    <div class="mb-3">
                        <label for="workDescription" class="form-label">Description *</label>
                        <textarea class="form-control" id="workDescription" name="workDescription" 
                                  rows="3" placeholder="Describe this project..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add to Portfolio</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function deleteWork(workId) {
    if (confirm('Are you sure you want to delete this work from your portfolio?')) {
        fetch(`/painter/portfolio/${workId}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            }
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }
}
</script>

<%- include('../partials/footer') %>
