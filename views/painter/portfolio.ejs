<%- include('../partials/header', { 
    title: 'Portfolio - Paintello Pro',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-images me-2"></i>My Portfolio
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Instructions for Painters -->
                    <div class="alert alert-info mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-info-circle fa-2x me-3"></i>
                            <div>
                                <h5 class="alert-heading mb-1">How to Add Portfolio Images</h5>
                                <p class="mb-0">
                                    To showcase your work, send your best project photos via WhatsApp. 
                                    We'll upload them to our professional gallery and add them to your portfolio.
                                </p>
                            </div>
                        </div>
                    </div>

                    <% if (painter.portfolio && painter.portfolio.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">No portfolio items yet</h4>
                        <p class="text-muted">Contact us via WhatsApp to add your work photos</p>
                        <div class="mt-3">
                            <a href="https://wa.me/1234567890?text=Hello! I'd like to add photos to my Paintello Pro portfolio. My painter ID is: <%= painter._id %>" 
                               class="btn btn-success" target="_blank">
                                <i class="fab fa-whatsapp me-2"></i>Contact via WhatsApp
                            </a>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="row">
                        <% painter.portfolio.forEach((project, index) => { %>
                        <div class="col-lg-6 mb-4">
                            <div class="card shadow-sm border-0 card-hover">
                                <% if (project.images && project.images.length > 0) { %>
                                    <% if (project.images.length > 1) { %>
                                        <!-- Carousel for multiple images -->
                                        <div id="carousel<%= index %>" class="carousel slide" data-bs-ride="carousel">
                                            <div class="carousel-inner rounded-top">
                                                <% project.images.forEach((img, i) => { %>
                                                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                                                    <img src="<%= img.url %>" 
                                                         class="d-block w-100 portfolio-image"
                                                         alt="<%= project.title || 'Project Image' %>"
                                                         style="height: 300px; object-fit: cover;">
                                                </div>
                                                <% }) %>
                                            </div>
                                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="prev">
                                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Previous</span>
                                            </button>
                                            <button class="carousel-control-next" type="button" data-bs-target="#carousel<%= index %>" data-bs-slide="next">
                                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                                <span class="visually-hidden">Next</span>
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <!-- Single image (no carousel) -->
                                        <div class="portfolio-image-container">
                                            <img src="<%= project.images[0].url %>" 
                                                 class="card-img-top portfolio-image"
                                                 alt="<%= project.title || 'Project Image' %>"
                                                 style="height: 300px; object-fit: cover;">
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <!-- No images available -->
                                    <div class="portfolio-image-container text-center bg-light">
                                        <img src="https://via.placeholder.com/600x400/f8f9fa/6c757d?text=No+Image+Available" 
                                             class="card-img-top"
                                             style="height: 300px; object-fit: cover;">
                                    </div>
                                <% } %>

                                <div class="card-body">
                                    <h5 class="card-title text-primary mb-2">
                                        <%= project.title || 'Untitled Project' %>
                                    </h5>
                                    <p class="card-text text-muted small mb-3">
                                        <%= project.description || 'No description available' %>
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="fas fa-calendar-alt me-1"></i>
                                            <%= project.uploadedAt ? new Date(project.uploadedAt).toLocaleDateString() : 'Unknown date' %>
                                        </small>
                                        <div>
                                            <% if (project.category) { %>
                                                <span class="badge bg-secondary me-1"><%= project.category %></span>
                                            <% } %>
                                            <% if (project.uploadedByAdmin) { %>
                                                <span class="badge bg-success">Verified</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>

                    <!-- Portfolio Statistics -->
                    <% if (painter.portfolio && painter.portfolio.length > 0) { %>
                    <div class="row mt-5">
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-primary mb-1"><%= painter.portfolio.length %></h2>
                                    <p class="text-muted mb-0 small">Total Projects</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-success mb-1">
                                        <%= painter.portfolio.filter(p => p.uploadedByAdmin).length %>
                                    </h2>
                                    <p class="text-muted mb-0 small">Verified Photos</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-warning mb-1">
                                        <%= painter.portfolio.filter(p => p.category === 'interior').length %>
                                    </h2>
                                    <p class="text-muted mb-0 small">Interior Projects</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="card text-center border-0 shadow-sm">
                                <div class="card-body py-4">
                                    <h2 class="text-info mb-1">
                                        <%= new Date().getFullYear() %>
                                    </h2>
                                    <p class="text-muted mb-0 small">Current Year</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Contact Information -->
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-question-circle me-2"></i>Need More Portfolio Photos?
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-primary">
                                <i class="fab fa-whatsapp me-2"></i>Via WhatsApp
                            </h6>
                            <p class="small text-muted mb-3">
                                Send your best work photos with project descriptions. 
                                We'll professionally upload and add them within 24 hours.
                            </p>
                            <a href="https://wa.me/1234567890?text=Hello! I'd like to add portfolio photos. My Painter ID: <%= painter._id %>" 
                               class="btn btn-success btn-sm" target="_blank">
                                <i class="fab fa-whatsapp me-1"></i>Send Photos
                            </a>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-primary">
                                <i class="fas fa-phone me-2"></i>Via Phone
                            </h6>
                            <p class="small text-muted mb-3">
                                Call us to discuss your portfolio and we'll guide you 
                                through the process of showcasing your work.
                            </p>
                            <a href="tel:+1234567890" class="btn btn-primary btn-sm">
                                <i class="fas fa-phone me-1"></i>Call Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.portfolio-image {
    transition: transform 0.3s ease;
}

.card-hover:hover .portfolio-image {
    transform: scale(1.05);
}

.card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
}

.card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.carousel-control-prev,
.carousel-control-next {
    width: 40px;
    height: 40px;
    background: rgba(0,0,0,0.5);
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
    margin: 0 10px;
}
</style>

<!-- Bootstrap 5 JavaScript for Carousel -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<%- include('../partials/footer') %>
