<%- include('../partials/header', { 
    title: 'Painter Dashboard - Paintello Pro',
    user: painter, // Pass painter as user for header compatibility
    painter: painter 
}) %>

<div class="container-fluid py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-lg-3 col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                 <div class="avatar-placeholder bg-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center"
     style="width: 80px; height: 80px; overflow: hidden;">
    <% if (painter.profilePicture && painter.profilePicture.url && painter.profilePicture.url.startsWith('http')) { %>
        <img src="<%= painter.profilePicture.url %>" 
             alt="<%= painter.name %>" 
             style="width: 100%; height: 100%; object-fit: cover;"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
        <div class="avatar-fallback" style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center; background: #007bff;">
            <i class="fas fa-brush fa-2x text-white"></i>
        </div>
    <% } else { %>
        <i class="fas fa-brush fa-2x text-white"></i>
    <% } %>
</div>
<!-- Availability Status -->
<div class="card shadow-sm mt-4 border-info">
    <div class="card-header bg-info text-white">
        <h6 class="mb-0"><i class="fas fa-calendar-check me-2"></i>Availability Status</h6>
    </div>
    <div class="card-body text-center">
        <% if (painter.availability === 'available') { %>
            <span class="badge bg-success fs-6 p-2 mb-2">
                <i class="fas fa-check-circle me-1"></i>Available
            </span>
            <p class="small mb-2 text-muted">Ready for new projects</p>
        <% } else if (painter.availability === 'busy') { %>
            <span class="badge bg-warning fs-6 p-2 mb-2">
                <i class="fas fa-clock me-1"></i>Busy
            </span>
            <p class="small mb-2 text-muted">Limited availability</p>
        <% } else { %>
            <span class="badge bg-danger fs-6 p-2 mb-2">
                <i class="fas fa-times-circle me-1"></i>Unavailable
            </span>
            <p class="small mb-2 text-muted">Not taking new work</p>
        <% } %>
        
        <% if (painter.availableFrom && painter.availability === 'unavailable') { %>
            <p class="small text-muted mb-1">
                <i class="fas fa-calendar me-1"></i>
                Available from: <%= new Date(painter.availableFrom).toLocaleDateString() %>
            </p>
        <% } %>
        
        <a href="/painter/availability" class="btn btn-outline-info btn-sm">
            <i class="fas fa-edit me-1"></i>Manage
        </a>
    </div>
</div>
                    <h5 class="card-title"><%= painter.name %></h5>
                    <p class="text-muted small">Professional Painter</p>
                    <% if (painter.verification.status === 'verified') { %>
                    <span class="badge bg-success mb-3">
                        <i class="fas fa-check-circle me-1"></i>Verified Pro
                    </span>
                    <% } else if (painter.verification.status === 'pending') { %>
                    <span class="badge bg-warning mb-3">
                        <i class="fas fa-clock me-1"></i>Pending Verification
                    </span>
                    <% } else { %>
                    <span class="badge bg-danger mb-3">
                        <i class="fas fa-times-circle me-1"></i>Verification Rejected
                    </span>
                    <% } %>
                    <div class="d-grid gap-2">
                        <a href="/painter/profile" class="btn btn-outline-primary">
                            <i class="fas fa-user-edit me-2"></i>Edit Profile
                        </a>
                        <a href="/painter/store" class="btn btn-primary">
                            <i class="fas fa-store me-2"></i>Team Store
                        </a>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Business Overview</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Total Jobs</span>
                        <span class="fw-bold text-primary"><%= stats.totalJobs || 0 %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Active Jobs</span>
                        <span class="fw-bold text-warning"><%= stats.activeJobs || 0 %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Completed</span>
                        <span class="fw-bold text-success"><%= stats.completedJobs || 0 %></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Total Earnings</span>
                        <span class="fw-bold text-success"><%= stats.totalEarnings || 0 %> DZD</span>
                    </div>
                </div>

            </div>

            <!-- Store Points -->
            <div class="card shadow-sm mt-4 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="fas fa-award me-2"></i>Loyalty Points</h6>
                </div>
                <div class="card-body text-center">
                    <h3 class="text-warning"><%= painter.loyaltyPoints || 0 %></h3>
                    <p class="small mb-2">Points Available</p>
                    <a href="/painter/store/loyalty" class="btn btn-outline-warning btn-sm">Redeem</a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9 col-md-8">
            <!-- Welcome Banner -->
            <div class="alert alert-info border-0 mb-4">
                <div class="d-flex align-items-center">
                    <i class="fas fa-info-circle fa-2x me-3"></i>
                    <div>
                        <h5 class="alert-heading mb-1">
                            Welcome to Paintello Pro, <%= painter.name %>!
                        </h5>
                        <p class="mb-0">Manage your painting business, accept new jobs, and grow your reputation.</p>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="row mb-4">
                <div class="col-xl-3 col-md-6 mb-3">
                    <div class="card card-hover border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-clipboard-list fa-2x text-primary"></i>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h4 class="mb-0"><%= stats.pendingJobs || 0 %></h4>
                                    <span class="text-muted">Pending Jobs</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6 mb-3">
                    <div class="card card-hover border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-paint-roller fa-2x text-warning"></i>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h4 class="mb-0"><%= stats.inProgressJobs || 0 %></h4>
                                    <span class="text-muted">In Progress</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6 mb-3">
                    <div class="card card-hover border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-star fa-2x text-success"></i>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h4 class="mb-0"><%= (painter.rating || 0).toFixed(1) %></h4>
                                    <span class="text-muted">Your Rating</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6 mb-3">
                    <div class="card card-hover border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-wallet fa-2x text-info"></i>
                                </div>
                                <div class="flex-grow-1 ms-3">
                                    <h4 class="mb-0"><%= stats.monthlyEarnings || 0 %> DZD</h4>
                                    <span class="text-muted">This Month</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Jobs & Quick Actions -->
            <div class="row">
                <!-- Recent Jobs -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Recent Job Requests</h5>
                            <a href="/painter/orders" class="btn btn-sm btn-outline-primary">View All</a>
                        </div>
                        <div class="card-body">
                            <% if (recentJobs.length === 0) { %>
                            <div class="text-center py-4">
                                <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No job requests yet</h5>
                                <p class="text-muted">Your profile will be shown to clients in your area</p>
                            </div>
                            <% } else { %>
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Client</th>
                                            <th>Service</th>
                                            <th>Location</th>
                                            <th>Budget</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% recentJobs.forEach(job => { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-placeholder bg-secondary rounded-circle me-2 d-flex align-items-center justify-content-center"
                                                         style="width: 30px; height: 30px;">
                                                        <i class="fas fa-user text-white small"></i>
                                                    </div>
                                                    <%= job.client.name %>
                                                </div>
                                            </td>
                                            <td><%= job.serviceType %></td>
                                            <td>
                                                <small><%= job.wilaya %></small>
                                            </td>
                                            <td><%= job.budget %> DZD</td>
                                            <td>
                                                <span class="badge bg-<%= 
                                                    job.status === 'completed' ? 'success' :
                                                    job.status === 'in_progress' ? 'primary' :
                                                    job.status === 'accepted' ? 'info' :
                                                    job.status === 'pending' ? 'warning' : 'secondary'
                                                %>">
                                                    <%= job.status.replace('_', ' ').toUpperCase() %>
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/painter/orders/<%= job._id %>" class="btn btn-sm btn-outline-primary">View</a>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                        </div>
                    </div>
      
<!-- Portfolio Showcase -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-images me-2"></i>My Portfolio Showcase
                </h5>
                <a href="/painter/portfolio" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <% if (painter.portfolio && painter.portfolio.length > 0) { %>
                    <div class="row">
                        <% 
                        // Show only the first 4 portfolio items on dashboard
                        const showcasePortfolio = painter.portfolio.slice(0, 4);
                        %>
                        <% showcasePortfolio.forEach((work, index) => { %>
                        <div class="col-xl-3 col-lg-3 col-md-6 mb-3">
                            <div class="card portfolio-card h-100">
                                <div class="portfolio-image-container" 
                                     style="height: 150px; overflow: hidden; background: #f8f9fa;">
                                    <img src="<%= work.flickrUrl %>" 
                                         class="card-img-top" 
                                         alt="Portfolio work"
                                         style="width: 100%; height: 100%; object-fit: cover;"
                                         onerror="this.src='https://via.placeholder.com/300x150/f8f9fa/6c757d?text=Image+Loading'">
                                </div>
                                <div class="card-body p-3">
                                    <% if (work.description) { %>
                                    <p class="card-text small text-muted mb-1" 
                                       style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        <%= work.description %>
                                    </p>
                                    <% } %>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            <i class="fas fa-tag me-1"></i><%= work.category %>
                                        </small>
                                        <% if (work.uploadedByAdmin) { %>
                                        <i class="fas fa-check-circle text-success" title="Verified by Admin"></i>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    </div>
                    <!-- Portfolio Stats -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="badge bg-primary">
                                        <i class="fas fa-images me-1"></i>
                                        <%= painter.portfolio.length %> Total Projects
                                    </span>
                                    <span class="badge bg-success ms-2">
                                        <i class="fas fa-check-circle me-1"></i>
                                        <%= painter.portfolio.filter(p => p.uploadedByAdmin).length %> Verified
                                    </span>
                                </div>
                                <div>
                                    <a href="/painter/portfolio" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i>View Full Portfolio
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                <% } else { %>
                    <div class="text-center py-4">
                        <i class="fas fa-images fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No portfolio items yet</h5>
                        <p class="text-muted mb-3">Showcase your work to attract more clients</p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="https://wa.me/1234567890?text=Hello! I'd like to add photos to my Paintello Pro portfolio. My painter ID is: <%= painter._id %>" 
                               class="btn btn-success btn-sm" target="_blank">
                                <i class="fab fa-whatsapp me-1"></i>Add Photos via WhatsApp
                            </a>
                            <a href="/painter/portfolio" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-info-circle me-1"></i>Learn More
                            </a>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
<!-- Quick Actions -->
                <div class="col-lg-4 mb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Quick Actions</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-3">
                                <a href="/painter/profile" class="btn btn-outline-primary text-start">
                                    <i class="fas fa-user-edit me-2"></i>Update Profile
                                </a>
                                <a href="/painter/portfolio" class="btn btn-outline-primary text-start">
                                    <i class="fas fa-images me-2"></i>Manage Portfolio
                                </a>
                                <a href="/painter/store" class="btn btn-outline-warning text-start">
                                    <i class="fas fa-store me-2"></i>Team Store
                                </a>
                                <a href="/painter/availability" class="btn btn-outline-success text-start">
                                    <i class="fas fa-calendar-check me-2"></i>Set Availability
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Performance Metrics -->
                    <div class="card shadow-sm mt-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Performance</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Response Rate</small>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-success" style="width: <%= stats.responseRate || 0 %>%"></div>
                                </div>
                                <small class="text-muted"><%= stats.responseRate || 0 %>%</small>
                            </div>
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Completion Rate</small>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-primary" style="width: <%= stats.completionRate || 0 %>%"></div>
                                </div>
                                <small class="text-muted"><%= stats.completionRate || 0 %>%</small>
                            </div>
                            <div>
                                <small class="text-muted d-block mb-1">Client Satisfaction</small>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-warning" style="width: <%= ((painter.rating || 0) / 5 * 100) %>%"></div>
                                </div>
                                <small class="text-muted"><%= (painter.rating || 0).toFixed(1) %>/5.0</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
