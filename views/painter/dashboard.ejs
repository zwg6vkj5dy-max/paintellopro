<%- include('../partials/header', { 
    title: 'لوحة التحكم - بينتيلو برو',
    user: painter,
    painter: painter 
}) %>

<style>
  :root {
    --primary-blue: #295797;
    --accent-blue: #1C84C1;
    --primary-dark: #1E3F5C;
    --text-dark: #262626;
    --text-gray: #8e8e8e;
    --bg-light: #fafafa;
    --bg-white: #ffffff;
    --border-light: #dbdbdb;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
    --radius-lg: 16px;
    --radius-md: 12px;
    --radius-sm: 8px;
  }
  body {
    background-color: var(--bg-light);
    font-family: 'Tajawal', 'Cairo', sans-serif;
    margin: 0;
    direction: rtl;
  }
  .dashboard-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 30px 20px;
  }

  /* Grid layout: sidebar + main */
  .dashboard-grid {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .sidebar {
    width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  /* Card style */
  .card {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-dark);
    background: white;
  }
  .card-header i { color: var(--primary-blue); }
  .card-body { padding: 20px; }

  /* Sidebar profile */
  .sidebar-profile {
    text-align: center;
    padding: 24px 20px;
  }
  .avatar-wrapper {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    margin: 0 auto 16px;
    background: var(--primary-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .avatar-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .painter-name {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text-dark);
    margin-bottom: 4px;
  }
  .painter-role {
    font-size: 0.9rem;
    color: var(--text-gray);
    margin-bottom: 12px;
  }
  .verification-badge {
    display: inline-block;
    background: rgba(41,87,151,0.1);
    color: var(--primary-blue);
    padding: 2px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Quick stats sidebar */
  .quick-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .quick-stat:last-child { border-bottom: none; }
  .quick-stat .label { font-size: 0.9rem; color: var(--text-gray); }
  .quick-stat .value { font-weight: 700; color: var(--text-dark); }
  .loyalty-points { font-size: 2rem; font-weight: 800; color: var(--primary-blue); }

  /* Welcome banner */
  .welcome-banner {
    background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    color: white;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .welcome-banner i { font-size: 2.4rem; opacity: 0.8; }
  .welcome-banner h2 { margin: 0; font-size: 1.5rem; font-weight: 700; }
  .welcome-banner p { margin: 4px 0 0; opacity: 0.9; }

  /* Stats row */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 16px;
  }
  .stat-box {
    background: white;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: rgba(41,87,151,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-blue);
    font-size: 1.3rem;
  }
  .stat-info h4 { margin: 0 0 2px; font-size: 1.3rem; color: var(--text-dark); }
  .stat-info span { font-size: 0.8rem; color: var(--text-gray); }

  /* Two columns for main area */
  .main-two-col {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .col-left {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .col-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Table style */
  .jobs-table {
    width: 100%;
    border-collapse: collapse;
  }
  .jobs-table th {
    text-align: right;
    padding: 10px 12px;
    border-bottom: 2px solid var(--border-light);
    color: var(--text-gray);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .jobs-table td {
    padding: 12px;
    border-bottom: 1px solid var(--border-light);
    font-size: 0.9rem;
  }
  .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .status-pending { background: #fff3cd; color: #856404; }
  .status-accepted { background: #d1ecf1; color: #0c5460; }
  .status-in_progress { background: #d6e4f0; color: #1E3F5C; }
  .status-completed { background: #d4edda; color: #155724; }

  /* Store product grid (2 per row) */
  .store-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .store-card {
    background: white;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
  }
  .store-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .store-card-img {
    aspect-ratio: 1 / 1;
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-light);
  }
  .store-card-img img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.3s;
  }
  .store-card:hover .store-card-img img {
    transform: scale(1.05);
  }
  .store-card-body {
    padding: 12px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .store-card-body h5 {
    font-weight: 600;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .store-price {
    font-weight: 700;
    color: var(--primary-blue);
  }

  /* Actions list */
  .action-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    color: var(--text-dark);
    text-decoration: none;
    transition: background 0.2s;
    margin-bottom: 4px;
  }
  .action-links a:hover {
    background: rgba(41,87,151,0.05);
    color: var(--primary-blue);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .dashboard-grid {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
    }
    .main-two-col {
      flex-direction: column;
    }
    .store-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 500px) {
    .store-grid {
      grid-template-columns: 1fr;
    }
    .stats-row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<div class="dashboard-wrapper">
  <div class="dashboard-grid">
    
    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar">
      <!-- Profile card -->
      <div class="card sidebar-profile">
        <div class="avatar-wrapper">
          <% if (painter.profilePicture && painter.profilePicture.url) { %>
            <img src="<%= painter.profilePicture.url %>" alt="<%= painter.name %>">
          <% } else { %>
            <i class="fas fa-brush fa-2x text-white"></i>
          <% } %>
        </div>
        <h3 class="painter-name"><%= painter.name %></h3>
        <div class="painter-role">دهان محترف</div>
        <% if (painter.verification && painter.verification.status === 'verified') { %>
          <span class="verification-badge"><i class="fas fa-check-circle"></i> موثوق</span>
        <% } else if (painter.verification && painter.verification.status === 'pending') { %>
          <span class="verification-badge" style="background: #fff3cd; color: #856404;"><i class="fas fa-clock"></i> في الانتظار</span>
        <% } else { %>
          <span class="verification-badge" style="background: #fdecea; color: #a71d2a;"><i class="fas fa-times-circle"></i> غير موثق</span>
        <% } %>
      </div>

      <!-- Quick stats -->
      <div class="card">
        <div class="card-header"><i class="fas fa-chart-bar"></i> إحصائيات سريعة</div>
        <div class="card-body" style="padding: 12px 20px;">
          <div class="quick-stat"><span class="label">مهام معلقة</span><span class="value"><%= stats.pendingJobs || 0 %></span></div>
          <div class="quick-stat"><span class="label">قيد التنفيذ</span><span class="value"><%= stats.inProgressJobs || 0 %></span></div>
          <div class="quick-stat"><span class="label">مكتملة</span><span class="value"><%= stats.completedJobs || 0 %></span></div>
          <div class="quick-stat"><span class="label">الأرباح (بعد العمولة)</span><span class="value"><%= stats.totalEarnings || 0 %> دج</span></div>
        </div>
      </div>

      <!-- Loyalty points -->
      <div class="card">
        <div class="card-header"><i class="fas fa-award"></i> نقاط الولاء</div>
        <div class="card-body text-center">
          <div class="loyalty-points"><%= painter.loyaltyPoints || 0 %></div>
          <small class="text-muted">نقطة متاحة</small>
        </div>
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">
      <!-- Welcome banner -->
      <div class="welcome-banner">
        <i class="fas fa-paint-roller"></i>
        <div>
          <h2>مرحباً بك، <%= painter.name %>!</h2>
          <p>إدارة أعمالك، قبول الطلبات، وتطوير سمعتك.</p>
        </div>
      </div>

      <!-- Stats cards -->
      <div class="stats-row">
        <div class="stat-box">
          <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
          <div class="stat-info"><h4><%= stats.pendingJobs || 0 %></h4><span>مهام معلقة</span></div>
        </div>
        <div class="stat-box">
          <div class="stat-icon"><i class="fas fa-spinner"></i></div>
          <div class="stat-info"><h4><%= stats.inProgressJobs || 0 %></h4><span>قيد التنفيذ</span></div>
        </div>
        <div class="stat-box">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info"><h4><%= stats.completedJobs || 0 %></h4><span>مكتملة</span></div>
        </div>
        <div class="stat-box">
          <div class="stat-icon"><i class="fas fa-star"></i></div>
          <div class="stat-info"><h4><%= (painter.rating || 0).toFixed(1) %></h4><span>تقييمك</span></div>
        </div>
        <div class="stat-box">
          <div class="stat-icon"><i class="fas fa-wallet"></i></div>
          <div class="stat-info"><h4><%= stats.totalEarnings || 0 %> دج</h4><span>أرباحك</span></div>
        </div>
      </div>

      <!-- Two-column area: jobs + store / right actions -->
      <div class="main-two-col">
        <div class="col-left">
          <!-- Recent jobs -->
          <div class="card">
            <div class="card-header justify-content-between">
              <span><i class="fas fa-briefcase"></i> طلبات العمل الحديثة</span>
              <a href="/painter/orders" class="btn btn-sm" style="background: var(--primary-blue); color: white; border-radius: 20px; padding: 4px 16px; text-decoration: none;">عرض الكل</a>
            </div>
            <div class="card-body" style="padding: 0;">
              <% if (recentJobs.length === 0) { %>
                <div class="text-center py-5">
                  <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                  <p class="text-muted">لا توجد طلبات حتى الآن</p>
                </div>
              <% } else { %>
                <table class="jobs-table">
                  <thead>
                    <tr>
                      <th>العميل</th>
                      <th>الخدمة</th>
                      <th>المبلغ</th>
                      <th>الحالة</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentJobs.forEach(job => { %>
                    <tr>
                      <td><strong><%= job.client.name %></strong></td>
                      <td><%= job.serviceType %></td>
                      <td><%= job.budget %> دج</td>
                      <td><span class="status-badge status-<%= job.status %>"><%= job.status === 'pending' ? 'معلق' : job.status === 'accepted' ? 'مقبول' : job.status === 'in_progress' ? 'قيد التنفيذ' : 'مكتمل' %></span></td>
                      <td>
                        <% if (job.status === 'pending') { %>
                          <form action="/painter/orders/<%= job._id %>/accept" method="POST" style="display:inline;">
                            <button class="btn btn-sm" style="background: #28a745; color: white; border-radius: 50px; padding: 4px 12px;">قبول</button>
                          </form>
                        <% } %>
                      </td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              <% } %>
            </div>
          </div>

          <!-- Store products (2 per row) -->
          <div class="card">
            <div class="card-header justify-content-between">
              <span><i class="fas fa-store"></i> المتجر – مستلزمات الدهان</span>
              <a href="/painter/store" class="btn btn-sm" style="background: var(--primary-blue); color: white; border-radius: 20px; padding: 4px 16px; text-decoration: none;">عرض الكل</a>
            </div>
            <div class="card-body">
              <% if (storeProducts && storeProducts.length > 0) { %>
                <div class="store-grid">
                  <% storeProducts.forEach(product => { %>
                    <a href="/painter/store-products/<%= product._id %>" class="store-card">
                      <div class="store-card-img">
                        <img src="<%= (product.images && product.images[0]) ? product.images[0] : (product.image || '/img/placeholder-product.png') %>" alt="<%= product.name %>">
                      </div>
                      <div class="store-card-body">
                        <h5><%= product.name %></h5>
                        <span class="store-price"><%= product.price.toLocaleString('ar-DZ') %> دج</span>
                      </div>
                    </a>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="text-center py-4">
                  <i class="fas fa-box-open fa-2x text-muted mb-2"></i>
                  <p class="text-muted">لا توجد منتجات متاحة حالياً</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Right column: Quick actions & Performance -->
        <div class="col-right">
          <div class="card">
            <div class="card-header"><i class="fas fa-bolt"></i> إجراءات سريعة</div>
            <div class="card-body action-links">
              <a href="/painter/profile"><i class="fas fa-user-edit"></i> تعديل الملف الشخصي</a>
              <a href="/painter/availability"><i class="fas fa-calendar-check"></i> إدارة التوفر</a>
              <a href="/painter/orders"><i class="fas fa-list-alt"></i> جميع الطلبات</a>
              <a href="/painter/store"><i class="fas fa-shopping-cart"></i> المتجر</a>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><i class="fas fa-chart-line"></i> الأداء</div>
            <div class="card-body">
              <div class="mb-2"><small>معدل الإكمال</small>
                <div class="progress" style="height: 6px; background: #e9ecef; border-radius: 3px;">
                  <div class="progress-bar" style="width: <%= stats.completionRate || 0 %>%; background: var(--primary-blue); border-radius: 3px;"></div>
                </div>
                <small><%= stats.completionRate || 0 %>%</small>
              </div>
              <div>
                <small>رضا العملاء</small>
                <div class="progress" style="height: 6px; background: #e9ecef; border-radius: 3px;">
                  <div class="progress-bar" style="width: <%= ((painter.rating || 0) / 5 * 100) %>%; background: #ffc107; border-radius: 3px;"></div>
                </div>
                <small><%= (painter.rating || 0).toFixed(1) %> / 5</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<%- include('../partials/footer') %>
