

<%- include('../partials/header', { title: 'لإدارة التوفر - بينتيلو برو',
    user: painter,
    painter: painter , isAndroidApp: typeof isAndroidApp !== 'undefined' ? isAndroidApp : false }) %>

<style>
  :root {
    --primary-blue: #295797;
    --accent-blue: #1C84C1;
    --primary-dark: #1E3F5C;
    --text-dark: #2D3748;
    --text-gray: #4A5568;
    --bg-light: #F7FAFC;
    --bg-white: #FFFFFF;
    --border-light: #E2E8F0;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.05), 0 1px 2px rgba(0,0,0,0.03);
    --shadow-md: 0 4px 12px rgba(41,87,151,0.12);
    --shadow-lg: 0 8px 24px rgba(41,87,151,0.16);
    --radius-lg: 16px;
    --radius-md: 12px;
    --radius-sm: 8px;
  }

  body {
    background-color: var(--bg-light);
    font-family: 'Tajawal', 'Cairo', sans-serif;
  }

  .page-header {
    background: linear-gradient(135deg, var(--primary-blue), var(--accent-blue));
    border-radius: var(--radius-lg);
    padding: 24px 30px;
    color: white;
    margin-bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: var(--shadow-md);
  }
  .page-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0;
  }
  .btn-back {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }
  .btn-back:hover {
    background: rgba(255,255,255,0.25);
    color: white;
  }

  .card-modern {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    height: 100%;
  }
  .card-modern .card-header {
    padding: 16px 24px;
    font-weight: 700;
    font-size: 1.1rem;
    border-bottom: 1px solid var(--border-light);
  }
  .card-modern .card-body {
    padding: 24px;
  }

  .badge-status {
    font-size: 1.1rem;
    padding: 10px 24px;
    border-radius: 50px;
    font-weight: 600;
  }
  .badge-available {
    background: #e9f7ef;
    color: #1e7e34;
    border: 1px solid #b7dfc3;
  }
  .badge-busy {
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffeeba;
  }
  .badge-unavailable {
    background: #fdecea;
    color: #a71d2a;
    border: 1px solid #f5c6cb;
  }

  .form-control, .form-select {
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    padding: 10px 16px;
    background: #fafafa;
    transition: all 0.2s;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(41,87,151,0.1);
    background: white;
  }

  .btn-primary-custom {
    background: var(--primary-blue);
    color: white;
    border: none;
    padding: 10px 24px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    transition: all 0.2s;
  }
  .btn-primary-custom:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  .btn-outline-warning-custom {
    border: 1px solid #f0ad4e;
    color: #f0ad4e;
    background: white;
    padding: 10px 24px;
    border-radius: var(--radius-sm);
    font-weight: 600;
  }
  .btn-outline-warning-custom:hover {
    background: #f0ad4e;
    color: white;
  }

  .list-group-item {
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm) !important;
    margin-bottom: 8px;
    padding: 16px;
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary-blue);
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 10px;
    margin-bottom: 20px;
  }

  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

<div class="container py-4">
  
  <!-- Header -->
  <div class="page-header">
    <h1><i class="fas fa-calendar-check me-2"></i>إدارة التوفر</h1>
    <a href="/painter/dashboard" class="btn-back">
      <i class="fas fa-arrow-left me-2"></i>العودة للوحة التحكم
    </a>
  </div>

  <!-- Alerts -->
  <% if (success) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>
  <% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>

  <div class="row">
    <!-- Current Status Card -->
    <div class="col-lg-4 mb-4">
      <div class="card-modern">
        <div class="card-header" style="background: var(--primary-blue); color: white;">
          <i class="fas fa-user-clock me-2"></i>الحالة الحالية
        </div>
        <div class="card-body text-center">
          <div class="mb-4">
            <% if (painter.availability === 'available') { %>
              <span class="badge-status badge-available">
                <i class="fas fa-check-circle me-2"></i>متاح
              </span>
            <% } else if (painter.availability === 'busy') { %>
              <span class="badge-status badge-busy">
                <i class="fas fa-clock me-2"></i>مشغول
              </span>
            <% } else { %>
              <span class="badge-status badge-unavailable">
                <i class="fas fa-times-circle me-2"></i>غير متاح
              </span>
            <% } %>
          </div>
          <p class="text-muted">
            <% if (painter.availability === 'available') { %>
              يمكن للعملاء رؤيتك في نتائج البحث وإرسال طلبات العمل.
            <% } else if (painter.availability === 'busy') { %>
              أنت مرئي ولكن قد يكون لديك توفر محدود.
            <% } else { %>
              أنت مخفي من نتائج البحث.
            <% } %>
          </p>
        </div>
      </div>
    </div>

    <!-- Quick Status Update -->
    <div class="col-lg-8 mb-4">
      <div class="card-modern">
        <div class="card-header" style="background: var(--bg-light); color: var(--text-dark);">
          <i class="fas fa-sync-alt me-2"></i>تحديث الحالة
        </div>
        <div class="card-body">
          <form action="/painter/availability/status" method="POST">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="status" class="form-label fw-bold">حالة التوفر *</label>
                <select class="form-select" id="status" name="status" required>
                  <option value="available" <%= painter.availability === 'available' ? 'selected' : '' %>>متاح للمشاريع الجديدة</option>
                  <option value="busy" <%= painter.availability === 'busy' ? 'selected' : '' %>>مشغول (توفر محدود)</option>
                  <option value="unavailable" <%= painter.availability === 'unavailable' ? 'selected' : '' %>>غير متاح</option>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label for="reason" class="form-label fw-bold">السبب (اختياري)</label>
                <input type="text" class="form-control" id="reason" name="reason" 
                       placeholder="مثال: إجازة، جدول ممتلئ...">
              </div>
            </div>
            <div class="row" id="unavailableFields" style="display: none;">
              <div class="col-12 mb-3">
                <label for="availableFrom" class="form-label fw-bold">متاح من تاريخ</label>
                <input type="date" class="form-control" id="availableFrom" name="availableFrom"
                       min="<%= new Date().toISOString().split('T')[0] %>">
                <div class="form-text">متى ستكون متاحاً مرة أخرى؟</div>
              </div>
            </div>
            <button type="submit" class="btn-primary-custom">
              <i class="fas fa-save me-2"></i>تحديث الحالة
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Job Overview -->
  <div class="row">
    <div class="col-lg-6 mb-4">
      <div class="card-modern">
        <div class="card-header" style="background: #1C84C1; color: white;">
          <i class="fas fa-paint-roller me-2"></i>المهام الحالية
          <span class="badge bg-light text-dark ms-2"><%= currentJobs.length %></span>
        </div>
        <div class="card-body">
          <% if (currentJobs.length === 0) { %>
            <div class="text-center py-4">
              <i class="fas fa-clipboard-list fa-2x text-muted mb-3"></i>
              <p class="text-muted">لا توجد مهام نشطة</p>
            </div>
          <% } else { %>
            <div class="list-group list-group-flush">
              <% currentJobs.forEach(job => { %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <h6 class="mb-1 fw-bold"><%= job.serviceType %></h6>
                  <small class="text-muted"><%= job.client.name %></small>
                </div>
                <span class="badge bg-primary rounded-pill">
                  <%= job.status === 'completed' ? 'مكتمل' :
                     job.status === 'in_progress' ? 'قيد التنفيذ' :
                     job.status === 'accepted' ? 'مقبول' :
                     job.status === 'pending' ? 'معلق' : job.status %>
                </span>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-6 mb-4">
      <div class="card-modern">
        <div class="card-header" style="background: #f0ad4e; color: white;">
          <i class="fas fa-calendar me-2"></i>المهام القادمة
          <span class="badge bg-light text-dark ms-2"><%= upcomingJobs.length %></span>
        </div>
        <div class="card-body">
          <% if (upcomingJobs.length === 0) { %>
            <div class="text-center py-4">
              <i class="fas fa-calendar-times fa-2x text-muted mb-3"></i>
              <p class="text-muted">لا توجد مهام قادمة</p>
            </div>
          <% } else { %>
            <div class="list-group list-group-flush">
              <% upcomingJobs.forEach(job => { %>
              <div class="list-group-item">
                <h6 class="mb-1 fw-bold"><%= job.serviceType %></h6>
                <small class="text-muted">
                  <i class="fas fa-user me-1"></i><%= job.client.name %><br>
                  <i class="fas fa-clock me-1"></i><%= new Date(job.scheduledDate).toLocaleDateString('ar') %>
                </small>
              </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Busy Periods Management -->
  <div class="row">
    <div class="col-12">
      <div class="card-modern">
        <div class="card-header" style="background: var(--bg-light); color: var(--text-dark);">
          <i class="fas fa-ban me-2"></i>إدارة فترات الانشغال
        </div>
        <div class="card-body">
          <form action="/painter/availability/busy-period" method="POST" class="mb-4">
            <div class="row">
              <div class="col-md-3 mb-3">
                <label for="startDate" class="form-label fw-bold">تاريخ البدء *</label>
                <input type="date" class="form-control" id="startDate" name="startDate" 
                       min="<%= new Date().toISOString().split('T')[0] %>" required>
              </div>
              <div class="col-md-3 mb-3">
                <label for="endDate" class="form-label fw-bold">تاريخ الانتهاء *</label>
                <input type="date" class="form-control" id="endDate" name="endDate" 
                       min="<%= new Date().toISOString().split('T')[0] %>" required>
              </div>
              <div class="col-md-4 mb-3">
                <label for="busyReason" class="form-label fw-bold">السبب *</label>
                <input type="text" class="form-control" id="busyReason" name="reason" 
                       placeholder="مثال: إجازة، وقت شخصي..." required>
              </div>
              <div class="col-md-2 mb-3 d-flex align-items-end">
                <button type="submit" class="btn-outline-warning-custom w-100">
                  <i class="fas fa-plus me-2"></i>إضافة
                </button>
              </div>
            </div>
          </form>

          <% if (painter.busyPeriods && painter.busyPeriods.length > 0) { %>
            <h6 class="fw-bold mb-3">فترات الانشغال المجدولة:</h6>
            <div class="list-group">
              <% painter.busyPeriods.forEach(period => { %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= period.reason %></strong><br>
                  <small class="text-muted">
                    <%= new Date(period.startDate).toLocaleDateString('ar') %> - <%= new Date(period.endDate).toLocaleDateString('ar') %>
                  </small>
                </div>
                <form action="/painter/availability/busy-period/remove" method="POST" class="d-inline">
                  <input type="hidden" name="periodId" value="<%= period._id %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm" 
                          onclick="return confirm('هل تريد إزالة فترة الانشغال هذه؟')">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="text-center py-4">
              <i class="fas fa-calendar-check fa-2x text-muted mb-3"></i>
              <p class="text-muted">لا توجد فترات انشغال مجدولة</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Show/hide unavailable fields based on status selection
document.getElementById('status').addEventListener('change', function() {
    const unavailableFields = document.getElementById('unavailableFields');
    if (this.value === 'unavailable') {
        unavailableFields.style.display = 'block';
    } else {
        unavailableFields.style.display = 'none';
    }
});

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    const statusSelect = document.getElementById('status');
    if (statusSelect) {
        statusSelect.dispatchEvent(new Event('change'));
    }

    // Ensure end date is not before start date
    const startDate = document.getElementById('startDate');
    const endDate = document.getElementById('endDate');
    if (startDate && endDate) {
        startDate.addEventListener('change', function() {
            endDate.min = this.value;
            if (endDate.value && endDate.value < this.value) {
                endDate.value = this.value;
            }
        });
    }
});
</script>

<%- include('../partials/footer') %>
