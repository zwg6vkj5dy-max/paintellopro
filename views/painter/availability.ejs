<%- include('../partials/header', { 
    title: 'إدارة التوفر - بينتيلو برو',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">
                    <i class="fas fa-calendar-check me-2 text-primary"></i>إدارة التوفر
                </h1>
                <a href="/painter/dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>العودة للوحة التحكم
                </a>
            </div>

            <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
            
            <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <div class="row">
                <!-- بطاقة الحالة الحالية -->
                <div class="col-lg-4 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-user-clock me-2"></i>الحالة الحالية
                            </h5>
                        </div>
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <% if (painter.availability === 'available') { %>
                                    <span class="badge bg-success fs-6 p-3">
                                        <i class="fas fa-check-circle me-2"></i>متاح
                                    </span>
                                <% } else if (painter.availability === 'busy') { %>
                                    <span class="badge bg-warning fs-6 p-3">
                                        <i class="fas fa-clock me-2"></i>مشغول
                                    </span>
                                <% } else { %>
                                    <span class="badge bg-danger fs-6 p-3">
                                        <i class="fas fa-times-circle me-2"></i>غير متاح
                                    </span>
                                <% } %>
                            </div>
                            <p class="text-muted small mb-0">
                                <% if (painter.availability === 'available') { %>
                                    يمكن للعملاء رؤيتك في نتائج البحث وإرسال طلبات العمل.
                                <% } else if (painter.availability === 'busy') { %>
                                    أنت مرئي ولكن قد يكون لديك توفر محدود.
                                <% } else { %>
                                    أنت مخفي من نتائج البحث.
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- تحديث الحالة السريع -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-sync-alt me-2"></i>تحديث الحالة
                            </h5>
                        </div>
                        <div class="card-body">
                            <form action="/painter/availability/status" method="POST">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="status" class="form-label">حالة التوفر *</label>
                                        <select class="form-select" id="status" name="status" required>
                                            <option value="available" <%= painter.availability === 'available' ? 'selected' : '' %>>متاح للمشاريع الجديدة</option>
                                            <option value="busy" <%= painter.availability === 'busy' ? 'selected' : '' %>>مشغول (توفر محدود)</option>
                                            <option value="unavailable" <%= painter.availability === 'unavailable' ? 'selected' : '' %>>غير متاح</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="reason" class="form-label">السبب (اختياري)</label>
                                        <input type="text" class="form-control" id="reason" name="reason" 
                                               placeholder="مثال: إجازة، جدول ممتلئ...">
                                    </div>
                                </div>
                                <div class="row" id="unavailableFields" style="display: none;">
                                    <div class="col-12 mb-3">
                                        <label for="availableFrom" class="form-label">متاح من تاريخ</label>
                                        <input type="date" class="form-control" id="availableFrom" name="availableFrom"
                                               min="<%= new Date().toISOString().split('T')[0] %>">
                                        <div class="form-text">متى ستكون متاحاً مرة أخرى؟</div>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>تحديث الحالة
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- نظرة عامة على العمل الحالي -->
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-paint-roller me-2"></i>المهام الحالية
                                <span class="badge bg-light text-dark ms-2"><%= currentJobs.length %></span>
                            </h5>
                        </div>
                        <div class="card-body">
                            <% if (currentJobs.length === 0) { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-clipboard-list fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">لا توجد مهام نشطة</p>
                                </div>
                            <% } else { %>
                                <div class="list-group list-group-flush">
                                    <% currentJobs.forEach(job => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1"><%= job.serviceType %></h6>
                                            <small class="text-muted"><%= job.client.name %></small>
                                        </div>
                                        <span class="badge bg-primary">
                                            <%= job.status === 'completed' ? 'مكتمل' :
                                               job.status === 'in_progress' ? 'قيد التنفيذ' :
                                               job.status === 'accepted' ? 'مقبول' :
                                               job.status === 'pending' ? 'معلق' : job.status %>
                                        </span>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">
                                <i class="fas fa-calendar me-2"></i>المهام القادمة
                                <span class="badge bg-light text-dark ms-2"><%= upcomingJobs.length %></span>
                            </h5>
                        </div>
                        <div class="card-body">
                            <% if (upcomingJobs.length === 0) { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-calendar-times fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">لا توجد مهام قادمة</p>
                                </div>
                            <% } else { %>
                                <div class="list-group list-group-flush">
                                    <% upcomingJobs.forEach(job => { %>
                                    <div class="list-group-item">
                                        <h6 class="mb-1"><%= job.serviceType %></h6>
                                        <small class="text-muted">
                                            <i class="fas fa-user me-1"></i><%= job.client.name %><br>
                                            <i class="fas fa-clock me-1"></i><%= new Date(job.scheduledDate).toLocaleDateString('ar') %>
                                        </small>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- إدارة فترات الانشغال -->
            <div class="row">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-ban me-2"></i>إدارة فترات الانشغال
                            </h5>
                        </div>
                        <div class="card-body">
                            <form action="/painter/availability/busy-period" method="POST" class="mb-4">
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label for="startDate" class="form-label">تاريخ البدء *</label>
                                        <input type="date" class="form-control" id="startDate" name="startDate" 
                                               min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="endDate" class="form-label">تاريخ الانتهاء *</label>
                                        <input type="date" class="form-control" id="endDate" name="endDate" 
                                               min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="reason" class="form-label">السبب *</label>
                                        <input type="text" class="form-control" id="reason" name="reason" 
                                               placeholder="مثال: إجازة، وقت شخصي..." required>
                                    </div>
                                    <div class="col-md-2 mb-3 d-flex align-items-end">
                                        <button type="submit" class="btn btn-outline-warning w-100">
                                            <i class="fas fa-plus me-2"></i>إضافة
                                        </button>
                                    </div>
                                </div>
                            </form>

                            <% if (painter.busyPeriods && painter.busyPeriods.length > 0) { %>
                                <h6 class="mb-3">فترات الانشغال المجدولة:</h6>
                                <div class="list-group">
                                    <% painter.busyPeriods.forEach(period => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong><%= period.reason %></strong><br>
                                            <small class="text-muted">
                                                <%= new Date(period.startDate).toLocaleDateString('ar') %> - <%= new Date(period.endDate).toLocaleDateString('ar') %>
                                            </small>
                                        </div>
                                        <form action="/painter/availability/busy-period/remove" method="POST" class="d-inline">
                                            <input type="hidden" name="periodId" value="<%= period._id %>">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" 
                                                    onclick="return confirm('هل تريد إزالة فترة الانشغال هذه؟')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-calendar-check fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">لا توجد فترات انشغال مجدولة</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// إظهار/إخفاء حقول غير متاح بناءً على الحالة
document.getElementById('status').addEventListener('change', function() {
    const unavailableFields = document.getElementById('unavailableFields');
    if (this.value === 'unavailable') {
        unavailableFields.style.display = 'block';
    } else {
        unavailableFields.style.display = 'none';
    }
});

// التهيئة عند تحميل الصفحة
document.addEventListener('DOMContentLoaded', function() {
    const statusSelect = document.getElementById('status');
    if (statusSelect) {
        statusSelect.dispatchEvent(new Event('change'));
    }

    // تعيين الحد الأدنى لتاريخ الانتهاء بناءً على تاريخ البدء
    const startDate = document.getElementById('startDate');
    const endDate = document.getElementById('endDate');
    
    if (startDate && endDate) {
        startDate.addEventListener('change', function() {
            endDate.min = this.value;
            if (endDate.value && endDate.value < this.value) {
                endDate.value = this.value;
            }
        });
    }
});
</script>

<%- include('../partials/footer') %>
