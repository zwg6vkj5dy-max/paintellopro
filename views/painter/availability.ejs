<%- include('../partials/header', { 
    title: 'Manage Availability - Paintello Pro',
    user: painter,
    painter: painter 
}) %>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">
                    <i class="fas fa-calendar-check me-2 text-primary"></i>Manage Availability
                </h1>
                <a href="/painter/dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>

            <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i><%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
            
            <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <div class="row">
                <!-- Current Status Card -->
                <div class="col-lg-4 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-user-clock me-2"></i>Current Status
                            </h5>
                        </div>
                        <div class="card-body text-center">
                            <div class="mb-3">
                                <% if (painter.availability === 'available') { %>
                                    <span class="badge bg-success fs-6 p-3">
                                        <i class="fas fa-check-circle me-2"></i>Available
                                    </span>
                                <% } else if (painter.availability === 'busy') { %>
                                    <span class="badge bg-warning fs-6 p-3">
                                        <i class="fas fa-clock me-2"></i>Busy
                                    </span>
                                <% } else { %>
                                    <span class="badge bg-danger fs-6 p-3">
                                        <i class="fas fa-times-circle me-2"></i>Unavailable
                                    </span>
                                <% } %>
                            </div>
                            <p class="text-muted small mb-0">
                                <% if (painter.availability === 'available') { %>
                                    Clients can see you in search results and send job requests.
                                <% } else if (painter.availability === 'busy') { %>
                                    You're visible but may have limited availability.
                                <% } else { %>
                                    You're hidden from search results.
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Quick Status Update -->
                <div class="col-lg-8 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-sync-alt me-2"></i>Update Status
                            </h5>
                        </div>
                        <div class="card-body">
                            <form action="/painter/availability/status" method="POST">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="status" class="form-label">Availability Status *</label>
                                        <select class="form-select" id="status" name="status" required>
                                            <option value="available" <%= painter.availability === 'available' ? 'selected' : '' %>>Available for new projects</option>
                                            <option value="busy" <%= painter.availability === 'busy' ? 'selected' : '' %>>Busy (Limited availability)</option>
                                            <option value="unavailable" <%= painter.availability === 'unavailable' ? 'selected' : '' %>>Unavailable</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="reason" class="form-label">Reason (Optional)</label>
                                        <input type="text" class="form-control" id="reason" name="reason" 
                                               placeholder="e.g., Vacation, Full schedule...">
                                    </div>
                                </div>
                                <div class="row" id="unavailableFields" style="display: none;">
                                    <div class="col-12 mb-3">
                                        <label for="availableFrom" class="form-label">Available From Date</label>
                                        <input type="date" class="form-control" id="availableFrom" name="availableFrom"
                                               min="<%= new Date().toISOString().split('T')[0] %>">
                                        <div class="form-text">When will you be available again?</div>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Update Status
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Current Work Overview -->
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-paint-roller me-2"></i>Current Jobs
                                <span class="badge bg-light text-dark ms-2"><%= currentJobs.length %></span>
                            </h5>
                        </div>
                        <div class="card-body">
                            <% if (currentJobs.length === 0) { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-clipboard-list fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">No active jobs</p>
                                </div>
                            <% } else { %>
                                <div class="list-group list-group-flush">
                                    <% currentJobs.forEach(job => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1"><%= job.serviceType %></h6>
                                            <small class="text-muted"><%= job.client.name %></small>
                                        </div>
                                        <span class="badge bg-primary"><%= job.status.replace('_', ' ') %></span>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">
                                <i class="fas fa-calendar me-2"></i>Upcoming Jobs
                                <span class="badge bg-light text-dark ms-2"><%= upcomingJobs.length %></span>
                            </h5>
                        </div>
                        <div class="card-body">
                            <% if (upcomingJobs.length === 0) { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-calendar-times fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">No upcoming jobs</p>
                                </div>
                            <% } else { %>
                                <div class="list-group list-group-flush">
                                    <% upcomingJobs.forEach(job => { %>
                                    <div class="list-group-item">
                                        <h6 class="mb-1"><%= job.serviceType %></h6>
                                        <small class="text-muted">
                                            <i class="fas fa-user me-1"></i><%= job.client.name %><br>
                                            <i class="fas fa-clock me-1"></i><%= new Date(job.scheduledDate).toLocaleDateString() %>
                                        </small>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Busy Periods Management -->
            <div class="row">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-ban me-2"></i>Manage Busy Periods
                            </h5>
                        </div>
                        <div class="card-body">
                            <form action="/painter/availability/busy-period" method="POST" class="mb-4">
                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label for="startDate" class="form-label">Start Date *</label>
                                        <input type="date" class="form-control" id="startDate" name="startDate" 
                                               min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-3 mb-3">
                                        <label for="endDate" class="form-label">End Date *</label>
                                        <input type="date" class="form-control" id="endDate" name="endDate" 
                                               min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label for="reason" class="form-label">Reason *</label>
                                        <input type="text" class="form-control" id="reason" name="reason" 
                                               placeholder="e.g., Vacation, Personal time..." required>
                                    </div>
                                    <div class="col-md-2 mb-3 d-flex align-items-end">
                                        <button type="submit" class="btn btn-outline-warning w-100">
                                            <i class="fas fa-plus me-2"></i>Add
                                        </button>
                                    </div>
                                </div>
                            </form>

                            <% if (painter.busyPeriods && painter.busyPeriods.length > 0) { %>
                                <h6 class="mb-3">Scheduled Busy Periods:</h6>
                                <div class="list-group">
                                    <% painter.busyPeriods.forEach(period => { %>
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong><%= period.reason %></strong><br>
                                            <small class="text-muted">
                                                <%= new Date(period.startDate).toLocaleDateString() %> - <%= new Date(period.endDate).toLocaleDateString() %>
                                            </small>
                                        </div>
                                        <form action="/painter/availability/busy-period/remove" method="POST" class="d-inline">
                                            <input type="hidden" name="periodId" value="<%= period._id %>">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" 
                                                    onclick="return confirm('Remove this busy period?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-3">
                                    <i class="fas fa-calendar-check fa-2x text-muted mb-2"></i>
                                    <p class="text-muted mb-0">No busy periods scheduled</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Show/hide unavailable fields based on status
document.getElementById('status').addEventListener('change', function() {
    const unavailableFields = document.getElementById('unavailableFields');
    if (this.value === 'unavailable') {
        unavailableFields.style.display = 'block';
    } else {
        unavailableFields.style.display = 'none';
    }
});

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    const statusSelect = document.getElementById('status');
    if (statusSelect) {
        statusSelect.dispatchEvent(new Event('change'));
    }

    // Set min date for end date based on start date
    const startDate = document.getElementById('startDate');
    const endDate = document.getElementById('endDate');
    
    if (startDate && endDate) {
        startDate.addEventListener('change', function() {
            endDate.min = this.value;
            if (endDate.value && endDate.value < this.value) {
                endDate.value = this.value;
            }
        });
    }
});
</script>

<%- include('../partials/footer') %>
